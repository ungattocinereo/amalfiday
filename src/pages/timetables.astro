---
import BaseLayout from '../layouts/BaseLayout.astro'
import { site } from '../data/site'
const heroImage = '/staticpages/timetables/bus-timetables-amalfi-coast.jpg'

const pageTitle = 'Local Transport Timetables — Amalfi Coast Buses & Shuttles'
const pageDescription =
  'Download the latest SitaBus (SITA) timetables for the Amalfi Coast and plan bus, shuttle, train, and taxi connections between Salerno, Amalfi, Positano, and Sorrento.'
const shareImageAlt = 'SITA bus traveling along the Amalfi Coast'

const heroSlides = [
  {
    image: heroImage,
    label: 'SITA bus',
    alt: 'SITA bus traveling along the Amalfi Coast road',
    position: 'center',
  },
  {
    image: '/staticpages/timetables/hero-bus-amalfi-harbor.jpg',
    label: 'Amalfi stop',
    alt: 'SITA buses waiting near Amalfi harbor',
    position: 'center',
  },
  {
    image: '/staticpages/timetables/hero-bus-amalfi-road.jpg',
    label: 'Coastal road',
    alt: 'SITA bus driving through Amalfi on the coastal road',
    position: 'center',
  },
]

const heroTags = [
  'Salerno',
  'Amalfi',
  'Atrani',
  'Maiori',
  'Positano',
  'Sorrento',
]

const heroStats = [
  { value: '6', label: 'bus lines' },
  { value: '2026', label: 'updated files' },
  { value: '4', label: 'ticket apps' },
]

const introParagraphs = [
  'Planning your dream vacation along the breathtaking Amalfi Coast? Perfect timing! The official 2025 SITA bus schedules are now available for download, offering seamless connectivity between all the iconic coastal gems - Salerno, Maiori, Minori, Amalfi, Positano, and Sorrento.',
  "These updated timetables ensure you can effortlessly navigate Italy's most spectacular coastline while maximizing your time in each charming destination. Download now to experience the Amalfi Coast's winding cliffside roads and panoramic Mediterranean views with complete confidence in your travel plans.",
  'Experience the Amalfi Coast like a local:',
  'Embrace the relaxed pace of life and enjoy the scenic coastal journey. The new 2025 bus timetables empower you to discover the hidden gems and captivating beauty of each town along the Amalfi Coast, making your Italian adventure unforgettable.',
]

const timetables = [
  {
    number: '5120',
    updated: 'Updated: Apr 1, 2026',
    route: ['Amalfi', 'Atrani', 'Minori', 'Maiori', 'Cetara', 'Vietri sul Mare', 'Salerno'],
    link: 'https://amalfi.day/files/BUS-timetables.pdf',
  },
  {
    number: '5110',
    updated: 'Updated: Apr 1, 2026',
    route: [
      'Scala',
      'Minuta',
      'San Pietro',
      'Sambuco',
      'Ravello',
      'Pontone',
      'Ravello',
      'Amalfi',
    ],
    link: 'https://amalfi.day/files/BUS-timetables.pdf',
  },
  {
    number: '5080',
    updated: 'Updated: Apr 1, 2026',
    route: ['Amalfi', 'Conca', 'Furore', 'Agerola', 'Pimonte', 'Gragnano', 'Castellammare', 'Napoli'],
    link: 'https://amalfi.day/files/BUS-5080-AMALFI-AGEROLA-GRAGNANO-CASTELLAMMARE-NAPOLI.pdf',
  },
  {
    number: '5020',
    updated: 'Updated: Apr 1, 2026',
    route: [
      'Amalfi',
      'Atrani',
      'Minori',
      'Maiori',
      'Cetara',
      'Vietri sul Mare',
      "Cava de' Tirreni",
      'Nocera',
      'Napoli',
    ],
    link: 'https://amalfi.day/files/BUS-5020-AMALFI-NAPOLI.pdf',
  },
  {
    number: '5010',
    updated: 'Updated: Apr 1, 2026',
    route: [
      'Maiori',
      'Tramonti',
      'Corbara',
      'San Egidio',
      'Pagani',
      'Nocera',
      "Cava de' Tirreni",
      'Salerno',
    ],
    link: 'https://amalfi.day/files/BUS-5010-MAIORI-TRAMONTI-NOCERA-INFERIORE-CAVA-SALERNO.pdf',
  },
  {
    number: '5070',
    updated: 'Updated: Apr 1, 2026',
    route: [
      'Amalfi',
      'Conca',
      'Praiano',
      'Positano',
      'Colli San Pietro',
      'Meta',
      'San Agnello',
      'Colli Fontanelle',
      "Sant' Agata",
      'Priora',
      'Sorrento',
      'Piano di Sorrento',
    ],
    link: 'https://amalfi.day/files/BUS-5070-AMALFI-POSITANO-SORRENTO.pdf',
  },
]

const ticketApps = [
  {
    name: 'MooneyGo',
    kind: 'Transport app / web planner',
    logo: '/staticpages/how-to-get/logos/mooneygo-logo.svg',
    logoAlt: 'MooneyGo logo',
    buy: 'Bus, metro, train, taxi and mobility tickets',
    bestFor: 'All-in-one public transport checks before moving around Naples and Campania',
    note: 'Good backup app when coverage fits your route; verify the operator before buying.',
    href: 'https://www.mooneygo.it/trasporti/',
    action: 'Open MooneyGo',
  },
  {
    name: 'Unico Campania',
    kind: 'Campania ticket system',
    logo: '/staticpages/how-to-get/logos/unico-campania-logo.svg',
    logoAlt: 'Unico Campania logo',
    buy: 'Unico tickets, fare checks, App Unico and points of sale',
    bestFor: 'Naples and Campania urban fares, Tap&Go, and official tariff checks',
    note: 'Use it to confirm the official Campania fare system before choosing a ticket.',
    href: 'https://www.unicocampania.it',
    action: 'Open Unico',
  },
  {
    name: 'Trenitalia App',
    kind: 'Train app',
    logo: '/staticpages/how-to-get/logos/trenitalia-logo.svg',
    logoAlt: 'Trenitalia logo',
    buy: 'Napoli Centrale to Salerno regional train tickets',
    bestFor: 'The train leg toward Salerno ferries or buses',
    note: 'Digital regional tickets are bought in the app or on the website.',
    href: 'https://www.trenitalia.com/en/information/trenitalia-app.html',
    action: 'Open Trenitalia',
  },
  {
    name: '.italo',
    kind: 'High-speed train app',
    logo: '/staticpages/how-to-get/logos/italo-logo.jpg',
    logoAlt: '.italo logo',
    logoTheme: 'italo',
    buy: 'Italo high-speed train tickets across Italy',
    bestFor: 'Rome, Naples, Florence, Milan and other fast train legs before reaching the coast',
    note: 'Compare Italo with Trenitalia for long-distance trains into Napoli Centrale or Salerno.',
    href: 'https://www.italotreno.com/en/app',
    action: 'Open Italo',
  },
]

const timetablesFaqs = [
  {
    q: 'How do I buy SITA bus tickets on the Amalfi Coast?',
    a: 'Buy tickets at any Tabacchi shop displaying the "T" sign before you board — drivers do not sell tickets on the bus. Tickets cost from 1.50 to 2.40 EUR depending on the route. Validate the ticket in the small machine when you board.',
  },
  {
    q: 'Which bus line runs from Amalfi to Salerno?',
    a: 'Line 5120 connects Amalfi → Atrani → Minori → Maiori → Cetara → Vietri sul Mare → Salerno. It is the main coastal line and runs frequently throughout the day.',
  },
  {
    q: 'How do I get from Amalfi to Positano by bus?',
    a: 'Take SITA line 5070, which runs Amalfi → Positano → Sorrento, stopping in Praiano along the way. The route follows the SS163 with dramatic coastal views — sit on the seaward side if you can.',
  },
  {
    q: 'Are there ferries from Amalfi to Capri or Positano?',
    a: 'Yes — TravelMar, Alicost, and other operators run seasonal ferries from Amalfi to Positano, Capri, Salerno, and Sorrento. Routes operate roughly April through October. Download the latest ferry timetables PDF for current schedules.',
  },
  {
    q: 'How do I get from Naples airport to Amalfi or Atrani?',
    a: 'Take a train from Napoli Centrale to Salerno (about an hour), then either ferry or SITA bus 5120 to Amalfi. From Amalfi it is a 10-minute walk along the waterfront to Atrani.',
  },
]

const timetablesJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: pageTitle,
    description: pageDescription,
    url: `${site.url}/timetables`,
    image: new URL(heroImage, site.url).toString(),
    author: { '@id': `${site.url}/#business` },
    publisher: { '@id': `${site.url}/#business` },
    inLanguage: 'en',
    about: { '@type': 'Place', name: 'Amalfi Coast' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: timetablesFaqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: 'Timetables', item: `${site.url}/timetables` },
    ],
  },
]
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={heroImage}
  imageAlt={shareImageAlt}
  jsonLd={timetablesJsonLd}
>
  <section class="timetables-hero hero--dark">
    <div class="timetables-hero__slides" aria-hidden="true">
      {heroSlides.map((slide, i) => (
        <div class={`timetables-hero__slide ${i === 0 ? 'is-active' : ''}`}>
          <img
            src={slide.image}
            alt={slide.alt}
            loading={i === 0 ? 'eager' : 'lazy'}
            style={`object-position: ${slide.position};`}
          />
        </div>
      ))}
    </div>
    <div class="timetables-hero__vignette"></div>
    <div class="timetables-hero__content">
      <div class="container">
        <div class="timetables-hero__grid">
          <div class="timetables-hero__copy">
            <span class="timetables-hero__eyebrow">Amalfi Coast public transport 2026</span>
            <h1 class="timetables-hero__title">
              Local<br />transport<br />timetables
            </h1>
            <p class="timetables-hero__lead">
              SITA bus lines, local shuttles, taxis, trains, and ticket apps for moving between
              Salerno, Amalfi, Positano, Sorrento, and the coastal villages.
            </p>
            <div class="timetables-hero__stats">
              {heroStats.map((item) => (
                <div class="timetables-hero__stat">
                  <strong>{item.value}</strong>
                  <span>{item.label}</span>
                </div>
              ))}
            </div>
            <div class="timetables-hero__actions">
              <a class="timetables-hero__btn timetables-hero__btn--primary" href="https://cnr.pw/bus" target="_blank" rel="noreferrer">Download bus PDFs</a>
              <a class="timetables-hero__btn timetables-hero__btn--ghost" href="#tickets">Ticket apps</a>
            </div>
          </div>
          <div class="timetables-hero__aside">
            <ul class="timetables-hero__tags">
              {heroTags.map((tag, i) => (
                <li class="timetables-hero__tag" style={`animation-delay: ${0.6 + i * 0.08}s`}>{tag}</li>
              ))}
            </ul>
            <div class="timetables-hero__progress">
              {heroSlides.map((slide, i) => (
                <button
                  class={`timetables-hero__dot ${i === 0 ? 'is-active' : ''}`}
                  type="button"
                  data-slide={i}
                  aria-label={`Show ${slide.label}`}
                >
                  <span class="timetables-hero__dot-label">{slide.label}</span>
                  <span class="timetables-hero__dot-bar"><span class="timetables-hero__dot-fill"></span></span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="timetables-hero__scroll-hint" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <section class="section timetables-section">
    <div class="container timetables-intro">
      <div class="section-heading">
        <span class="section-kicker">SITA bus files</span>
        <h2>
          New 2026 <span class="accent-italic">Timetables</span>
        </h2>
        <p>
          Download the latest SITA bus schedules for the main Amalfi Coast routes and keep
          them offline for quick route checks.
        </p>
      </div>

      <div class="timetables-intro__details">
        <div class="timetables-copy">
          <p>{introParagraphs[0]}</p>
          <p>{introParagraphs[1]}</p>
          <p class="timetables-copy__highlight">{introParagraphs[2]}</p>
          <p>{introParagraphs[3]}</p>
        </div>
        <div class="timetables-update">
          <span class="badge">
            <i class="fa-solid fa-clock"></i>
            Updated: Apr 1, 2026
          </span>
        </div>
      </div>
    </div>

    <div class="container timetables-grid">
      <div class="timetables-list">
        {timetables.map((line) => (
          <article class="timetable-card">
            <div class="timetable-card__meta">
              <span class="timetable-chip timetable-chip--number">{line.number}</span>
              <span class="timetable-chip timetable-chip--date">
                <i class="fa-solid fa-calendar"></i>
                {line.updated}
              </span>
            </div>
            <div class="timetable-card__route">
              {line.route.map((stop, index) => (
                <span class="route-node">
                  <span
                    class={`route-stop ${
                      index === 0 || index === line.route.length - 1 ? 'route-stop--strong' : ''
                    }`}
                  >
                    {stop}
                  </span>
                  {index < line.route.length - 1 && (
                    <span class="route-arrow" aria-hidden="true">
                      &rarr;
                    </span>
                  )}
                </span>
              ))}
            </div>
            <div class="timetable-card__actions">
              <a class="timetable-download" href={line.link} target="_blank" rel="noreferrer">
                <i class="fa-solid fa-cloud-arrow-down"></i>
                Download
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="container amico-block">
      <div class="section-heading">
        <span class="section-kicker">Local shuttle</span>
        <h2>
          Amico Shuttle <span class="accent-italic">From Amalfi-Ravello</span>
        </h2>
        <p>
          Book the Amalfi-Ravello shuttle online before you travel and check the luggage rules
          before boarding.
        </p>
      </div>
      <p>
        You can buy Online Ticket here (
        <a href="https://www.amicoshuttle.com/en/" target="_blank" rel="noreferrer">
          https://www.amicoshuttle.com/en/
        </a>
        )
      </p>
      <p class="amico-block__price">
        10,00€ one way - 16,00€ round trip (Children 0-3 free) and the luggage is not allowed on
        this bus
      </p>
      <a class="timetable-download amico-block__download" href="https://cnr.pw/amico" target="_blank" rel="noreferrer">
        <i class="fa-solid fa-cloud-arrow-down"></i>
        Download timetable
      </a>
    </div>

    <div class="container tickets-block" id="tickets">
      <div class="section-heading tickets-header">
        <span class="section-kicker">Before you board</span>
        <h2>
          How to buy <span class="accent-italic">bus tickets</span> in Amalfi Coast
        </h2>
        <p>
          Paper tickets are still the simplest option for SITA buses. Buy them before boarding,
          validate once you step on the bus, and keep the ticket until the end of the ride.
        </p>
      </div>

      <div class="tickets-grid">
        <div class="tickets-info">
          <div class="tickets-icon">
            <i class="fa-solid fa-ticket"></i>
          </div>

          <ol class="ticket-steps">
            <li class="ticket-step">
              <span class="ticket-step__number">01</span>
              <div>
                <h3>Buy before boarding</h3>
                <p>
                  Use the newsstand in the train station or any Tabacchi shop with the letter
                  "T" sign.
                </p>
              </div>
            </li>
            <li class="ticket-step">
              <span class="ticket-step__number">02</span>
              <div>
                <h3>Validate on the bus</h3>
                <p>
                  Stamp the paper ticket in the small machine after you board, then keep it with
                  you for checks.
                </p>
              </div>
            </li>
            <li class="ticket-step">
              <span class="ticket-step__number">03</span>
              <div>
                <h3>Activate app tickets first</h3>
                <p>
                  If you use a digital ticket, activate it in the app before the trip starts.
                </p>
              </div>
            </li>
          </ol>

          <div class="tickets-note">
            <i class="fa-solid fa-circle-exclamation" aria-hidden="true"></i>
            <p>
              Drivers usually expect passengers to board with a paper ticket or an already
              activated digital ticket.
            </p>
          </div>
        </div>
        <figure class="tickets-image">
          <img
            src="/staticpages/timetables/TABACCI.webp"
            alt="Travelers buying bus tickets at a Tabacchi shop on the Amalfi Coast"
            loading="lazy" width="1200" height="1200"
          />
        </figure>
      </div>

      <div class="tickets-apps">
        <div class="section-heading tickets-apps__intro">
          <span class="section-kicker">Digital backup</span>
          <h3>Apps for tickets and train legs</h3>
          <p>
            You can also use apps for some bus, Campania public transport, and train tickets.
            Activate electronic bus tickets in the app before boarding, and recheck the operator
            shown for your route before buying.
          </p>
        </div>

        <div class="ticket-grid">
          {ticketApps.map((app) => (
            <a class="ticket-card" href={app.href} target="_blank" rel="noreferrer">
              <figure class={`ticket-card__media ${app.logoTheme ? `ticket-card__media--${app.logoTheme}` : ''}`}>
                <img
                  src={app.logo}
                  alt={app.logoAlt}
                  loading="lazy"
                  decoding="async"
                />
              </figure>

              <div class="ticket-card__body">
                <h3>{app.name}</h3>
                <p class="ticket-card__kind">{app.kind}</p>

                <div class="ticket-card__divider"></div>

                <div class="ticket-card__meta ticket-card__meta--buy">
                  <i class="fa-solid fa-ticket" aria-hidden="true"></i>
                  <strong>{app.buy}</strong>
                </div>

                <div class="ticket-card__divider"></div>

                <div class="ticket-card__meta">
                  <i class="fa-solid fa-route" aria-hidden="true"></i>
                  <span>{app.bestFor}</span>
                </div>
              </div>

              <div class="ticket-card__footer">
                <p class="ticket-card__note">{app.note}</p>
                <span class="ticket-card__action" aria-label={app.action}>
                  <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="container travel-section">
      <div class="section-heading">
        <span class="section-kicker">Connections</span>
        <h2>
          Fastest ways to Amalfi: <span class="accent-italic">shuttle or taxi</span>
        </h2>
        <p class="travel-lead">
          If you're arriving from another part of Italy, the quickest door-to-door options are a
          pre-booked shuttle or a private taxi from Naples, Salerno, or the nearest station.
          Trains are useful for the long leg, but the final coastal transfer is usually fastest
          by road.
        </p>
      </div>
      <div class="travel-grid">
        <article class="travel-card travel-card--split">
          <div class="travel-card__media">
            <img
              src="/staticpages/timetables/shuttle.webp"
              alt="Airport shuttle from Naples to Amalfi"
              loading="lazy" width="1200" height="1200"
            />
          </div>
          <div class="travel-card__content">
            <h3>
              <i class="fa-solid fa-bus"></i>
              Shuttle from airport
            </h3>
            <p>
              Shuttle services operated by PinTourBus from Naples Airport to Amalfi. There are 6
              daily races.
            </p>
            <a
              class="button travel-button"
              href="https://cnr.pw/shuttle"
              target="_blank"
              rel="noreferrer"
            >
              Book the shuttle
            </a>
          </div>
        </article>
        <article class="travel-card travel-card--split">
          <div class="travel-card__media">
            <img
              src="/staticpages/timetables/Taxi.webp"
              alt="Taxi on the Amalfi Coast"
              loading="lazy" width="1200" height="1200"
            />
          </div>
          <div class="travel-card__content">
            <h3>
              <i class="fa-solid fa-taxi"></i>
              Taxi
            </h3>
            <p>
              Taxi to Amalfi from Airport cost about 180€ from Salerno to Amalfi about 100€ .
              You can book a taxi at their website
            </p>
            <a
              class="button travel-button"
              href="https://radiotaxisalerno.it"
              target="_blank"
              rel="noreferrer"
            >
              Book a taxi
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section tt-faq">
    <div class="container">
      <div class="section-heading tt-faq__heading">
        <span class="section-kicker">Quick answers</span>
        <h2>Public transport <span class="accent-italic">FAQ</span></h2>
        <p>
          Short answers for the most common ticket, route, and connection questions on the Amalfi
          Coast.
        </p>
      </div>
      <div class="tt-faq__list">
        {timetablesFaqs.map((f) => (
          <details class="tt-faq__item">
            <summary class="tt-faq__q">{f.q}</summary>
            <p class="tt-faq__a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  ;(function () {
    const slides = document.querySelectorAll('.timetables-hero__slide')
    const dots = document.querySelectorAll('.timetables-hero__dot')
    if (!slides.length) return

    let current = 0
    const duration = 6000
    const FADE_DURATION = 1300
    const freezeTimers = new WeakMap()

    function clearSlideFreeze(slide) {
      const image = slide?.querySelector('img')
      if (!image) return
      image.style.animation = ''
      image.style.transform = ''
    }

    function freezeSlideTransform(slide) {
      const image = slide?.querySelector('img')
      if (!image) return

      const transform = window.getComputedStyle(image).transform
      image.style.animation = 'none'
      image.style.transform = transform === 'none' ? '' : transform

      window.clearTimeout(freezeTimers.get(slide))
      freezeTimers.set(
        slide,
        window.setTimeout(() => {
          if (!slide.classList.contains('is-active')) {
            clearSlideFreeze(slide)
          }
          freezeTimers.delete(slide)
        }, FADE_DURATION)
      )
    }

    function go(next) {
      if (next === current) return
      freezeSlideTransform(slides[current])
      slides[current].classList.remove('is-active')
      dots[current]?.classList.remove('is-active')
      current = next
      clearSlideFreeze(slides[current])
      slides[current].classList.add('is-active')
      dots[current]?.classList.add('is-active')
    }

    let timer = window.setInterval(() => go((current + 1) % slides.length), duration)

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        window.clearInterval(timer)
        go(Number(dot.dataset.slide))
        timer = window.setInterval(() => go((current + 1) % slides.length), duration)
      })
    })
  })()
</script>

<style>
  .timetables-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: #0a0a0a;
    color: #ffffff;
  }

  .timetables-hero__slides {
    position: absolute;
    inset: -2px;
    z-index: 0;
    overflow: hidden;
  }

  .timetables-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    backface-visibility: hidden;
  }

  .timetables-hero__slide.is-active {
    opacity: 1;
  }

  .timetables-hero__slide img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.86) saturate(1.02);
    transform: scale(1.01);
    backface-visibility: hidden;
  }

  .timetables-hero__slide.is-active img {
    animation: timetables-ken-burns 6.5s cubic-bezier(0.25, 0, 0.4, 1) forwards;
  }

  @keyframes timetables-ken-burns {
    from { transform: scale(1.01); }
    to { transform: scale(1.06); }
  }

  .timetables-hero__vignette {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(0deg, rgba(0, 0, 0, 0.78) 0%, rgba(0, 0, 0, 0.24) 45%, rgba(0, 0, 0, 0.08) 65%),
      linear-gradient(90deg, rgba(0, 0, 0, 0.44) 0%, transparent 52%),
      radial-gradient(ellipse at 50% 0%, transparent 48%, rgba(0, 0, 0, 0.24) 100%);
    pointer-events: none;
  }

  .timetables-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-bottom: clamp(2.5rem, 5vh, 4.5rem);
  }

  .timetables-hero__grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: end;
  }

  .timetables-hero__copy {
    max-width: 780px;
  }

  .timetables-hero__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0;
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1rem;
    opacity: 0;
    animation: timetables-fade-up 0.7s 0.15s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .timetables-hero__title {
    font-size: clamp(2.8rem, 6.5vw, 5.5rem);
    line-height: 1;
    letter-spacing: 0;
    margin: 0;
    color: #ffffff;
    opacity: 0;
    animation: timetables-fade-up 0.8s 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .timetables-hero__lead {
    max-width: 38rem;
    font-size: 1.05rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.78);
    margin-top: 1.2rem;
    opacity: 0;
    animation: timetables-fade-up 0.8s 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .timetables-hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.4rem;
    opacity: 0;
    animation: timetables-fade-up 0.8s 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .timetables-hero__stat {
    padding: 0.6rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .timetables-hero__stat strong {
    font-size: 1.1rem;
    color: #ff5900;
  }

  .timetables-hero__stat span {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.75);
  }

  .timetables-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.4rem;
    opacity: 0;
    animation: timetables-fade-up 0.8s 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .timetables-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 1.5rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
    cursor: pointer;
    border: none;
  }

  .timetables-hero__btn--primary {
    background: #ff5900;
    color: #ffffff;
  }

  .timetables-hero__btn--primary:hover {
    background: #ff7a33;
    transform: translateY(-1px);
    box-shadow: 0 8px 30px rgba(255, 89, 0, 0.35);
    text-decoration: none;
    color: #ffffff;
  }

  .timetables-hero__btn--ghost {
    background: rgba(255, 255, 255, 0.14);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .timetables-hero__btn--ghost:hover {
    background: rgba(255, 255, 255, 0.22);
    border-color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    color: #ffffff;
  }

  .timetables-hero__aside {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2rem;
    opacity: 0;
    animation: timetables-fade-up 0.8s 0.65s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .timetables-hero__tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
    max-width: 260px;
  }

  .timetables-hero__tag {
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.18);
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.78);
    opacity: 0;
    animation: timetables-fade-up 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .timetables-hero__progress {
    display: flex;
    gap: 0.6rem;
  }

  .timetables-hero__dot {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .timetables-hero__dot-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0;
    color: rgba(255, 255, 255, 0.9);
    opacity: 0.4;
    transition: opacity 0.4s ease;
  }

  .timetables-hero__dot.is-active .timetables-hero__dot-label {
    opacity: 1;
  }

  .timetables-hero__dot-bar {
    width: 36px;
    height: 2px;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 2px;
    overflow: hidden;
  }

  .timetables-hero__dot-fill {
    display: block;
    width: 100%;
    height: 100%;
    background: #ff5900;
    border-radius: 2px;
    transform-origin: left center;
    transform: scaleX(0);
  }

  .timetables-hero__dot.is-active .timetables-hero__dot-fill {
    animation: timetables-fill-bar 6s linear forwards;
  }

  @keyframes timetables-fill-bar {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .timetables-hero__scroll-hint {
    position: absolute;
    bottom: clamp(1rem, 2.5vh, 2rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    opacity: 0;
    animation: timetables-fade-up 0.6s 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .timetables-hero__scroll-hint span {
    display: block;
    width: 1px;
    height: 32px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.5), transparent);
    animation: timetables-scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes timetables-scroll-pulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.3); }
  }

  @keyframes timetables-fade-up {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .timetables-section {
    position: relative;
  }

  .timetables-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top left, rgba(255, 195, 0, 0.08), transparent 45%),
      radial-gradient(circle at bottom right, rgba(0, 156, 255, 0.08), transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  .timetables-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .timetables-intro {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
    padding-bottom: clamp(2rem, 5vw, 3.25rem);
    border-radius: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .timetables-intro__details {
    max-width: 48rem;
  }

  .section-heading {
    display: grid;
    gap: 0.55rem;
    max-width: 58rem;
  }

  .section-heading h2,
  .section-heading h3 {
    margin: 0;
    font-size: clamp(2.45rem, 4.8vw, 4.35rem);
    line-height: 1.04;
  }

  .section-heading p {
    max-width: 44rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: clamp(1rem, 1.5vw, 1.14rem);
    line-height: 1.6;
  }

  .section-kicker {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-accent);
    margin-bottom: 0.6rem;
  }

  .timetables-copy {
    margin-top: 0;
  }

  .timetables-copy p {
    margin-bottom: 1.2rem;
  }

  .timetables-copy__highlight {
    font-weight: 600;
    color: var(--color-text);
  }

  .timetables-update {
    margin-top: 1.8rem;
  }

  .timetables-update .badge {
    background: rgba(255, 89, 0, 0.12);
    color: var(--color-accent);
    border: 1px solid rgba(255, 89, 0, 0.18);
  }

  .timetables-list {
    grid-column: auto;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .timetable-card {
    display: flex;
    flex-direction: column;
    gap: 1.3rem;
    padding: 1.6rem;
    border-radius: var(--radius-lg);
    background: var(--color-card);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-soft);
  }

  .timetable-card__meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .timetable-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0;
    border-radius: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .timetable-chip--number {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 4vw, 3.6rem);
    color: var(--color-accent);
  }

  .timetable-chip--date {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
  }

  .timetable-card__route {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem 0.7rem;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .route-node {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .route-stop--strong {
    font-weight: 700;
  }

  .route-arrow {
    color: var(--color-accent);
    font-weight: 700;
  }

  .timetable-download {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    background: var(--gradient-sunset);
    color: #ffffff;
    font-weight: 600;
    border: none;
    box-shadow: 0 12px 30px rgba(255, 89, 0, 0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .timetable-card__actions {
    margin-top: auto;
  }

  .timetable-download::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: inherit;
    background: radial-gradient(circle, rgba(255, 195, 0, 0.45), transparent 60%);
    opacity: 0;
    filter: blur(8px);
    transition: opacity 0.2s ease;
    z-index: -1;
  }

  .timetable-download:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 40px rgba(255, 89, 0, 0.4);
    text-decoration: none;
  }

  .timetable-download:hover::after {
    opacity: 1;
  }

  .amico-block {
    margin-top: 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 48rem;
  }

  .amico-block p {
    margin: 0;
  }

  .amico-block p a {
    color: var(--color-accent);
    font-weight: 600;
  }

  .amico-block p a:hover {
    color: var(--color-accent-2);
  }

  .amico-block__price {
    font-family: var(--font-mono);
    color: var(--color-text);
  }

  .amico-block__download {
    align-self: flex-start;
  }

  .tickets-block {
    --ticket-ink: var(--color-text);
    --ticket-muted: var(--color-text-muted);
    --ticket-line: var(--color-border);
    --ticket-surface: var(--color-card);
    --ticket-soft: var(--color-surface);
    --ticket-orange: var(--color-accent);
    scroll-margin-top: calc(var(--header-space) + 1.5rem);
    margin-top: clamp(4.5rem, 7vw, 6.25rem);
    display: grid;
    gap: clamp(1.6rem, 3vw, 2.4rem);
  }

  .tickets-header {
    max-width: 62rem;
  }

  .tickets-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.98fr) minmax(20rem, 0.72fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: start;
  }

  .tickets-info {
    display: grid;
    align-content: start;
    gap: 1.35rem;
    padding-top: 0.35rem;
    color: var(--ticket-ink);
  }

  .tickets-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(255, 89, 0, 0.1);
    border: 1px solid rgba(255, 89, 0, 0.22);
    color: var(--ticket-orange);
    font-size: 1.35rem;
  }

  .ticket-steps {
    display: grid;
    gap: 1.05rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ticket-step {
    position: relative;
    display: grid;
    grid-template-columns: 3.2rem minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .ticket-step + .ticket-step::before {
    content: '';
    position: absolute;
    top: -1.05rem;
    left: 1.58rem;
    width: 1px;
    height: 1.05rem;
    background: rgba(255, 89, 0, 0.22);
  }

  .ticket-step__number {
    display: grid;
    place-items: center;
    width: 3.05rem;
    height: 3.05rem;
    border-radius: 50%;
    background: rgba(255, 89, 0, 0.08);
    border: 1px solid rgba(255, 89, 0, 0.22);
    color: var(--ticket-orange);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .ticket-step h3 {
    margin: 0 0 0.35rem;
    color: var(--ticket-ink);
    font-size: clamp(1.1rem, 1.7vw, 1.32rem);
    line-height: 1.18;
  }

  .ticket-step p {
    margin: 0;
    color: var(--ticket-muted);
    line-height: 1.55;
  }

  .tickets-note {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.75rem;
    align-items: start;
    margin-top: 0.3rem;
    padding: 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255, 89, 0, 0.2);
    background: rgba(255, 89, 0, 0.07);
  }

  .tickets-note i {
    margin-top: 0.18rem;
    color: var(--ticket-orange);
  }

  .tickets-note p {
    margin: 0;
    color: var(--ticket-ink);
    line-height: 1.45;
  }

  .tickets-image {
    position: relative;
    margin: 0;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lift);
    background: var(--ticket-soft);
  }

  .tickets-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tickets-apps {
    display: grid;
    gap: 1.25rem;
    padding-top: 0.35rem;
  }

  .tickets-apps__intro {
    max-width: 64rem;
  }

  .ticket-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .ticket-card {
    display: flex;
    flex-direction: column;
    min-height: 392px;
    overflow: hidden;
    padding: 0;
    color: var(--ticket-ink);
    border: 1px solid var(--ticket-line);
    border-radius: var(--radius-sm);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.76)),
      var(--ticket-surface);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .ticket-card:hover,
  .ticket-card:focus-visible {
    color: var(--ticket-ink);
    text-decoration: none;
    transform: translateY(-4px);
    border-color: rgba(255, 89, 0, 0.36);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.13);
  }

  .ticket-card__media {
    display: grid;
    place-items: center;
    min-height: 132px;
    margin: 0;
    padding: 1.2rem;
    border-bottom: 1px solid var(--ticket-line);
    background:
      radial-gradient(circle at 84% 18%, rgba(1, 98, 255, 0.1), transparent 34%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(239, 247, 245, 0.88)),
      var(--ticket-soft);
  }

  .ticket-card__media img {
    display: block;
    width: auto;
    max-width: min(82%, 220px);
    height: auto;
    max-height: 76px;
    object-fit: contain;
  }

  .ticket-card__media--italo {
    background: #A51B33;
  }

  .ticket-card__media--italo img {
    max-width: min(94%, 253px);
    max-height: 87px;
  }

  .ticket-card__body {
    display: flex;
    flex-direction: column;
    padding: 1rem 1rem 0.85rem;
  }

  .ticket-card h3 {
    margin-bottom: 0.35rem;
    font-size: 1.15rem;
    line-height: 1.2;
  }

  .ticket-card__kind {
    display: block;
    margin: 0;
    color: var(--ticket-orange);
    font: 400 0.72rem/1.4 var(--font-mono);
  }

  .ticket-card__divider {
    height: 1px;
    margin: 0.9rem 0;
    background: var(--ticket-line);
  }

  .ticket-card__meta {
    display: grid;
    grid-template-columns: 1.65rem minmax(0, 1fr);
    gap: 0.65rem;
    align-items: start;
  }

  .ticket-card__meta i {
    display: grid;
    place-items: center;
    width: 1.65rem;
    height: 1.65rem;
    border-radius: 50%;
    background: rgba(255, 89, 0, 0.12);
    color: var(--ticket-orange);
    font-size: 0.72rem;
  }

  .ticket-card__meta strong {
    display: block;
    color: var(--ticket-ink);
    font-size: 0.98rem;
    line-height: 1.3;
  }

  .ticket-card__meta span {
    display: block;
    color: var(--ticket-muted);
    font-size: 0.92rem;
    line-height: 1.42;
  }

  .ticket-card__footer {
    position: relative;
    margin-top: auto;
    min-height: 108px;
    padding: 0.82rem 3.1rem 1rem 1rem;
    background: linear-gradient(135deg, var(--ticket-orange), #d94700);
  }

  .ticket-card__note {
    margin: 0;
    color: #fff;
    font-size: 0.94rem;
    font-weight: 800;
    line-height: 1.35;
  }

  .ticket-card__action {
    position: absolute;
    right: 0;
    bottom: 0;
    display: grid;
    place-items: center;
    width: 2.65rem;
    height: 2.65rem;
    border-radius: var(--radius-sm) 0 0 0;
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
    font-size: 0.9rem;
  }

  .travel-section {
    margin-top: 4.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .travel-lead {
    max-width: 70rem;
  }

  .travel-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem;
    align-items: stretch;
  }

  .travel-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
    padding: 1.6rem;
    border-radius: var(--radius-sm);
    background: var(--color-card);
    border: 1px solid var(--color-border);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .travel-card--split {
    flex-direction: row;
    padding: 0;
    overflow: hidden;
  }

  .travel-card__media {
    flex: 0 0 40%;
    min-height: 100%;
    height: 100%;
  }

  .travel-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .travel-card__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.6rem;
  }

  .travel-card h3 {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
  }

  .travel-card h3 i {
    color: var(--color-accent);
  }

  .travel-card p {
    margin: 0;
