---
import { site } from '../../data/site'

const redirectTo = '/photoshootings'
const pageTitle = 'Photoshoots — Amalfi.Day'
const pageDescription =
  'Photo stories and galleries from Amalfi Coast sessions in Atrani, Ravello, Amalfi, and Positano.'
const shareImage = '/photoshootings/hero/influencer/3-berra-influenser-slider-slider.jpg'
const shareImageAlt = 'Amalfi Coast photoshoot hero scene'
const canonicalUrl = new URL(redirectTo, site.url).toString()
const ogImage = new URL(shareImage, site.url).toString()
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${redirectTo}`} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex, follow" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={shareImageAlt} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
  </head>
  <body>
    <p>Redirecting to <a href={redirectTo}>{redirectTo}</a></p>
  </body>
</html>
