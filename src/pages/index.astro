---
import BaseLayout from '../layouts/BaseLayout.astro'
import CldImage from '../components/CldImage.astro'
import { featuredPhotoshoots, heroLinks } from '../data/site'
import { getGhostPosts } from '../data/ghost'
import heroQuatrains from '../../hero-quatrains.json'

const pageTitle = 'Amalfi.Day — CristallPont Amalfi Day'
const pageDescription =
  'Amalfi.Day is a local guide for Amalfi Coast photoshoots, apartments in Atrani, beach reviews, and curated experiences in Amalfi, Ravello, and Positano.'
const shareImage = '/staticpages/video/atrani-sorrento-video.webp'
const shareImageAlt = 'Atrani to Sorrento coast'

const staticPages = [
  {
    title: 'Amalfi news',
    href: '/blog',
    note: 'Latest news and stories from the Amalfi Coast.',
    image: '/staticpages/index/blog-of-amalfi-coast.webp',
    imageAlt: 'Amalfi Coast blog and news',
  },
  {
    title: 'Public transport',
    href: '/timetables',
    note: 'Buses, ferries, and regional routes in one place.',
    image: '/staticpages/mainpage/allublictransport.webp',
    imageAlt: 'Public transport connections along the Amalfi Coast',
  },
  {
    title: 'Apartment rentals',
    href: '/apartments',
    note: 'Apartments, suites, and rooms near Atrani beach.',
    image: '/staticpages/mainpage/rental-houses.webp',
    imageAlt: 'Amalfi Coast apartments with sea view',
  },
  {
    title: 'Parking tips',
    href: '/parking',
    note: 'Where to park and how to avoid traffic.',
    image: '/staticpages/mainpage/parking.webp',
    imageAlt: 'Parking area on the Amalfi Coast',
  },
  {
    title: 'Beach reviews',
    href: '/beaches',
    note: 'Best spots for swimming, sun, and photos.',
    image: '/staticpages/mainpage/beach-reviews.webp',
    imageAlt: 'Amalfi Coast beach overview',
  },
  {
    title: 'Moto roads',
    href: '/moto',
    note: 'Scenic motorcycle routes along the coast.',
    image: '/staticpages/index/moto-roads-in-amalfi.webp',
    imageAlt: 'Motorcycle roads on the Amalfi Coast',
  },
]

const { posts: newsPosts } = await getGhostPosts({ limit: 8 })
const quatrains = Array.isArray(heroQuatrains) ? heroQuatrains : []
const fallbackQuatrain =
  Array.isArray(quatrains[0]) && quatrains[0].length === 4
    ? quatrains[0]
    : ['', '', '', '']

---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={shareImage}
  imageAlt={shareImageAlt}
  themeColor="#FF5900"
  themeColorDark="#FF5900"
  bodyClass="home-page"
  browserChromeColor="#FF5900"
>
  <section class="hero hero--orange">
    <div class="container hero__inner">
      <div class="hero__intro">
        <h1 class="hero__h1 sr-only">Amalfi Coast Photoshoots, Tours & Local Guide</h1>
        <div class="hero__quatrain" data-quatrains={JSON.stringify(quatrains)}>
          <p class="hero__line" data-quatrain-line>{fallbackQuatrain[0]}</p>
          <p class="hero__line" data-quatrain-line>{fallbackQuatrain[1]}</p>
          <p class="hero__line" data-quatrain-line>{fallbackQuatrain[2]}</p>
          <p class="hero__line" data-quatrain-line>{fallbackQuatrain[3]}</p>
        </div>
        <div class="hero__logo" data-particle-logo="/brand/amalficarion_logo.svg" role="img" aria-label="The Amalfication">
          <div class="hero__logo-stage">
            <canvas class="hero__logo-canvas" data-particle-canvas aria-hidden="true"></canvas>
            <img class="hero__logo-fallback" src="/brand/amalficarion_logo.svg" alt="" width="642" height="129" loading="eager" />
          </div>
        </div>
      </div>

      <div class="hero__mosaic">
        <div class="hero__tile hero__tile--primary">
          <a class="guide-card" href="https://guide.amalfi.day" target="_blank" rel="noreferrer">
            <div class="guide-card__media">
              <CldImage
                class="guide-card__poster"
                src="/staticpages/video/atrani-sorrento-video.webp"
                alt="Atrani to Sorrento coast"
                width={1500}
                height={1072}
                priority
                sizes="(max-width: 900px) 100vw, 60vw"
              />
              <video
                class="guide-card__video"
                muted
                loop
                playsinline
                preload="none"
                poster="/staticpages/video/atrani-sorrento-video.webp"
              >
                <source data-src="/staticpages/video/atrani-sorrento-video.mp4" type="video/mp4" />
              </video>
            </div>
            <span class="guide-card__badge">
              <span class="guide-card__badge-text">guide.amalfi.day</span>
              <i class="fa-solid fa-up-right-from-square"></i>
            </span>
          </a>
        </div>
        <div class="hero__tile hero__tile--small hero__tile--small-a">
          <a
            class="hero__mini hero__mini--photo"
            href={heroLinks.busPdf}
            id="bus"
            target="_blank"
            rel="noreferrer"
          >
            <img
              src="/staticpages/index/bus-timetables.webp"
              alt="Bus timetables"
              loading="lazy"
              decoding="async"
              width="1000"
              height="1000"
            />
            <span class="hero__mini-badge">Bus timetables</span>
          </a>
        </div>
        <div class="hero__tile hero__tile--small hero__tile--small-b">
          <a
            class="hero__mini hero__mini--photo"
            href="/ferry-timetables"
            id="ferry"
          >
            <img
              src="/staticpages/index/ferry-timetables.webp"
              alt="Ferry timetables"
              loading="lazy"
              decoding="async"
              width="1000"
              height="1000"
            />
            <span class="hero__mini-badge">Ferry timetables</span>
          </a>
        </div>
        <div class="hero__tile hero__tile--bottom">
          <a class="hero__mini" href="/photoshootings">
            <i class="fa-solid fa-camera-retro"></i>
            <div>
              <strong>Photoshoots</strong>
              <span>Get the best professional photos of yourself.</span>
            </div>
            <i class="fa-solid fa-up-right-from-square"></i>
          </a>
        </div>
      </div>

      <div class="hero__essentials">
        {staticPages.map((item) => (
          <a class="hero__essential" href={item.href}>
            <img
              src={item.image}
              alt={item.imageAlt}
              loading="lazy"
              decoding="async"
              width="1200"
              height="1200"
            />
            <span class="hero__mini-badge">{item.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--experience">
    <div class="container">
      <div class="section__header xp__header">
        <h2>
          Amalfi <span class="accent-italic">with us</span>
        </h2>
        <a class="section__subtitle-link" href="/experience">
          We offer the most creative ways to experience the Amalfi Coast.
        </a>
      </div>
      <div class="xp-grid">
        <a class="xp-card" href="/experience/car-tours">
          <div class="xp-card__media">
            <img
              src="/staticpages/car-tours/Scenic-Coast/Scenic-Coast-amalfi-coast-tours-5.webp"
              alt="Scenic Coast — private car tour along the Amalfi Coast"
              loading="lazy"
              decoding="async" width="2499" height="1874"
            />
          </div>
          <div class="xp-card__body">
            <div class="xp-card__top">
              <span class="xp-card__eyebrow">Private car tour</span>
              <h3 class="xp-card__title">Scenic Coast</h3>
            </div>
            <p class="xp-card__text">
              Cliff-top viewpoints, charming villages, limoncello tasting, and a local lunch by the sea.
            </p>
            <div class="xp-card__tags">
              <span class="xp-card__tag">8 hours</span>
              <span class="xp-card__tag">Up to 6 ppl</span>
            </div>
          </div>
          <span class="xp-card__arrow"><i class="fa-solid fa-up-right-from-square"></i></span>
        </a>

        <a class="xp-card" href="/experience/car-tours">
          <div class="xp-card__media">
            <img
              src="/staticpages/car-tours/Peak-Flavors/Peak-Flavors-amalfi-coast-tours-7.webp"
              alt="Peak Flavors — food and wine tour in Tramonti Valley"
              loading="lazy"
              decoding="async" width="2500" height="1875"
            />
          </div>
          <div class="xp-card__body">
            <div class="xp-card__top">
              <span class="xp-card__eyebrow">Wine &amp; food tour</span>
              <h3 class="xp-card__title">Peak Flavors</h3>
            </div>
            <p class="xp-card__text">
              Buffalo mozzarella, hillside vineyards, and panoramic mountain views you won't find in any guidebook.
            </p>
            <div class="xp-card__tags">
              <span class="xp-card__tag">8 hours</span>
              <span class="xp-card__tag">Wine tasting</span>
            </div>
          </div>
          <span class="xp-card__arrow"><i class="fa-solid fa-up-right-from-square"></i></span>
        </a>

        <a class="xp-card" href="/experience/scooter">
          <div class="xp-card__media">
            <img
              src="/staticpages/moto/hero/moto-ride-with-photographer-in-amalfi-coast-4.webp"
              alt="Scooter Photo Tour along the Amalfi Coast"
              loading="lazy"
              decoding="async" width="2500" height="1395"
            />
          </div>
          <div class="xp-card__body">
            <div class="xp-card__top">
              <span class="xp-card__eyebrow">Motorbike adventure</span>
              <h3 class="xp-card__title">Scooter Photo Tour</h3>
            </div>
            <p class="xp-card__text">
              Cliffside roads, cinematic overlooks, and 50+ professional photos to take home.
            </p>
            <div class="xp-card__tags">
              <span class="xp-card__tag">4 hours</span>
              <span class="xp-card__tag">Photo included</span>
            </div>
          </div>
          <span class="xp-card__arrow"><i class="fa-solid fa-up-right-from-square"></i></span>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--photos">
    <div class="container">
      <div class="section__header">
        <h2>
          <a class="section__title-link" href="/photoshootings">
            Photo <span class="accent-italic">sessions</span>
          </a>
        </h2>
        <p>
          <a class="section__subtitle-link" href="/photoshootings">
            Scroll through the latest stories and shooting concepts.
          </a>
        </p>
      </div>
      <div class="scroll" aria-label="Featured photoshoots">
        {featuredPhotoshoots.map((item, index) => (
          <a class="scroll__card" href={item.href}>
            <div class="scroll__media" data-index={index}>
              <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
            </div>
            <div class="scroll__overlay">
              <h3>{item.title}</h3>
              <span><i class="fa-solid fa-location-dot"></i> {item.location}</span>
            </div>
          </a>
        ))}
      </div>
      <div class="photos-cta">
        <a class="photos-cta__btn" href="/contact">
          <i class="fa-solid fa-camera"></i>
          Book a photoshoot
        </a>
      </div>
    </div>
  </section>

  <section class="section section--news">
    <div class="container">
      <div class="section__header news__header">
        <h2>
          Amalfi <span class="accent-italic">News</span>
        </h2>
        <a class="section__subtitle-link" href="/blog">
          Fresh stories and local insights are always waiting...
        </a>
      </div>
      <div class="news-scroll" aria-label="Latest blog posts">
        {newsPosts.map((post) => (
          <a class="news-card" href={post.href}>
            <div class="news-card__media">
              {post.image ? (
                <img src={post.image} alt={post.title} loading="lazy" decoding="async" />
              ) : (
                <div class="news-card__placeholder" aria-hidden="true"></div>
              )}
            </div>
            <span class="news-card__date">{post.date}</span>
            <h3>{post.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section etsy">
    <div class="container etsy__inner">
      <div class="etsy__copy">
        <div class="section__header etsy__header">
          <h2>
            Dress to <span class="accent-italic">express</span>
          </h2>
          <span class="section__subtitle etsy__subtitle">
            Prints, presets, and handcrafted Amalfi souvenirs<br />
            <strong>coming soon</strong>
          </span>
        </div>
      </div>
      <div class="etsy__gallery" aria-label="Amalfi merch previews">
        <img
          class="etsy__photo"
          src="/merch/t-shirt-0130.webp"
          alt="Amalfi t-shirt design preview"
          loading="lazy"
          decoding="async" width="500" height="500"
        />
        <img
          class="etsy__photo"
          src="/merch/t-shirt-che-cosa-new-3.webp"
          alt="Amalfi t-shirt graphic in blue"
          loading="lazy"
          decoding="async" width="500" height="500"
        />
        <img
          class="etsy__photo"
          src="/merch/t-shirt-hastalavista-new.webp"
          alt="Amalfi t-shirt print design"
          loading="lazy"
          decoding="async" width="500" height="500"
        />
        <img
          class="etsy__photo"
          src="/merch/t-shirt-pastaparty-00-new.webp"
          alt="Amalfi pasta party t-shirt design"
          loading="lazy"
          decoding="async" width="500" height="500"
        />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  :global(html) {
    background-color: #FF5900;
  }

  :global(html[data-theme='night']),
  :global(body.home-page) {
    background-color: #FF5900;
  }

  :global(body.home-page main) {
    background: var(--color-bg);
  }

  .hero {
    padding: 6rem 0 3rem;
    position: relative;
    color: #ffffff;
    box-sizing: border-box;
    background: #ff5900;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    width: min(1200px, 140vw);
    height: min(1200px, 140vw);
    transform: translate(-50%, -50%);
    background: radial-gradient(
      circle at 50% 50%,
      rgba(255, 195, 0, 0.95) 0%,
      rgba(255, 126, 0, 0.9) 45%,
      rgba(255, 89, 0, 1) 72%
    );
    opacity: 0.95;
  }


  .hero::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: calc(1.5rem + 5vw);
    background: var(--color-bg);
    z-index: 1;
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    align-items: center;
  }

  .hero__intro {
    text-align: center;
    max-width: 980px;
    margin: 0 auto;
    position: relative;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin-top: 0.8rem;
    margin-bottom: 1.6rem;
  }

  .hero__h1 {
    font-family: var(--font-body);
    font-size: clamp(0.72rem, 1.1vw, 0.82rem);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  .hero__quatrain {
    position: relative;
    z-index: 2;
    font-family: var(--font-display);
    font-size: clamp(0.81rem, 1.27vw, 1.04rem);
    line-height: 1.44;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.92);
    text-wrap: balance;
    max-width: 760px;
    margin: 0 auto;
  }

  .hero__line {
    margin: 0;
    transition: opacity 0.25s ease;
  }

  .hero__line.is-fading {
    opacity: 0.2;
  }

  .hero__logo {
    position: relative;
    z-index: 0;
    isolation: isolate;
    display: flex;
    justify-content: center;
    width: min(560px, 82vw);
    aspect-ratio: 641.6 / 128.69;
    transform: scale(var(--hero-logo-scroll-scale, 1));
    transform-origin: center center;
    will-change: transform;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  .hero__logo-stage {
    position: relative;
    width: 100%;
    height: 100%;
    transform: scale(1.2) translateY(-20%);
    transform-origin: center top;
    will-change: transform;
  }

  .hero__logo-canvas,
  .hero__logo-fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
  }

  .hero__logo-canvas {
    opacity: 0;
    transition: opacity 0.28s ease;
  }

  .hero__logo-fallback {
    object-fit: contain;
    opacity: 1;
    transition: opacity 0.2s ease;
  }

  .hero__logo.is-ready .hero__logo-canvas {
    opacity: 1;
  }

  .hero__logo.is-ready .hero__logo-fallback {
    opacity: 0;
  }

  @media (max-width: 700px) {
    .hero__logo-canvas {
      display: none;
    }

    .hero__logo.is-ready .hero__logo-fallback {
      opacity: 1;
    }
  }

  .hero__quatrain,
  .hero__logo {
    cursor: pointer;
  }

  .hero__mosaic {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    grid-template-rows: auto auto;
    gap: 1.2rem;
    align-items: stretch;
    width: 100%;
  }

  @media (min-width: 1001px) {
    .hero__logo-stage {
      transform: scale(2.25) rotate(-3deg) translateY(-25%);
      transform-origin: center top;
    }
  }

  .hero__tile {
    position: relative;
    border-radius: 26px;
    overflow: hidden;
    display: flex;
    align-items: stretch;
  }

  .hero__tile > a {
    width: 100%;
    height: 100%;
  }

  .hero__tile--primary {
    grid-column: 1 / span 4;
    grid-row: 1 / 3;
  }

  .hero__tile--small {
    aspect-ratio: 1 / 1;
  }

  .hero__tile--small-a {
    grid-column: 5;
    grid-row: 1;
  }

  .hero__tile--small-b {
    grid-column: 6;
    grid-row: 1;
  }

  .hero__tile--bottom {
    grid-column: 5 / span 2;
    grid-row: 2;
  }

  .hero__intro :is(a, h1, h2, h3, h4, h5, h6, p, span, strong) {
    color: #ffffff;
  }

  .guide-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    padding: 0;
    background: #ffffff;
    border: none;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: start;
    text-decoration: none;
    height: 100%;
  }

  .guide-card:hover {
    text-decoration: none;
  }

  .guide-card__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .guide-card__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.25s ease;
    z-index: 1;
  }

  .guide-card__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 2;
    position: relative;
  }

  .guide-card.is-video-ready .guide-card__poster {
    opacity: 0;
  }

  .guide-card__badge {
    position: absolute;
    bottom: 12px;
    left: 12px;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    background: #ffffff;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    letter-spacing: 0.02em;
    color: #111111;
    z-index: 2;
  }

  .guide-card__badge i {
    color: inherit;
    font-size: 0.95em;
  }

  .guide-card:hover .guide-card__badge {
    background: var(--color-accent);
    color: #ffffff;
  }

  .hero__mini {
    border-radius: 18px;
    padding: 1rem 1.2rem;
    background: #ffffff;
    border: 1px solid rgba(26, 26, 26, 0.08);
    display: flex;
    align-items: center;
    gap: 1rem;
    justify-content: space-between;
    text-decoration: none;
    height: 100%;
    color: #1a1a1a;
  }

  .hero__mini--photo {
    position: relative;
    padding: 0;
    overflow: hidden;
    color: #ffffff;
    justify-content: stretch;
    border: none;
    background: transparent;
  }

  .hero__mini--photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .hero__mini--photo:hover img {
    transform: scale(1.05);
  }

  .hero__mini-badge {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    background: #ffffff;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 12px;
    letter-spacing: 0.01em;
    color: #111111;
    white-space: nowrap;
  }

  .hero__mini--photo:hover .hero__mini-badge {
    background: var(--color-accent);
    color: #ffffff;
  }

  .hero__essentials {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 1.2rem;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .hero__essential {
    position: relative;
    border-radius: 26px;
    overflow: hidden;
    display: block;
    text-decoration: none;
    aspect-ratio: 1 / 1;
  }

  .hero__essential img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .hero__essential:hover img {
    transform: scale(1.05);
  }

  .hero__essential:hover .hero__mini-badge {
    background: var(--color-accent);
    color: #ffffff;
  }

  .hero__mini--stack {
    flex-direction: column;
    gap: 0.8rem;
    justify-content: center;
    text-align: center;
  }

  .hero__mini--stack i {
    font-size: 2rem;
  }

  .hero__mini > i {
    font-size: 2rem;
  }

  .hero__icon {
    display: inline-block;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }

  .hero__icon--sunset {
    background-image: var(--gradient-sunset);
  }

  .hero__icon--azure {
    background-image: var(--gradient-azure);
  }

  .hero__mini:hover {
    text-decoration: none;
  }

  .hero__mini strong {
    display: block;
    font-size: 1rem;
  }

  .hero__mini span:not(.hero__mini-badge) {
