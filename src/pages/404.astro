---
import BaseLayout from '../layouts/BaseLayout.astro'

const pageTitle = '404 — Wrong turn | Amalfi.Day'
const pageDescription =
  'This page took a wrong turn off the coast road. Find your way to photoshoots, apartments, and Amalfi stories.'
const shareImage = '/staticpages/video/atrani-sorrento-video.webp'
const shareImageAlt = 'Atrani to Sorrento coast'

const quatrains = [
  [
    'You took a wrong turn off the coast road.',
    'Boh — it happens, even to locals.',
    'The lemons are still on the tree, the sea still salty.',
    'Pick a path below and keep wandering.',
  ],
  [
    'This page is on holiday in Positano.',
    'Or maybe behind a lemon tree in Atrani.',
    'Either way — niente panico.',
    "Here's where everyone else is headed.",
  ],
  [
    'Mamma mia, that link is broken.',
    'But the road keeps winding, the sea keeps glittering.',
    'Sometimes the wrong turn finds the better view.',
    'Pick one of these and carry on.',
  ],
]

const fallbackQuatrain = quatrains[0]

const destinations = [
  {
    title: 'Home',
    href: '/',
    image: '/staticpages/video/atrani-sorrento-video.webp',
    imageAlt: 'Amalfi Coast home',
  },
  {
    title: 'Photoshoots',
    href: '/photoshootings',
    image: '/photoshootings/individual/Shifa/Hero.webp',
    imageAlt: 'Amalfi Coast photoshoots',
  },
  {
    title: 'Apartments',
    href: '/apartments',
    image: '/staticpages/mainpage/rental-houses.webp',
    imageAlt: 'Apartments in Atrani',
  },
  {
    title: 'Amalfi News',
    href: '/blog',
    image: '/staticpages/index/blog-of-amalfi-coast.webp',
    imageAlt: 'Amalfi Coast blog and news',
  },
]
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={shareImage}
  noindex={true}
  imageAlt={shareImageAlt}
>
  <section class="hero404">
    <div class="container hero404__inner">
      <p class="hero404__eyebrow">404 — Hai sbagliato strada</p>
      <div class="hero404__quatrain" data-quatrains={JSON.stringify(quatrains)}>
        <p class="hero404__line" data-quatrain-line>{fallbackQuatrain[0]}</p>
        <p class="hero404__line" data-quatrain-line>{fallbackQuatrain[1]}</p>
        <p class="hero404__line" data-quatrain-line>{fallbackQuatrain[2]}</p>
        <p class="hero404__line" data-quatrain-line>{fallbackQuatrain[3]}</p>
      </div>
      <a class="hero404__cta" href="/">
        <i class="fa-solid fa-arrow-left"></i>
        Torna a casa
      </a>
    </div>
  </section>

  <section class="section section--404">
    <div class="container">
      <div class="section__header section__header--404">
        <h2>
          Where you might <span class="accent-italic">be headed</span>
        </h2>
      </div>
      <div class="essentials404">
        {destinations.map((item) => (
          <a class="essential404" href={item.href}>
            <img
              src={item.image}
              alt={item.imageAlt}
              loading="lazy"
              decoding="async"
              width="1200"
              height="1200"
            />
            <span class="essential404__badge">{item.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero404 {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    color: #ffffff;
    box-sizing: border-box;
    background: #ff5900;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1rem 4rem;
  }

  .hero404::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 30%;
    width: min(1400px, 160vw);
    height: min(1400px, 160vw);
    transform: translate(-50%, -50%);
    background: radial-gradient(
      circle at 50% 50%,
      rgba(255, 195, 0, 0.95) 0%,
      rgba(255, 126, 0, 0.9) 45%,
      rgba(255, 89, 0, 1) 72%
    );
    opacity: 0.95;
    pointer-events: none;
  }

  .hero404__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    align-items: center;
    text-align: center;
    max-width: 820px;
    width: 100%;
  }

  .hero404__eyebrow {
    font-family: var(--font-mono);
    font-size: clamp(0.78rem, 1.1vw, 0.92rem);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
  }

  .hero404__quatrain {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.15rem, 2vw, 1.6rem);
    line-height: 1.55;
    letter-spacing: 0.01em;
    color: #ffffff;
    text-wrap: balance;
    max-width: 740px;
    cursor: pointer;
    margin: 0;
  }

  .hero404__line {
    margin: 0;
    color: #ffffff;
    transition: opacity 0.25s ease;
  }

  .hero404__line.is-fading {
    opacity: 0.2;
  }

  .hero404__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 1rem;
    padding: 1rem 2.4rem;
    background: #ffffff;
    color: #1a1a1a;
    font-family: var(--font-display);
    font-style: normal;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    border-radius: 999px;
    text-decoration: none;
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.22);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .hero404__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.28);
    background: #1a1a1a;
    color: #ffffff;
    text-decoration: none;
  }

  .hero404__cta i {
    font-size: 0.85em;
  }

  .section--404 {
    background: var(--color-bg);
    padding-top: 1.5rem;
  }

  .section__header--404 {
    display: flex;
    align-items: baseline;
    justify-content: center;
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .section__header--404 h2 {
    font-size: clamp(1.6rem, 2.6vw, 2.4rem);
    margin: 0;
  }

  .essentials404 {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.2rem;
    width: 100%;
  }

  .essential404 {
    position: relative;
    border-radius: 26px;
    overflow: hidden;
    display: block;
    text-decoration: none;
    aspect-ratio: 1 / 1;
    box-shadow: var(--shadow-soft);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .essential404:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lift);
    text-decoration: none;
  }

  .essential404 img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .essential404:hover img {
    transform: scale(1.05);
  }

  .essential404__badge {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: #ffffff;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    letter-spacing: 0.01em;
    color: #111111;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .essential404:hover .essential404__badge {
    background: var(--color-accent);
    color: #ffffff;
  }

  @media (max-width: 1000px) {
    .essentials404 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .hero404 {
      padding: 5rem 1rem 3rem;
    }

    .essentials404 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.9rem;
    }
  }
</style>

<script is:inline>
  const quatrainRoot = document.querySelector('.hero404__quatrain[data-quatrains]')
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)')

  if (quatrainRoot) {
    const lines = [...quatrainRoot.querySelectorAll('[data-quatrain-line]')]
    try {
      const quatrains = JSON.parse(quatrainRoot.dataset.quatrains || '[]')
      if (Array.isArray(quatrains) && quatrains.length > 1 && lines.length) {
        let currentIndex = 0

        const applyQuatrain = (index) => {
          const pick = quatrains[index]
          if (!Array.isArray(pick)) return
          lines.forEach((line, i) => {
            line.textContent = pick[i] || ''
          })
          currentIndex = index
        }

        const pickNextIndex = () => {
          let next = currentIndex
          while (next === currentIndex) {
            next = Math.floor(Math.random() * quatrains.length)
          }
          return next
        }

        const setLineFade = (value) => {
          lines.forEach((line) => line.classList.toggle('is-fading', value))
        }

        const swapQuatrain = () => {
          const nextIndex = pickNextIndex()
          if (prefersReducedMotion.matches) {
            applyQuatrain(nextIndex)
            return
          }
          if (lines.some((line) => line.classList.contains('is-fading'))) return
          setLineFade(true)
          window.setTimeout(() => {
            applyQuatrain(nextIndex)
            setLineFade(false)
          }, 220)
        }

        applyQuatrain(Math.floor(Math.random() * quatrains.length))
        quatrainRoot.addEventListener('click', swapQuatrain)
      }
    } catch (error) {
      // no-op: keep fallback quatrain
    }
  }
</script>
