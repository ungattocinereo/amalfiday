    border: none;
    color: #fff;
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  :global(.gallery-lightbox__nav:hover) {
    background: rgba(255, 255, 255, 0.25);
  }

  :global(.gallery-lightbox__prev) {
    left: 1rem;
  }

  :global(.gallery-lightbox__next) {
