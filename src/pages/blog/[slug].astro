    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.1em;
  }

  /* === RESPONSIVE === */
  @media (max-width: 640px) {
    .post-hero {
      min-height: 100svh;
    }

    .post-hero__content {
      padding-bottom: clamp(4rem, 12vh, 6rem);
    }

