const tableCount = operators.reduce((sum, operator) => sum + operator.tables.length, 0)
const isDeparturesHeader = (header) => /departures/i.test(header)
const isMoneyHeader = (header) => /fare|price/i.test(header)
const isItineraryHeader = (header) => /itinerary/i.test(header)
const formatMoney = (value) => (/^\d+(?:\.\d+)?$/.test(value) ? `EUR ${value}` : value)
const splitDepartures = (value) => value.split(/\s*,\s*/).filter(Boolean)
const splitItinerary = (value) => value.split(/\s*;\s*/).filter(Boolean)
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={shareImage}
  imageAlt="Ferry on the Amalfi Coast"
  jsonLd={ferryJsonLd}
>
  <section class="apt-hero hero--dark">
    <div class="apt-hero__slides" aria-hidden="true">
      {heroSlides.map((slide, i) => (
        <div class={`apt-hero__slide ${i === 0 ? 'is-active' : ''}`}>
          <img
            src={slide.image}
            alt={slide.alt}
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        </div>
      ))}
    </div>
    <div class="apt-hero__vignette"></div>
    <div class="apt-hero__content">
      <div class="container">
        <div class="apt-hero__grid">
          <div class="apt-hero__copy">
            <span class="apt-hero__eyebrow">Amalfi Coast ferries 2026</span>
            <h1 class="apt-hero__title">
              Ferry<br />timetables
            </h1>
            <p class="apt-hero__lead">
              Travelmar, Grassi Junior Ferries, and NLG schedules for the main coastal routes.
              Use this page to scan departures quickly, then verify live availability before travel.
            </p>
            <div class="apt-hero__stats">
              {stats.map((item) => (
                <div class="apt-hero__stat">
                  <strong>{item.value}</strong>
                  <span>{item.label}</span>
                </div>
              ))}
              <div class="apt-hero__stat">
                <strong>{tableCount}</strong>
                <span>route tables</span>
              </div>
            </div>
            <div class="apt-hero__actions">
              <a class="apt-hero__btn apt-hero__btn--primary" href="#download">Ferry company PDFs</a>
              <a class="apt-hero__btn apt-hero__btn--ghost" href="#travelmar">Browse schedules</a>
            </div>
          </div>
          <div class="apt-hero__aside">
            <ul class="apt-hero__tags">
              {heroTags.map((tag, i) => (
                <li class="apt-hero__tag" style={`animation-delay: ${0.6 + i * 0.08}s`}>{tag}</li>
              ))}
            </ul>
            <div class="apt-hero__progress">
              {heroSlides.map((slide, i) => (
                <button
                  class={`apt-hero__dot ${i === 0 ? 'is-active' : ''}`}
                  data-slide={i}
                  aria-label={`Show ${slide.label}`}
                >
                  <span class="apt-hero__dot-label">{slide.label}</span>
                  <span class="apt-hero__dot-bar"><span class="apt-hero__dot-fill"></span></span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="apt-hero__scroll-hint" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <section class="section ferry-section" id="download" aria-label="Sea ferry timetable downloads">
    <div class="container">
      <div class="ferry-header">
        <h2>
          Sea Ferries <span class="accent-italic">Timetables</span>
        </h2>
        <span class="ferry-update">Files were updated 26 March 2026</span>
      </div>
      <p class="ferry-lead">
        Several ferry companies operate services along the Amalfi Coast, connecting major towns
        such as Cetara, Maiori, Amalfi, Positano, and Salerno. Travelmar - is one of the most
        popular ferry companies in Amalfi Coast. NLG - operating between Amalfi and Naples and
        in Sorrento Coast.
      </p>
      <div class="ferry-grid">
        <article class="ferry-column">
          <div class="ferry-media">
            <img
              src="/staticpages/timetables/TraVelMar.webp"
              alt="TravelMar ferry on the Amalfi Coast"
              loading="lazy" width="1200" height="1200"
            />
          </div>
          <div class="ferry-content">
            <h3>
              <i class="fa-solid fa-water"></i>
              TravelMar
            </h3>
            <p>
              The most convenient mode of transportation for traveling between towns along the
              Amalfi Coast is by ferry. The ferry routes operate from April to October and connect
              all the coastal towns. In addition to linking Amalfi and Positano, there are also
              ferry services to Capri and Sorrento. However, it is important to note that ferry
              operations may be temporarily suspended during rough sea conditions.
            </p>
            <p class="ferry-route">
              <i class="fa-solid fa-circle-info"></i>
              <span>Salerno → Cetara → Maiori → Minori → Vietri sul Mare → Amalfi</span>
            </p>
            <a
              class="timetable-download ferry-download"
              href="https://amalfi.day/files/FERRY-timetables.pdf"
              target="_blank"
              rel="noreferrer"
            >
              <i class="fa-solid fa-cloud-arrow-down"></i>
              TravelMar timetables
            </a>
          </div>
        </article>
        <article class="ferry-column">
          <div class="ferry-media">
            <img
              src="/staticpages/timetables/PositanoJet.webp"
              alt="PositanoJet ferry on the Amalfi Coast"
              loading="lazy" width="1200" height="1200"
            />
          </div>
          <div class="ferry-content">
            <h3>
              <i class="fa-solid fa-compass"></i>
              PositanoJet
            </h3>
            <p>
              Positano Jet is a new company operating in 2025 along the Amalfi Coast. They offer
              tours not only to Positano but also to Capri and Sorrento. We've gathered all their
              schedules here for your convenience.
              <a
                class="ferry-inline-link"
                href="https://positanojet.nefesy.com/b2c/b2c.php?LANG=en"
                target="_blank"
                rel="noreferrer"
              >
                Book your ticket by clicking here.
              </a>
            </p>
            <p class="ferry-fees">
              <i class="fa-solid fa-circle-info"></i>
              <span>
                Additional Fees:
                <br />
                Baggage: 3,00€
                <br />
                Baggage XL 5,00€
                <br />
                Pet Ticket: 5,00€
              </span>
            </p>
            <a
              class="timetable-download ferry-download"
              href="https://amalfi.day/files/FERRY-timetables-positanojet.pdf"
              target="_blank"
              rel="noreferrer"
            >
              <i class="fa-solid fa-cloud-arrow-down"></i>
              Positanojet timetables
            </a>
          </div>
        </article>
        <article class="ferry-column">
          <div class="ferry-media">
            <img
              src="/staticpages/timetables/NLG.webp"
              alt="Alicost ferry on the Amalfi Coast"
              loading="lazy" width="1200" height="1200"
            />
          </div>
          <div class="ferry-content">
            <h3>
              <i class="fa-solid fa-sun"></i>
              Alicost
            </h3>
            <p>
              Positano Jet is a new company operating in 2025 along the Amalfi Coast. They offer
              tours not only to Positano but also to Capri and Sorrento. We've gathered all their
              schedules here for your convenience. You can book your ticket by clicking here
            </p>
            <p class="ferry-fees">
              <i class="fa-solid fa-circle-info"></i>
              <span>
                Additional Taxes Per Person
                <br />
                Capri Tax: + 5,00 €
                <span class="tax-direction">
                  <i class="fa-solid fa-arrow-right-to-bracket"></i>
                  Capri
                </span>
                <br />
                Procida Tax: + 3,50 €
                <span class="tax-direction">
                  <i class="fa-solid fa-arrow-right-to-bracket"></i>
                  Procida
                </span>
                <br />
                Salerno Tax: + 1,50 €
                <span class="tax-direction">
                  <i class="fa-solid fa-arrow-up-right-from-square"></i>
                  Salerno
                </span>
              </span>
            </p>
            <a
              class="timetable-download ferry-download"
              href="https://amalfi.day/files/FERRY-timetables-alicost.pdf"
              target="_blank"
              rel="noreferrer"
            >
              <i class="fa-solid fa-cloud-arrow-down"></i>
              Alicost Timetables
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="ferry-notes section">
    <div class="container ferry-notes__grid">
      <div>
        <span class="ferry-eyebrow">Before boarding</span>
        <h2>Ferry times can change fast.</h2>
      </div>
      <div class="tourist-note-grid">
        <article class="tourist-note">
          <i class="fa-solid fa-clock"></i>
          <div>
            <h3>Local time</h3>
            <p>All departures are shown in local Italian time.</p>
          </div>
        </article>
        <article class="tourist-note">
          <i class="fa-solid fa-euro-sign"></i>
          <div>
            <h3>EUR fares</h3>
            <p>Prices are in euros and may not include luggage or port extras.</p>
          </div>
        </article>
        <article class="tourist-note">
          <i class="fa-solid fa-cloud-sun-rain"></i>
          <div>
            <h3>Sea conditions</h3>
            <p>Weather, technical issues, and operator updates can change service.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  {operators.map((operator) => (
    <section class="operator-section" id={operator.id}>
      <div class="container">
        <header class="operator-header">
          <span class="ferry-eyebrow">Operator</span>
          <h2>{operator.name}</h2>
          <p>{operator.summary}</p>
        </header>

        <div class="operator-sticky-label" aria-label={`Current ferry operator: ${operator.name}`}>
          <div class="operator-pill">
            <i class="fa-solid fa-ship"></i>
            <strong>{operator.shortName}</strong>
          </div>
          <div class="operator-route-note" aria-live="polite">
            <i class="fa-solid fa-location-dot"></i>
            <span data-current-route>{getStickyRouteLabel(operator.tables[0]?.title ?? '')}</span>
          </div>
        </div>

        <div class="operator-highlights">
          {operator.highlights.map((item) => (
            <article class="operator-highlight">
              <i class={`fa-solid ${item.icon}`}></i>
              <div>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="schedule-stack">
          {operator.tables.map((table, tableIndex) => (
            <article
              class="schedule-card"
              id={`${operator.id}-${tableIndex + 1}`}
              data-route-label={getStickyRouteLabel(table.title)}
            >
              <div class="schedule-card__header">
                <div>
                  {table.group && <span>{table.group}</span>}
                  <h3>{table.title}</h3>
                </div>
              </div>

              <div class="table-scroll" tabindex="0">
                <table>
                  <thead>
                    <tr>
                      {table.headers.map((header) => (
                        <th>{header}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {table.rows.map((row) => (
                      <tr>
                        {table.headers.map((header, cellIndex) => {
                          const cell = row[cellIndex] ?? ''
                          return (
                            <td data-label={header}>
                              {isDeparturesHeader(header) && cell ? (
                                <div class="time-list">
                                  {splitDepartures(cell).map((time) => (
                                    <span>{time}</span>
                                  ))}
                                </div>
                              ) : isItineraryHeader(header) && cell ? (
                                <div class="itinerary-list">
                                  {splitItinerary(cell).map((leg) => (
                                    <span>{leg}</span>
                                  ))}
                                </div>
                              ) : isMoneyHeader(header) && cell ? (
                                <strong class="fare-value">{formatMoney(cell)}</strong>
                              ) : cell ? (
                                <span>{cell}</span>
                              ) : (
                                <span class="empty-cell">-</span>
                              )}
                            </td>
                          )
                        })}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}
</BaseLayout>

<script is:inline>
  ;(function () {
    const slides = document.querySelectorAll('.apt-hero__slide')
    const dots = document.querySelectorAll('.apt-hero__dot')
    if (!slides.length) return

    let current = 0
    const DURATION = 6000
    const FADE_DURATION = 1300
    const freezeTimers = new WeakMap()

    function clearSlideFreeze(slide) {
      const image = slide?.querySelector('img')
      if (!image) return
      image.style.animation = ''
      image.style.transform = ''
    }

    function freezeSlideTransform(slide) {
      const image = slide?.querySelector('img')
      if (!image) return

      const transform = window.getComputedStyle(image).transform
      image.style.animation = 'none'
      image.style.transform = transform === 'none' ? '' : transform

      window.clearTimeout(freezeTimers.get(slide))
      freezeTimers.set(
        slide,
        window.setTimeout(() => {
          if (!slide.classList.contains('is-active')) {
            clearSlideFreeze(slide)
          }
          freezeTimers.delete(slide)
        }, FADE_DURATION)
      )
    }

    function go(next) {
      if (next === current) return
      freezeSlideTransform(slides[current])
      slides[current].classList.remove('is-active')
      dots[current].classList.remove('is-active')
      current = next
      clearSlideFreeze(slides[current])
      slides[current].classList.add('is-active')
      dots[current].classList.add('is-active')
    }

    let timer = setInterval(() => go((current + 1) % slides.length), DURATION)

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        clearInterval(timer)
        go(Number(dot.dataset.slide))
        timer = setInterval(() => go((current + 1) % slides.length), DURATION)
      })
    })
  })()

  ;(function () {
    const sections = Array.from(document.querySelectorAll('.operator-section'))
    if (!sections.length) return

    const contexts = sections.map((section) => ({
      label: section.querySelector('[data-current-route]'),
      cards: Array.from(section.querySelectorAll('[data-route-label]')),
    })).filter((context) => context.label && context.cards.length)

    function updateCurrentRoutes() {
      contexts.forEach(({ label, cards }) => {
        const referenceY = window.innerHeight * 0.34
        let active = cards[0]

        cards.forEach((card) => {
          const rect = card.getBoundingClientRect()
          if (rect.top <= referenceY && rect.bottom > 96) {
            active = card
          }
        })

        const nextTitle = active?.dataset.routeLabel || ''
        if (nextTitle && label.textContent !== nextTitle) {
          label.textContent = nextTitle
        }
      })
    }

    let ticking = false
    function requestUpdate() {
      if (ticking) return
      ticking = true
      window.requestAnimationFrame(() => {
        updateCurrentRoutes()
        ticking = false
      })
    }

    updateCurrentRoutes()
    window.addEventListener('scroll', requestUpdate, { passive: true })
    window.addEventListener('resize', requestUpdate)
  })()
</script>

