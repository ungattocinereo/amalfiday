---
import BaseLayout from '../layouts/BaseLayout.astro'
import { site } from '../data/site'
const pageTitle = 'Amalfi Coast Ferry Timetables 2026'
const pageDescription =
  'Updated Amalfi Coast ferry schedules for Travelmar, Grassi Junior Ferries, and NLG, with departures, fares, routes, notes, and PDF download.'
const shareImage = '/staticpages/timetables/ferry-hero-01.webp'

const heroSlides = [
  {
    image: '/staticpages/timetables/ferry-hero-01.webp',
    label: 'Coast ferry',
    alt: 'Ferry crossing the Amalfi Coast',
  },
  {
    image: '/staticpages/timetables/ferry-hero-02.webp',
    label: 'Amalfi port',
    alt: 'Ferries near Amalfi port',
  },
  {
    image: '/staticpages/timetables/ferry-hero-03.webp',
    label: 'Sea route',
    alt: 'Amalfi Coast ferry route at sea',
  },
]

const heroTags = [
  'Salerno',
  'Amalfi',
  'Positano',
  'Capri',
  'Sorrento',
  'Maiori',
]

const stats = [
  { value: '3', label: 'ferry operators' },
  { value: '2026', label: 'season schedules' },
]

const getStickyRouteLabel = (title: string) => {
  const compactTitle = title
    .replace(/^Departures From Salerno Masuccio Pier - Concordia$/, 'From Salerno piers')
    .replace(/^Departures From /, 'From ')
    .replace(/ And /g, ' & ')
    .replace(/ In The Same Day$/, ' same day')

  return compactTitle
}

const ferryJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: pageTitle,
    description: pageDescription,
    url: `${site.url}/ferry-timetables`,
    dateModified: '2026-05-06',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: 'Ferry timetables', item: `${site.url}/ferry-timetables` },
    ],
  },
]

const operators = [
  {
    name: 'Travelmar',
    shortName: 'Travelmar',
    id: 'travelmar',
    summary: 'Frequent coastal ferries between Salerno, Cetara, Maiori, Amalfi, and Positano.',
    highlights: [
      { icon: 'fa-route', title: 'Best for coast hopping', text: 'Useful for Salerno, Amalfi, Positano, Maiori, and Cetara.' },
      { icon: 'fa-clock', title: 'Fast Amalfi link', text: 'Salerno to Amalfi is usually 35 minutes; starred trips take about 60 minutes.' },
      { icon: 'fa-cloud-sun-rain', title: 'Weather dependent', text: 'Always recheck the live schedule before boarding.' },
    ],
    tables: [
      {
        title: 'Departures From Salerno',
        group: 'Travelmar Timetable',
        headers: ['Destination', 'Departures', 'Duration', 'Fare', 'Notes'],
