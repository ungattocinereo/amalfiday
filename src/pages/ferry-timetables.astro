        rows: [
          ['Salerno', '08:40, 10:00 direct, 12:50, 16:45, 19:05', '15.00', ''],
          ['Amalfi', '08:40, 12:50, 16:45, 19:05', '10.00', ''],
          ['Capri', '10:00 via Salerno, 14:35', '28.00', ''],
          ['Cetara', '08:40*, 12:50', '15.00', '* via Salerno'],
          ['Maiori', '08:40*, 12:50', '13.00', '* via Salerno'],
          ['Minori', '08:40*, 12:50', '13.00', '* via Salerno'],
        ],
      },
      {
        title: 'Departures From Amalfi',
        group: 'Grassi Junior Main Timetable',
        headers: ['Destination', 'Departures', 'Fare', 'Notes'],
        rows: [
          ['Salerno', '09:10, 13:15, 17:25, 19:30', '10.00', ''],
          ['Positano', '11:00, 15:10, 17:25*, 19:30*', '10.00', '* via Salerno'],
          ['Cetara', '09:10*, 13:15', '8.00', '* via Salerno'],
          ['Maiori', '09:10*, 13:15', '4.00', '* via Salerno'],
          ['Minori', '09:10*, 13:15', '4.00', '* via Salerno'],
        ],
      },
      {
        title: 'Departures From Cetara',
        group: 'Grassi Junior Main Timetable',
        headers: ['Destination', 'Departures', 'Fare', 'Notes'],
        rows: [
          ['Positano', '10:15, 14:15*', '15.00', '* via Salerno'],
          ['Amalfi', '10:15, 14:15', '8.00', ''],
          ['Salerno', '14:15', '6.00', ''],
          ['Maiori', '10:15', '7.00', ''],
          ['Minori', '10:15', '7.00', ''],
        ],
      },
      {
        title: 'Departures From Maiori',
        group: 'Grassi Junior Main Timetable',
        headers: ['Destination', 'Departures', 'Fare', 'Notes'],
        rows: [
          ['Positano', '10:35, 13:50*', '13.00', '* via Salerno'],
          ['Amalfi', '10:35, 13:50', '4.00', ''],
          ['Salerno', '13:50', '9.00', ''],
          ['Minori', '10:35', '4.00', ''],
          ['Cetara', '13:50', '7.00', ''],
        ],
      },
      {
        title: 'Departures From Minori',
        group: 'Grassi Junior Main Timetable',
        headers: ['Destination', 'Departures', 'Fare', 'Notes'],
        rows: [
          ['Positano', '10:50, 13:35*', '13.00', '* via Salerno'],
          ['Amalfi', '10:50', '4.00', ''],
          ['Salerno', '13:35', '9.00', ''],
          ['Maiori', '13:35', '4.00', ''],
          ['Cetara', '13:35', '7.00', ''],
        ],
      },
      {
        title: 'Departures From Capri',
        group: 'Grassi Junior Main Timetable',
        headers: ['Destination', 'Departures', 'Fare', 'Notes'],
        rows: [
          ['Positano', '13:10, 18:20', '23.00', ''],
          ['Amalfi', '18:20', '24.00', ''],
