---
import BaseLayout from '../layouts/BaseLayout.astro'
import { site } from '../data/site'

const downloadUrl = 'https://cnr.pw/ferry'
const pageTitle = 'Amalfi Coast Ferry Timetables 2026'
const pageDescription =
  'Updated Amalfi Coast ferry schedules for Travelmar, Grassi Junior Ferries, and NLG, with departures, fares, routes, notes, and PDF download.'
const shareImage = '/staticpages/timetables/ferry-hero-01.webp'

const heroSlides = [
  {
    image: '/staticpages/timetables/ferry-hero-01.webp',
    label: 'Coast ferry',
    alt: 'Ferry crossing the Amalfi Coast',
  },
  {
    image: '/staticpages/timetables/ferry-hero-02.webp',
    label: 'Amalfi port',
    alt: 'Ferries near Amalfi port',
  },
  {
    image: '/staticpages/timetables/ferry-hero-03.webp',
    label: 'Sea route',
    alt: 'Amalfi Coast ferry route at sea',
  },
]

const heroTags = [
  'Salerno',
  'Amalfi',
  'Positano',
  'Capri',
  'Sorrento',
  'Maiori',
]

const stats = [
  { value: '3', label: 'ferry operators' },
  { value: '2026', label: 'season schedules' },
]

const ferryJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: pageTitle,
    description: pageDescription,
    url: `${site.url}/ferry-timetables`,
    dateModified: '2026-05-06',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: 'Ferry timetables', item: `${site.url}/ferry-timetables` },
    ],
  },
]

const operators = [
