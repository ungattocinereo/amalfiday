      { icon: 'fa-umbrella-beach', title: 'Capri links', text: 'Includes Positano, Capri, Amalfi, and Salerno route tables.' },
      { icon: 'fa-circle-info', title: 'Some prices differ', text: 'Promotional cards and main timetable show a few different prices.' },
    ],
    tables: [
      {
        title: 'Departures From Salerno Masuccio Pier - Concordia',
        group: 'Grassi Junior Main Timetable',
        headers: ['Destination', 'Departures', 'Fare', 'Notes'],
        rows: [
