  },
  {
    name: 'NLG',
    shortName: 'NLG',
    id: 'nlg',
    summary: 'Longer seasonal links from Amalfi to Capri, Sorrento, Naples, Salerno, Castellammare, and Positano.',
    highlights: [
      { icon: 'fa-calendar-days', title: 'Main season', text: 'Most 2026 routes run from 01 April to 03 November.' },
      { icon: 'fa-right-left', title: 'Check changes', text: 'Some Naples to Amalfi trips require a change at Capri.' },
      { icon: 'fa-ticket', title: 'Amalfi office', text: 'Ticket office phone: 0815520763 / 3483441759.' },
    ],
    tables: [
      {
        title: 'Amalfi and Capri ferry times',
        group: 'NLG Timetable',
        headers: ['Departure Port', 'Departures', 'Service'],
        rows: [
          ['Amalfi', '08:54, 10:30, 17:00', 'Everyday'],
          ['Capri', '09:45, 15:45, 17:15', 'Everyday'],
        ],
      },
      {
        title: 'Sorrento and Amalfi ferry times',
        group: 'NLG Timetable',
        headers: ['Period', 'Departure Port', 'Departures', 'Service'],
        rows: [
          ['17 Nov 2025 - 31 Mar 2026', 'Sorrento', '11:00', 'Sat-Sun; everyday from 24/03'],
          ['17 Nov 2025 - 31 Mar 2026', 'Amalfi', '15:45', 'Sat-Sun; everyday from 24/03'],
          ['01 April - 03 November 2026', 'Sorrento', '09:00, 09:30, 11:00, 12:25, 15:15, 16:10', 'Everyday'],
          ['01 April - 03 November 2026', 'Amalfi', '08:54, 10:53, 13:40, 15:45, 17:02', 'Everyday'],
        ],
      },
      {
        title: 'Napoli Beverello and Amalfi ferry times',
        group: 'NLG Timetable',
