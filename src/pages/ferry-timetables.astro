          ['Positano', '09:20, 10:30, 11:30, 12:00, 12:30, 14:00, 15:00, 16:20, 18:00', '25 min', '10.00', ''],
          ['Maiori', '09:00, 11:20, 13:00, 14:15, 16:30, 18:00, 19:10', '15 min', '5.00', ''],
