---
import BaseLayout from '../layouts/BaseLayout.astro'

const pageTitle = 'Terms and Conditions — Amalfi.Day'
const pageDescription =
  'Terms and conditions for booking apartments, tours, and experiences on the Amalfi Coast with CristallPont S.R.L.'
const shareImage = '/pre-footer/2-food-in-amalfi-good.webp'
---

<BaseLayout title={pageTitle} description={pageDescription} image={shareImage}>
  <section class="section policy">
    <div class="container policy__inner">
      <div class="policy__intro">
        <h1>
          Terms and <span class="accent-italic">Conditions</span>
        </h1>
        <p>
          General booking terms for the accommodation, tours, and experiences offered through
          amalfi.day by CristallPont S.R.L.
        </p>
        <div class="policy__meta">
          <span class="badge"><i class="fa-solid fa-file-lines"></i> General terms</span>
          <span class="badge"
            ><i class="fa-solid fa-calendar"></i> Last updated: 21 February 2026</span
          >
        </div>
      </div>

      <div class="policy__content">
        <div class="policy__grid">
          <div class="card policy__card">
            <h3>Bookings</h3>
            <ul>
              <li>Confirmation via email or direct message.</li>
              <li>Deposit required to confirm booking.</li>
              <li>Balance due at check-in or before the tour.</li>
            </ul>
          </div>
          <div class="card policy__card">
            <h3>Cancellations</h3>
            <ul>
              <li>Free cancellation more than 30 days before arrival.</li>
              <li>50% of deposit between 15 and 30 days.</li>
              <li>No refund under 15 days.</li>
            </ul>
          </div>
          <div class="card policy__card">
            <h3>Tours & Experiences</h3>
            <ul>
              <li>Confirmed after deposit payment.</li>
              <li>Date changes subject to availability.</li>
              <li>Free cancellation more than 48 hours before.</li>
            </ul>
          </div>
          <div class="card policy__card">
            <h3>Applicable Law</h3>
            <ul>
              <li>Italian law.</li>
              <li>Jurisdiction: Court of Salerno.</li>
              <li>EU ODR platform for online disputes.</li>
            </ul>
          </div>
        </div>

        <div class="policy__sections">
          <article class="policy__section">
            <h2>Service Provider</h2>
            <p>
              The services advertised on amalfi.day are provided by:<br />
              <strong>CristallPont S.R.L.</strong><br />
              VAT / Tax ID: 05863730650<br />
              Registered office: Traversa Dragone, 2<br />
              Share capital: &euro;10,000.00<br />
              Email: <a href="mailto:hello@amalfi.day">hello@amalfi.day</a>
            </p>
          </article>

          <article class="policy__section">
            <h2>Booking and Confirmation</h2>
            <p>
              Booking requests are made via the contact form on the website or through direct
              communication (email, WhatsApp). A booking is considered confirmed only after receipt
              of the deposit and our written confirmation.
            </p>
            <p>
              Simply submitting a request through the contact form does not constitute a confirmed
              booking.
            </p>
          </article>

          <article class="policy__section">
            <h2>Prices and Payments</h2>
            <p>
              All prices published on the website include VAT where applicable. A deposit payment is
              required to confirm the booking. The balance is due at check-in (for accommodation) or
              before the start of the tour (for experiences).
            </p>
            <p>
              Accepted payment methods are communicated at the time of booking confirmation.
            </p>
          </article>

          <article class="policy__section">
            <h2>Cancellation and Refunds &mdash; Accommodation</h2>
            <p>
              The following cancellation terms apply to direct bookings through amalfi.day.
              For bookings made through third-party platforms (Booking.com, Airbnb), the respective
              platform's terms apply.
            </p>
            <ul>
              <li>
                <strong>More than 30 days before check-in:</strong> free cancellation, full deposit
                refund.
              </li>
              <li>
                <strong>Between 15 and 30 days before check-in:</strong> 50% deposit refund.
              </li>
              <li>
                <strong>Less than 15 days before check-in:</strong> no deposit refund.
              </li>
            </ul>
            <p>
              In case of force majeure (natural disaster, government restrictions), alternative dates
              or a refund will be offered depending on the circumstances.
            </p>
          </article>

          <article class="policy__section">
            <h2>Cancellation and Refunds &mdash; Tours & Experiences</h2>
            <ul>
              <li>
                <strong>More than 48 hours before:</strong> free cancellation, full refund.
              </li>
              <li>
                <strong>Between 24 and 48 hours before:</strong> 50% refund.
              </li>
              <li>
                <strong>Less than 24 hours before or no-show:</strong> no refund.
              </li>
            </ul>
            <p>
              In case of bad weather preventing the tour, alternative dates or a full refund will be
              offered.
            </p>
          </article>

          <article class="policy__section">
            <h2>Check-in and Check-out</h2>
            <p>
              Standard times are: check-in from 14:00, check-out by 10:00. Early check-in or late
              check-out may be requested and are subject to availability.
            </p>
            <p>
              Access instructions are provided after booking confirmation.
            </p>
          </article>

          <article class="policy__section">
            <h2>Liability</h2>
            <p>
              The guest is responsible for any damage caused to the property during their stay.
              The provider is not responsible for valuables left unattended in the accommodation.
              The provider's liability is limited to the value of the booked service.
            </p>
          </article>

          <article class="policy__section">
            <h2>Tourist Tax</h2>
            <p>
              The Municipality of Atrani levies a tourist tax per person per night, in accordance
              with current municipal regulations. The exact amount is communicated at the time of
              booking and must be paid separately at check-in.
            </p>
          </article>

          <article class="policy__section">
            <h2>Online Dispute Resolution (ODR)</h2>
            <p>
              In case of a dispute relating to an online purchase, you may use the Online Dispute
              Resolution (ODR) platform provided by the European Commission at:
              <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noreferrer"
                >https://ec.europa.eu/consumers/odr</a
              >.
            </p>
            <p>
              Our email address for out-of-court dispute resolution is:
              <a href="mailto:hello@amalfi.day">hello@amalfi.day</a>.
            </p>
          </article>

          <article class="policy__section">
            <h2>Applicable Law and Jurisdiction</h2>
            <p>
              These terms and conditions are governed by Italian law. For any dispute arising from the
              interpretation or performance of these terms, the Court of Salerno has exclusive
              jurisdiction, without prejudice to the mandatory consumer forum under Legislative Decree
              206/2005 (Consumer Code).
            </p>
          </article>

          <article class="policy__section">
            <h2>Changes to Terms</h2>
            <p>
              These terms may be updated periodically. Changes will be published on this page with
              the revision date. For information about how we handle your personal data, please see
              our <a href="/privacy">Privacy Policy</a>.
            </p>
          </article>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .section.policy {
    padding-top: clamp(7rem, 12vw, 10rem);
  }

  .policy__inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .policy__intro h1 {
    font-size: clamp(2.6rem, 4vw, 3.8rem);
  }

  .policy__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.5rem;
  }

  .policy__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .policy__card {
    padding: 1.5rem;
  }

  .policy__card h3 {
    margin-bottom: 0.8rem;
  }

  .policy__card ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-text-muted);
  }

  .policy__card li {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .policy__sections {
    display: grid;
    gap: 1.8rem;
  }

  .policy__section h2 {
    font-size: 1.4rem;
  }

  .policy__section a {
    color: var(--color-accent);
  }

  .policy__section ul {
    padding-left: 1.2rem;
    color: var(--color-text-muted);
  }

  .policy__section li {
    margin-bottom: 0.4rem;
    line-height: 1.6;
  }

  @media (max-width: 700px) {
    .policy__inner {
      gap: 2.2rem;
    }
  }
</style>
