---

<BaseLayout title={pageTitle} description={pageDescription} image={shareImage} imageAlt={shareImageAlt}>
  <section class="xp-hero hero--dark">
    <div class="xp-hero__slides" aria-hidden="true">
      {heroSlides.map((slide, i) => (
        <div class={`xp-hero__slide ${i === 0 ? 'is-active' : ''}`}>
          <img src={slide.image} alt="" loading={i === 0 ? 'eager' : 'lazy'} />
        </div>
      ))}
    </div>
    <div class="xp-hero__vignette"></div>
    <div class="xp-hero__content">
      <div class="container">
        <div class="xp-hero__grid">
          <div class="xp-hero__copy">
            <span class="xp-hero__eyebrow">Amalfi Day Photoshootings</span>
            <h1 class="xp-hero__title">
              Your story<br /><span class="xp-hero__title-accent">in golden light</span>
            </h1>
            <p class="xp-hero__lead">
              Cinematic photo sessions on the Amalfi Coast — couples, solo portraits, and influencer shoots in the most beautiful locations.
            </p>
            <div class="xp-hero__actions">
              <a class="xp-hero__btn xp-hero__btn--primary" href="/contact">Book your session</a>
              <a class="xp-hero__btn xp-hero__btn--ghost" href="/experience">See experiences</a>
            </div>
          </div>
          <div class="xp-hero__aside">
            <ul class="xp-hero__tags">
              {heroTags.map((tag, i) => (
                <li class="xp-hero__tag" style={`animation-delay: ${0.6 + i * 0.08}s`}>{tag}</li>
              ))}
            </ul>
            <div class="xp-hero__progress">
              {heroSlides.map((slide, i) => (
                <button
                  class={`xp-hero__dot ${i === 0 ? 'is-active' : ''}`}
                  data-slide={i}
                  aria-label={`Show ${slide.label}`}
                >
                  <span class="xp-hero__dot-label">{slide.label}</span>
                  <span class="xp-hero__dot-bar"><span class="xp-hero__dot-fill"></span></span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="xp-hero__scroll-hint" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <script is:inline>
    ;(function () {
      const slides = document.querySelectorAll('.xp-hero__slide')
      const dots = document.querySelectorAll('.xp-hero__dot')
      if (!slides.length) return

      let current = 0
      const DURATION = 6000

      function go(next) {
        slides[current].classList.remove('is-active')
        dots[current].classList.remove('is-active')
        current = next
        slides[current].classList.add('is-active')
        dots[current].classList.add('is-active')
      }

      let timer = setInterval(() => go((current + 1) % slides.length), DURATION)

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          clearInterval(timer)
          go(Number(dot.dataset.slide))
          timer = setInterval(() => go((current + 1) % slides.length), DURATION)
        })
      })
    })()
  </script>

  <!-- ═══════ 1. INDIVIDUAL GALLERY ═══════ -->
