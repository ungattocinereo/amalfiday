const faqs = [
  {
    q: 'Is there a direct bus from Naples Airport to Amalfi?',
    a: 'Yes. Pintour lists a direct Naples Capodichino Airport to Amalfi shuttle with intermediate stops including Vietri, Cetara, Maiori, Minori, Ravello/Castiglione, Atrani, and Amalfi. Check live booking because seasonal timetables can change.',
  },
  {
    q: 'What is the best way from Naples Airport to Positano?',
    a: 'In ferry season, the smoothest public route is often Alibus to Naples Beverello or train to Salerno, then ferry to Positano. Outside ferry season or after a late landing, book a taxi or private transfer if you have luggage.',
  },
  {
    q: 'How much is a taxi from Naples Airport to the Amalfi Coast?',
    a: 'The official Naples fixed taxi tariff lists Positano at EUR 145, Amalfi at EUR 155, and Ravello at EUR 160 per cab. Motorway tolls and the EUR 5 minivan supplement are excluded.',
  },
