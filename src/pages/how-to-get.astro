const airportJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: pageTitle,
    description: pageDescription,
    image: `${site.url}${shareImage}`,
    url: `${site.url}/how-to-get`,
    dateModified: updatedDate,
    author: { '@id': `${site.url}/#business` },
    publisher: { '@id': `${site.url}/#business` },
    mainEntityOfPage: `${site.url}/how-to-get`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.a,
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Naples Airport to Amalfi Coast',
        item: `${site.url}/how-to-get`,
      },
    ],
  },
]
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={shareImage}
  imageAlt="Travel route to the Amalfi Coast"
  type="article"
  jsonLd={airportJsonLd}
>
  <article class="airport-page">
    <section class="airport-hero hero--dark">
      <div class="airport-hero__slides" aria-hidden="true">
        {heroSlides.map((slide, i) => (
          <div class={`airport-hero__slide ${i === 0 ? 'is-active' : ''}`}>
            <CldImage
              class="airport-hero__image"
              src={slide.image}
              alt={slide.alt}
              width={slide.width}
              height={slide.height}
              priority={i === 0}
              eager={i === 0}
              sizes="100vw"
            />
          </div>
        ))}
      </div>
      <div class="airport-hero__vignette"></div>
      <div class="airport-hero__content">
        <div class="container">
          <div class="airport-hero__grid">
            <div class="airport-hero__copy">
              <span class="airport-eyebrow">Airport transfer planner 2026</span>
              <h1 class="airport-hero__title">
                Naples Airport<br /><span class="airport-hero__title-accent accent-italic">to Amalfi Coast</span>
              </h1>
              <p class="airport-hero__lead">
                Choose by destination, bags, and arrival time. Before afternoon, public
                transport can be excellent. After evening, transfer or an overnight stop is
                often the smarter move.
              </p>
              <div class="airport-hero__stats">
                {heroStats.map((item) => (
                  <div class="airport-hero__stat">
                    <strong>{item.value}</strong>
                    <span>{item.label}</span>
                  </div>
                ))}
              </div>
              <div class="airport-hero__actions">
                <a class="airport-button airport-button--primary" href="#routes">
                  <i class="fa-solid fa-route" aria-hidden="true"></i>
                  Compare Routes
                </a>
                <a class="airport-button airport-button--ghost" href="#tickets">
                  <i class="fa-solid fa-ticket" aria-hidden="true"></i>
                  Ticket Apps
                </a>
              </div>
            </div>

            <div class="airport-hero__aside">
              <ul class="airport-hero__tags">
                {heroTags.map((tag, i) => (
                  <li class="airport-hero__tag" style={`animation-delay: ${0.6 + i * 0.08}s`}>{tag}</li>
                ))}
              </ul>
              <div class="airport-hero__progress" aria-label="Hero image routes">
                {heroSlides.map((slide, i) => (
                  <button
                    class={`airport-hero__dot ${i === 0 ? 'is-active' : ''}`}
                    type="button"
                    data-slide={i}
                    aria-label={`Show ${slide.label}`}
                  >
                    <span class="airport-hero__dot-label">{slide.label}</span>
                    <span class="airport-hero__dot-bar"><span class="airport-hero__dot-fill"></span></span>
                  </button>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="airport-hero__scroll-hint" aria-hidden="true">
        <span></span>
      </div>
    </section>

    <section class="airport-choice-band" aria-label="Route shortcuts">
      <div class="container">
        <div class="airport-choice-grid">
          {routeChoices.map((choice) => (
            <a class="choice-card" href={choice.href}>
              <span class="choice-card__icon">
                <i class={`fa-solid ${choice.icon}`} aria-hidden="true"></i>
              </span>
              <span class="choice-card__label">{choice.label}</span>
              <strong>{choice.title}</strong>
              <small>{choice.route}</small>
              <dl>
                <div>
                  <dt>For</dt>
                  <dd>{choice.bestFor}</dd>
                </div>
                <div>
                  <dt>Time</dt>
                  <dd>{choice.time}</dd>
                </div>
                <div>
                  <dt>Cost</dt>
                  <dd>{choice.cost}</dd>
                </div>
              </dl>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section airport-section" id="routes">
      <div class="container">
        <div class="airport-section__head">
          <span class="airport-kicker">Route Planner</span>
