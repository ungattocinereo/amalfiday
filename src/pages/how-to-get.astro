    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .airport-hero__scroll-hint {
    position: absolute;
    z-index: 3;
    bottom: clamp(1rem, 2.5vh, 2rem);
    left: 50%;
    transform: translateX(-50%);
