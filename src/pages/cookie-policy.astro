---
import BaseLayout from '../layouts/BaseLayout.astro'

const pageTitle = 'Cookie Policy — Amalfi.Day'
const pageDescription =
  'Cookie policy for amalfi.day: which cookies we use, why, and how to manage them.'
const shareImage = '/pre-footer/2-food-in-amalfi-good.webp'
---

<BaseLayout title={pageTitle} description={pageDescription} image={shareImage}>
  <section class="section policy">
    <div class="container policy__inner">
      <div class="policy__intro">
        <h1>
          Cookie <span class="accent-italic">Policy</span>
        </h1>
        <p>
          This page explains which cookies and tracking technologies we use on amalfi.day,
          why we use them, and how you can manage them.
        </p>
        <div class="policy__meta">
          <span class="badge"><i class="fa-solid fa-cookie"></i> Cookies and localStorage</span>
          <span class="badge"
            ><i class="fa-solid fa-calendar"></i> Last updated: 21 February 2026</span
          >
        </div>
      </div>

      <div class="policy__content">
        <div class="policy__grid">
          <div class="card policy__card">
            <h3>Technical Cookies</h3>
            <ul>
              <li>Theme preference (light/dark) — localStorage.</li>
              <li>Cookie consent choice — localStorage.</li>
              <li>Contact form anti-spam protection — localStorage.</li>
            </ul>
          </div>
          <div class="card policy__card">
            <h3>Analytics Cookies</h3>
            <ul>
              <li>Google Analytics: <code>_ga</code>, <code>_ga_*</code> (duration: 2 years).</li>
              <li>Collect anonymous browsing data.</li>
              <li>Activated only with explicit consent.</li>
            </ul>
          </div>
          <div class="card policy__card">
            <h3>Third-Party Cookies</h3>
            <ul>
              <li>No marketing or profiling cookies.</li>
              <li>No tracking pixels (Facebook, etc.).</li>
            </ul>
          </div>
          <div class="card policy__card">
            <h3>Managing Cookies</h3>
            <ul>
              <li>Use the "Cookie settings" link in the site footer.</li>
              <li>Disable cookies in your browser settings.</li>
              <li>Install the Google Analytics opt-out add-on.</li>
            </ul>
          </div>
        </div>

        <div class="policy__sections">
          <article class="policy__section">
            <h2>What Are Cookies</h2>
            <p>
              Cookies are small text files stored by your browser when you visit a website.
              They allow the site to remember your preferences and collect anonymous usage
              information. The term "cookies" in this policy also includes equivalent technologies
              such as localStorage.
            </p>
          </article>

          <article class="policy__section">
            <h2>Essential Technical Cookies</h2>
            <p>
              These cookies are necessary for the website to function and do not collect personal
              data. They do not require consent.
            </p>
            <div class="policy__table-wrap">
              <table class="policy__table">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Purpose</th>
                    <th>Duration</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><code>theme</code></td>
                    <td>localStorage</td>
                    <td>Saves light/dark theme preference</td>
                    <td>Persistent</td>
                  </tr>
                  <tr>
                    <td><code>cookie-consent</code></td>
                    <td>localStorage</td>
                    <td>Records analytics cookie consent choice</td>
                    <td>Persistent</td>
                  </tr>
                  <tr>
                    <td><code>amalfi-contact-last-submit-at</code></td>
                    <td>localStorage</td>
                    <td>Contact form anti-spam protection (60 sec. cooldown)</td>
                    <td>Session</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </article>

          <article class="policy__section">
            <h2>Analytics Cookies — Google Analytics</h2>
            <p>
              We use Google Analytics 4 (ID: G-C2E8E3XBBJ) to understand how visitors use the site.
              These cookies are activated <strong>only after your explicit consent</strong> via the
              cookie banner.
            </p>
            <div class="policy__table-wrap">
              <table class="policy__table">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Purpose</th>
                    <th>Duration</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><code>_ga</code></td>
                    <td>HTTP Cookie</td>
                    <td>Distinguishes users anonymously</td>
                    <td>2 years</td>
                  </tr>
                  <tr>
                    <td><code>_ga_C2E8E3XBBJ</code></td>
                    <td>HTTP Cookie</td>
                    <td>Maintains session state</td>
                    <td>2 years</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p>
              The data collected is aggregated and anonymous. Google acts as a data processor in
              accordance with the
              <a href="https://business.safety.google/processorterms/" target="_blank" rel="noreferrer"
                >Google Data Processing Agreement</a
              >.
            </p>
          </article>

          <article class="policy__section">
            <h2>Third-Party Cookies</h2>
            <p>
              Fonts are self-hosted on this site, so no third-party font CDN (such as Google Fonts) is
              contacted on page load. Apart from Google Analytics described above, we do not use
              marketing cookies, profiling cookies, or tracking pixels (Facebook Pixel, etc.).
            </p>
          </article>

          <article class="policy__section">
            <h2>How to Manage or Disable Cookies</h2>
            <p>You can manage cookies in several ways:</p>
            <ul>
              <li>
                <strong>Site banner:</strong> click "Cookie settings" in the footer to change your
                choice at any time.
              </li>
              <li>
                <strong>Browser settings:</strong> all browsers allow you to block or delete cookies.
                Refer to your browser's help guide (Chrome, Firefox, Safari, Edge).
              </li>
              <li>
                <strong>Google Analytics opt-out:</strong> install the
                <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noreferrer"
                  >opt-out browser add-on</a
                > available for all major browsers.
              </li>
            </ul>
            <p>
              Disabling technical cookies may affect some website features (for example, your theme
              preference may not be saved).
            </p>
          </article>

          <article class="policy__section">
            <h2>Changes to This Cookie Policy</h2>
            <p>
              This cookie policy may be updated periodically. Changes will be published on this page
              with the revision date. For complete information about how we handle your personal data,
              please see our <a href="/privacy">Privacy Policy</a>.
            </p>
          </article>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .section.policy {
    padding-top: clamp(7rem, 12vw, 10rem);
  }

  .policy__inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .policy__intro h1 {
    font-size: clamp(2.6rem, 4vw, 3.8rem);
  }

  .policy__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.5rem;
  }

  .policy__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .policy__card {
    padding: 1.5rem;
  }

  .policy__card h3 {
    margin-bottom: 0.8rem;
  }

  .policy__card ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-text-muted);
  }

  .policy__card li {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .policy__card code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-surface);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }

  .policy__sections {
    display: grid;
    gap: 1.8rem;
  }

  .policy__section h2 {
    font-size: 1.4rem;
  }

  .policy__section a {
    color: var(--color-accent);
  }

  .policy__section ul {
    padding-left: 1.2rem;
    color: var(--color-text-muted);
  }

  .policy__section li {
    margin-bottom: 0.4rem;
    line-height: 1.6;
  }

  .policy__section code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-surface);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }

  .policy__table-wrap {
    overflow-x: auto;
    margin: 1rem 0;
  }

  .policy__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .policy__table th,
  .policy__table td {
    text-align: left;
    padding: 0.65rem 0.9rem;
    border-bottom: 1px solid var(--color-border);
  }

  .policy__table th {
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
  }

  .policy__table td {
    color: var(--color-text);
  }

  .policy__table td code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-surface);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }

  @media (max-width: 700px) {
    .policy__inner {
      gap: 2.2rem;
    }
  }
</style>
