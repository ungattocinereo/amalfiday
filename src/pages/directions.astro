---
import BaseLayout from '../layouts/BaseLayout.astro'
import { site } from '../data/site'

const pageTitle = 'Directions to Atrani — Amalfi.Day'
const pageDescription =
  'How to reach Atrani on the Amalfi Coast: trains from Naples to Salerno, ferry and bus options, walking directions from Amalfi, driving routes, and parking tips.'
const shareImage = '/staticpages/directions/hero-bb-balcony.webp'

const heroSlides = [
  {
    image: '/staticpages/directions/hero-bb-balcony.webp',
    label: 'Terrace',
    width: 2400,
    height: 1809,
    position: 'center center',
  },
  {
    image: '/staticpages/directions/hero-bb-living.webp',
    label: 'Bright',
    width: 2400,
    height: 1632,
    position: 'center center',
  },
  {
    image: '/staticpages/directions/hero-bb-room-white.webp',
    label: 'Spacious',
    width: 2400,
    height: 1600,
    position: 'center center',
  },
  {
    image: '/staticpages/directions/hero-bb-room-wardrobe.webp',
    label: 'Cozy',
    width: 2400,
    height: 1600,
    position: 'center center',
  },
  {
    image: '/staticpages/directions/hero-bb-bedroom-desk.webp',
    label: 'Modest',
    width: 2400,
    height: 1601,
    position: 'center center',
  },
]

const transportSteps = [
  {
    step: '01',
    icon: 'fa-train',
    title: 'Naples',
    accent: 'to Salerno',
    mapSrc:
      'https://www.google.com/maps/embed?pb=!1m28!1m12!1m3!1d193401.59623369444!2d14.382212835982248!3d40.76422540917123!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!4m13!3e3!4m5!1s0x133b081659811bf3%3A0x26f7eaf2d2c03d87!2sNapoli+Centrale%2C+Piazza+Giuseppe+Garibaldi%2C+Naples%2C+Metropolitan+City+of+Naples!3m2!1d40.8529221!2d14.2723433!4m5!1s0x133bc238feb9bccd%3A0x69268f1bf0331971!2sSalerno%2C+Salerno%2C+Province+of+Salerno!3m2!1d40.6752834!2d14.772289599999999!5e0!3m2!1sen!2sit!4v1552303528152',
    description:
      'Start at Napoli Centrale and take a train to Salerno. Multiple trains run daily and the ride takes roughly the same time on all of them. Check schedules and buy tickets at trenitalia.com. Coming from other Italian cities? italotreno.it offers faster, more comfortable options.',
    links: [
      { text: 'trenitalia.com', url: 'https://www.trenitalia.com', icon: 'fa-up-right-from-square' },
      { text: 'italotreno.it', url: 'https://www.italotreno.it/en', icon: 'fa-up-right-from-square' },
    ],
  },
  {
    step: '02',
    icon: 'fa-water',
    title: 'Salerno',
    accent: 'to Amalfi',
    mapSrc: null,
    description: 'From Salerno you have two options to reach Amalfi: ferry or bus. Both depart near the train station. The ferry is faster and scenic; the bus is cheaper and runs more frequently. Choose whichever suits your schedule.',
    links: [],
  },
]

const ferryBus = [
  {
    icon: 'fa-water',
    mode: 'Ferry',
    accent: 'scenic route',
    time: '~35 min',
    price: 'from 12€',
    priceNote: 'Luggage +3€ · Pets +5€',
    image: '/staticpages/directions/get-here-by-ferry.webp',
    description:
      'Walk two blocks from the station towards the sea to reach Salerno seaport Concordia. The ferry is the fastest and most scenic way to Amalfi — no stop in Atrani. Once in Amalfi, turn right as you exit the ferry terminal and follow the waterfront road. The walk to Atrani takes about 10 minutes.',
    link: { text: 'Ferry timetables (PDF)', url: '/files/FERRY-timetables.pdf' },
  },
  {
    icon: 'fa-bus',
    mode: 'Bus',
    accent: 'budget route',
    time: '~75 min',
    price: 'from 2.80€',
    priceNote: 'Luggage included',
    image: '/staticpages/directions/get-here-by-bus.webp',
    description:
      'Right outside the train station you\'ll find a SITA bus stop. Look for line 5120 heading to Amalfi (shown on Google Maps or the Moovit app). The bus destination is displayed at the top. Important: buy your ticket before boarding at any Tabacchi shop (look for the "T" sign).',
    link: { text: 'Bus timetables (PDF)', url: '/files/BUS-timetables.pdf' },
  },
]

const heroTags = [
  'Train to Salerno',
  'Ferry or bus',
  '10-minute walk',
  'Skip Sorrento',
  'Parking tips',
]

const walkingMapSrc =
  'https://www.google.com/maps/embed?pb=!1m34!1m12!1m3!1d3027.783177685797!2d14.602921515089081!3d40.63466340028073!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!4m19!3e2!4m5!1s0x133b95adeeb3beb1%3A0xce3612645bf68968!2sFlavio%20Gioia%2C%20Via%20Lungomare%20dei%20Cavalieri%2C%20Amalfi%2C%20SA!3m2!1d40.633595899999996!2d14.6015562!4m5!1s0x133b95764da04449%3A0x4e2b19b97e30cee9!2sdejavu%20Amalfi%2C%20Piazza%20Municipio%2C%20Amalfi%2C%20SA!3m2!1d40.6343113!2d14.6044869!4m5!1s0x133b95a8e2219069%3A0xb6fe52d5ce1da27e!2sAtrani%2C%2084010%20SA!3m2!1d40.6357929!2d14.608620199999999!5e0!3m2!1sen!2sit!4v1600799650925!5m2!1sen!2sit'

const drivingRoutes = [
  {
    icon: 'fa-signs-post',
    name: 'Via Vietri Sul Mare',
    tag: 'Recommended',
    tagColor: 'green',
    description: 'Best and easiest way to get here. Mostly autostrada, then 40 minutes on the scenic Amalfi Drive.',
    mapSrc:
      'https://www.google.com/maps/embed?pb=!1m34!1m12!1m3!1d193406.8796035415!2d14.368275172026657!3d40.7624097678548!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!4m19!3e0!4m5!1s0x133ba81e8986d9e3%3A0xbf48c58ba6c9356d!2sNaples+International+Airport%2C+Viale+F.+Ruffo+di+Calabria%2C+80144+Napoli+NA!3m2!1d40.884749299999996!2d14.289242999999999!4m5!1s0x133bc1c1b213bded%3A0x1c97dd0bbf1cf787!2sVietri+Sul+Mare%2C+Province+of+Salerno!3m2!1d40.667944899999995!2d14.7278743!4m5!1s0x133b95a8e2219069%3A0xb6fe52d5ce1da27e!2sAtrani%2C+Province+of+Salerno!3m2!1d40.6357929!2d14.608620199999999!5e0!3m2!1sen!2sit!4v1549449540895',
  },
  {
    icon: 'fa-leaf',
    name: 'Via Sorrento',
    tag: 'Scenic',
    tagColor: 'blue',
    description: 'One of the curliest roads in Italy. Heavy traffic near Positano, but the views are extraordinary.',
    mapSrc:
      'https://www.google.com/maps/embed?pb=!1m34!1m12!1m3!1d193444.73588044615!2d14.306266970445343!3d40.749398424498246!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!4m19!3e0!4m5!1s0x133ba81e8986d9e3%3A0xbf48c58ba6c9356d!2sNaples+International+Airport%2C+Viale+F.+Ruffo+di+Calabria%2C+80144+Napoli+NA!3m2!1d40.884749299999996!2d14.289242999999999!4m5!1s0x133b9908fa0c0919%3A0xb396785a92762205!2sMeta%2C+Metropolitan+City+of+Naples!3m2!1d40.6428867!2d14.417339799999999!4m5!1s0x133b95a8e2219069%3A0xb6fe52d5ce1da27e!2sAtrani%2C+Province+of+Salerno!3m2!1d40.6357929!2d14.608620199999999!5e0!3m2!1sen!2sit!4v1549451299042',
  },
  {
    icon: 'fa-triangle-exclamation',
    name: 'Via Chiunzi & Ravello',
    tag: 'Challenging',
    tagColor: 'orange',
    description: 'The most demanding route. Narrow mountain road climbing to 880m. Not recommended for nervous drivers.',
    mapSrc:
      'https://www.google.com/maps/embed?pb=!1m34!1m12!1m3!1d193404.54078998204!2d14.312590722124368!3d40.76321351435591!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!4m19!3e0!4m5!1s0x133ba81e8986d9e3%3A0xbf48c58ba6c9356d!2sNaples+International+Airport%2C+Viale+F.+Ruffo+di+Calabria%2C+80144+Napoli+NA!3m2!1d40.884749299999996!2d14.289242999999999!4m5!1s0x133bbf1b74ad1205%3A0x31c12e12f653d572!2sValico+di+Chiunzi%2C+SP2b%2C+Sant%27Egidio+del+Monte+Albino%2C+Province+of+Salerno!3m2!1d40.7188042!2d14.619424799999999!4m5!1s0x133b95a8e2219069%3A0xb6fe52d5ce1da27e!2sAtrani%2C+Province+of+Salerno!3m2!1d40.6357929!2d14.608620199999999!5e0!3m2!1sen!2sit!4v1549452336042',
  },
]

const parkingOptions = [
  {
    icon: 'fa-square-parking',
    title: 'Street parking outside Atrani',
    accent: 'cheapest',
    price: '24€/24h',
    note: 'Free 22:00–08:00',
    description: 'Parking on the street along the coast road, just outside Atrani. The cheapest option on the entire Amalfi Coast.',
    link: {
      text: 'Open in Google Maps',
      url: 'https://maps.app.goo.gl/p6JhZaNCqfMnYoe78',
    },
  },
  {
    icon: 'fa-location-dot',
    title: 'Parcheggio Luna Rossa',
    accent: 'closest',
    price: 'from 40€/day',
    note: 'Open 24 hours',
    description: 'The closest paid parking garage to Atrani, a 5-minute walk away. If full, follow signs to the Amalfi seaport parking.',
    link: {
      text: 'Open in Google Maps',
      url: 'https://www.google.com/maps/place/Luna+Rossa/@40.6340223,14.6069911,15z/data=!4m5!3m4!1s0x0:0x4e0d420597d2f73d!8m2!3d40.6340223!4d14.6069911',
    },
  },
  {
    icon: 'fa-clock-rotate-left',
    title: 'Atrani town parking',
    accent: 'limited',
    price: '3€/hr',
    note: 'No overnight parking',
    description: 'There is a small public lot in Atrani itself, but overnight parking is forbidden. You must move your car out by 23:00.',
    link: {
      text: 'Open in Google Maps',
      url: 'https://maps.app.goo.gl/Vq8DE8haYbBivReL7',
    },
  },
]

const directionsFaqs = [
  {
    q: 'How do I get to Atrani from Naples airport?',
    a: 'Take a train from Napoli Centrale to Salerno (around an hour), then either a ferry (~35 min, from 12 EUR) or the SITA bus line 5120 (~75 min, from 2.80 EUR) to Amalfi. From Amalfi, walk along the waterfront for about 10 minutes to Atrani.',
  },
  {
    q: 'Is the ferry or the bus faster from Salerno to Amalfi?',
    a: 'The ferry is faster — about 35 minutes versus 75 minutes by bus — and far more scenic. The bus is cheaper (from 2.80 EUR) and runs more frequently year-round. The ferry costs from 12 EUR with luggage at 3 EUR extra.',
  },
  {
    q: 'Do I need to buy SITA bus tickets in advance?',
    a: 'Buy your ticket before boarding at any Tabacchi shop displaying the "T" sign. You cannot buy tickets on the bus. Validate the ticket in the machine when you board.',
  },
  {
    q: 'Which driving route to Atrani is easiest?',
    a: 'Via Vietri sul Mare is the recommended route — mostly autostrada, then about 40 minutes on the scenic Amalfi Drive (SS163). Via Sorrento is more scenic but heavily congested near Positano. Via Chiunzi & Ravello is the most challenging and not recommended for nervous drivers.',
  },
  {
    q: 'Can I park in Atrani overnight?',
    a: 'No — overnight parking is forbidden in Atrani town. The closest paid garage is Parcheggio Luna Rossa in Amalfi (from 40 EUR/day, 5 minutes on foot). The cheapest option is street parking on the coastal road just outside Atrani at 24 EUR per 24h.',
  },
]

const directionsJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: pageTitle,
    description: pageDescription,
    url: `${site.url}/directions`,
    image: new URL(shareImage, site.url).toString(),
    author: { '@id': `${site.url}/#business` },
    publisher: { '@id': `${site.url}/#business` },
    inLanguage: 'en',
    about: { '@type': 'Place', name: 'Atrani, Amalfi Coast' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: directionsFaqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: 'Directions', item: `${site.url}/directions` },
    ],
  },
]
---

<BaseLayout title={pageTitle} description={pageDescription} image={shareImage} jsonLd={directionsJsonLd}>
  <!-- ─── HERO ─── -->
  <section class="dir-hero hero--dark">
    <div class="dir-hero__slides" aria-hidden="true">
      {heroSlides.map((slide, i) => (
        <div class={`dir-hero__slide ${i === 0 ? 'is-active' : ''}`}>
          <img
            src={slide.image}
            alt={`Gregory's B&B in Atrani — ${slide.label}`}
            loading={i === 0 ? 'eager' : 'lazy'}
            fetchpriority={i === 0 ? 'high' : 'auto'}
            width={slide.width}
            height={slide.height}
            style={`--slide-position: ${slide.position};`}
          />
        </div>
      ))}
    </div>
    <div class="dir-hero__vignette" aria-hidden="true"></div>
    <div class="dir-hero__content">
      <div class="container">
        <div class="dir-hero__grid">
          <div class="dir-hero__copy">
            <span class="dir-hero__eyebrow">Three-step guide</span>
            <h1 class="dir-hero__title">
              Get to Atrani and find <span class="dir-hero__title-accent">our B&B</span>
            </h1>
            <p class="dir-hero__lead">
              Reach the Amalfi Coast in two simple steps: train to Salerno, then ferry or bus to Amalfi. Atrani is a 10-minute walk from there.
            </p>
            <nav class="dir-hero__actions" aria-label="Directions sections">
              <a class="dir-hero__btn dir-hero__btn--primary" href="#public-transport"><i class="fa-solid fa-train"></i> Public transport</a>
              <a class="dir-hero__btn dir-hero__btn--ghost" href="#walking"><i class="fa-solid fa-signs-post"></i> Walking route</a>
              <a class="dir-hero__btn dir-hero__btn--ghost" href="#driving"><i class="fa-solid fa-car"></i> Driving</a>
              <a class="dir-hero__btn dir-hero__btn--ghost" href="#parking"><i class="fa-solid fa-square-parking"></i> Parking</a>
            </nav>
          </div>
          <aside class="dir-hero__aside">
            <ul class="dir-hero__tags" aria-label="Route highlights">
              {heroTags.map((tag, i) => (
                <li class="dir-hero__tag" style={`animation-delay: ${0.6 + i * 0.08}s`}>{tag}</li>
              ))}
            </ul>
            <div class="dir-hero__progress">
              {heroSlides.map((slide, i) => (
                <button
                  class={`dir-hero__dot ${i === 0 ? 'is-active' : ''}`}
                  data-slide={i}
                  aria-label={`Show ${slide.label}`}
                >
                  <span class="dir-hero__dot-label">{slide.label}</span>
                  <span class="dir-hero__dot-bar"><span class="dir-hero__dot-fill"></span></span>
                </button>
              ))}
            </div>
            <p class="dir-hero__note">
              Go to <strong>Salerno</strong> by train, then take a bus or ferry to <strong>Amalfi</strong>. Watch out for Google Maps errors — it sometimes routes you through Sorrento, which adds hours.
            </p>
          </aside>
        </div>
      </div>
    </div>
    <div class="dir-hero__scroll-hint" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <!-- ─── STEP 1 & 2: PUBLIC TRANSPORT ─── -->
  <section class="section dir-transport" id="public-transport">
    <div class="container">
      <div class="dir-eyebrow">Step-by-step</div>
      <h2>Getting to Atrani with <span class="accent-italic">public</span> transport</h2>
      <p class="dir-transport__sub">The journey has three legs. All are straightforward.</p>

      <!-- Step 1: Naples to Salerno -->
      <div class="dir-step">
        <div class="dir-step__number">{transportSteps[0].step}</div>
        <div class="dir-step__body">
          <div class="dir-step__header">
            <i class={`fa-solid ${transportSteps[0].icon}`}></i>
            <h3>{transportSteps[0].title} <span class="accent-italic">{transportSteps[0].accent}</span></h3>
          </div>
          <p>{transportSteps[0].description}</p>
          <div class="dir-step__links">
            {transportSteps[0].links.map((l) => (
              <a href={l.url} target="_blank" rel="noopener">
                {l.text} <i class={`fa-solid ${l.icon}`}></i>
              </a>
            ))}
          </div>
          <div class="dir-map">
            <iframe
              src={transportSteps[0].mapSrc}
              width="100%"
              height="280"
              style="border:0; border-radius: var(--radius-md);"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Map: Naples to Salerno train route"
            ></iframe>
          </div>
        </div>
      </div>

      <!-- Step 2: Salerno to Amalfi -->
      <div class="dir-step">
        <div class="dir-step__number">{transportSteps[1].step}</div>
        <div class="dir-step__body">
          <div class="dir-step__header">
            <i class={`fa-solid ${transportSteps[1].icon}`}></i>
            <h3>{transportSteps[1].title} <span class="accent-italic">{transportSteps[1].accent}</span></h3>
          </div>
          <p>{transportSteps[1].description}</p>

          <div class="dir-options">
            {ferryBus.map((opt) => (
              <article class="dir-option card">
                {opt.image && (
                  <div class="dir-option__image">
                    <img src={opt.image} alt={`${opt.mode} to Amalfi`} loading="lazy" />
                  </div>
                )}
                <div class="dir-option__head">
                  <div class="dir-option__icon">
                    <i class={`fa-solid ${opt.icon}`}></i>
                  </div>
                  <div>
                    <h4>{opt.mode} <span class="accent-italic">{opt.accent}</span></h4>
                    <span class="dir-option__time"><i class="fa-solid fa-clock"></i> {opt.time}</span>
                  </div>
                </div>
                <p>{opt.description}</p>
                {opt.price && (
                  <div class="dir-option__pricing">
                    <span class="dir-option__price"><strong>{opt.price}</strong></span>
                    {opt.priceNote && <span class="dir-option__price-note">{opt.priceNote}</span>}
                  </div>
                )}
                <div class="dir-option__links">
                  {opt.link && (
                    <a class="dir-option__dl" href={opt.link.url} target="_blank" rel="noopener">
                      <i class="fa-solid fa-file-pdf"></i> {opt.link.text}
                    </a>
                  )}
                  {opt.bookLink && (
                    <a class="dir-option__book" href={opt.bookLink.url} target="_blank" rel="noopener">
                      <i class="fa-solid fa-ticket"></i> {opt.bookLink.text}
                    </a>
                  )}
                </div>
              </article>
            ))}
          </div>

          <div class="dir-useful-links">
            <h4>Useful links</h4>
            <div class="dir-useful-links__grid">
              <a href="https://www.travelmar.it/en/index" target="_blank" rel="noopener" class="dir-useful-link">
                <span class="dir-useful-link__icon"><i class="fa-solid fa-water"></i></span>
                <span class="dir-useful-link__body">
                  <span class="dir-useful-link__name">Travelmar</span>
                  <span class="dir-useful-link__desc">Ferry tickets & schedules</span>
                </span>
                <i class="fa-solid fa-up-right-from-square dir-useful-link__arrow"></i>
              </a>
              <a href="https://www.unicocampania.it" target="_blank" rel="noopener" class="dir-useful-link">
                <span class="dir-useful-link__icon"><i class="fa-solid fa-credit-card"></i></span>
                <span class="dir-useful-link__body">
                  <span class="dir-useful-link__name">Unico Campania</span>
                  <span class="dir-useful-link__desc">Regional transport passes</span>
                </span>
                <i class="fa-solid fa-up-right-from-square dir-useful-link__arrow"></i>
              </a>
              <a href="https://moovitapp.com/" target="_blank" rel="noopener" class="dir-useful-link">
                <span class="dir-useful-link__icon"><i class="fa-solid fa-mobile-screen-button"></i></span>
                <span class="dir-useful-link__body">
                  <span class="dir-useful-link__name">Moovit</span>
                  <span class="dir-useful-link__desc">Live bus & ferry tracker</span>
                </span>
                <i class="fa-solid fa-up-right-from-square dir-useful-link__arrow"></i>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 3: Amalfi to Atrani -->
      <div class="dir-step" id="walking">
        <div class="dir-step__number">03</div>
        <div class="dir-step__body">
          <div class="dir-step__header">
            <i class="fa-solid fa-signs-post"></i>
            <h3>Amalfi <span class="accent-italic">to Atrani</span></h3>
          </div>
          <div class="dir-eyebrow" style="margin-top: -0.5rem;">On foot · ~10 min</div>
          <p>
            From the Amalfi bus stop or seaport, walk along the shore until you find a pedestrian tunnel on your left near <a href="https://goo.gl/maps/PjaTgYN1spVb1N9Y6" target="_blank" rel="noopener">Dejavu Amalfi</a>. This tunnel is always open and exclusively for pedestrians — the safest route between the two towns.
          </p>
          <p>
            Once you exit the tunnel, cross the road. You'll see the entrance to <a href="https://goo.gl/maps/nHHAdCS92NtrXi9D8" target="_blank" rel="noopener">Cantina Nostromo</a> restaurant on your left. Walk through it and down the steps to arrive in Atrani, just below the bus stop.
          </p>
          <p>
            From the main parking lot, head up to the <a href="https://goo.gl/maps/ocBVhiLBmwF2oKer5" target="_blank" rel="noopener">fruits and vegetables shop</a>. Continue to the tunnel and turn inside it toward the ring. After climbing about 10 steps, you'll arrive at your destination.
          </p>
          <div class="dir-walking__map">
            <iframe
              src={walkingMapSrc}
              width="100%"
              height="360"
              style="border:0; border-radius: var(--radius-md);"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
