---
import BaseLayout from '../layouts/BaseLayout.astro'
import CldImage from '../components/CldImage.astro'
import PhotoSpotsMap from '../components/PhotoSpotsMap.astro'
import { photoSpots } from '../data/photo-locations'
import { site } from '../data/site'

const pageTitle = 'Amalfi Coast Photo Spots Map — 25 Pinned Locations | Amalfi.Day'
const pageDescription =
  'Interactive Amalfi Coast photo spots map with Positano, Amalfi, Atrani, Ravello, Praiano, Furore, Sorrento, Capri, and local hidden viewpoints.'
const heroImage = '/photoshootings/ayuna/39-Ayuna-Atrani-2023.webp'
const shareImageAlt = 'Amalfi Coast photo spot portrait in Atrani'
const pageUrl = `${site.url}/photolocations`

const cities = Array.from(new Set(photoSpots.map((spot) => spot.city)))
const heroStats = [
  { value: String(photoSpots.length), label: 'pinned locations' },
  { value: String(cities.length), label: 'towns and routes' },
  { value: '1', label: 'local photographer CTA' },
]

const pageJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${pageUrl}#collection`,
    name: pageTitle,
    description: pageDescription,
    url: pageUrl,
    image: new URL(heroImage, site.url).toString(),
    inLanguage: 'en',
    isPartOf: { '@id': `${site.url}/#business` },
    about: { '@type': 'Place', name: 'Amalfi Coast' },
    mainEntity: {
      '@type': 'ItemList',
      name: 'Amalfi Coast photo spots',
      numberOfItems: photoSpots.length,
      itemListOrder: 'https://schema.org/ItemListOrderAscending',
      itemListElement: photoSpots.map((spot, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: `${pageUrl}#${spot.slug}`,
        name: `${spot.title}, ${spot.city}`,
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
      { '@type': 'ListItem', position: 2, name: 'Photo Spots', item: pageUrl },
    ],
  },
  ...photoSpots.map((spot) => ({
    '@context': 'https://schema.org',
    '@type': ['TouristAttraction', 'Place'],
    '@id': `${pageUrl}#${spot.slug}`,
    name: `${spot.title}, ${spot.city}`,
    description: spot.description.join(' '),
    url: `${pageUrl}#${spot.slug}`,
    image: new URL(spot.image.src, site.url).toString(),
    containedInPlace: {
      '@type': 'Place',
      name: spot.city === 'Amalfi Coast' ? 'Amalfi Coast' : `${spot.city}, Amalfi Coast`,
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: spot.coordinates.lat,
      longitude: spot.coordinates.lng,
    },
    isAccessibleForFree: spot.cost.toLowerCase().includes('free'),
  })),
]
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={heroImage}
  imageAlt={shareImageAlt}
  jsonLd={pageJsonLd}
  browserChromeColor="#101419"
>
  <section class="pl-hero hero--dark">
    <div class="pl-hero__media">
      <CldImage
        class="pl-hero__image"
        src={heroImage}
        alt="Atrani photo spot on the Amalfi Coast"
        width={1200}
        height={800}
        sizes="100vw"
        priority
      />
      <div class="pl-hero__film" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>
    <div class="pl-hero__veil" aria-hidden="true"></div>
    <div class="container pl-hero__content">
      <div class="pl-hero__copy">
        <p class="pl-hero__eyebrow">Amalfi.Day field map</p>
        <h1>Amalfi Coast Photo Spots Map</h1>
        <p class="pl-hero__lead">
          Every perfect shot, pinned. From iconic viewpoints to secret locals-only terraces.
        </p>
        <div class="pl-hero__actions">
          <a class="pl-button pl-button--primary" href="#photo-spots-map">
            <i class="fa-solid fa-map-location-dot"></i>
            Explore photo spots
          </a>
          <a class="pl-button pl-button--ghost" href="/contact?service=Photoshooting&spot=Amalfi%20Coast%20photo%20spots">
            <i class="fa-solid fa-camera"></i>
            Book photographer
          </a>
        </div>
      </div>
      <aside class="pl-hero__panel" aria-label="Photo spots summary">
        <div class="pl-hero__stats">
          {heroStats.map((item) => (
            <div>
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </div>
          ))}
        </div>
        <div class="pl-hero__towns">
          {['Positano', 'Amalfi', 'Atrani', 'Ravello', 'Praiano', 'Capri'].map((town) => (
            <span>{town}</span>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <PhotoSpotsMap spots={photoSpots} />
</BaseLayout>

<style>
  .pl-hero {
    position: relative;
    min-height: 62svh;
    display: grid;
    align-items: end;
    overflow: hidden;
    color: #ffffff;
    background: #101419;
  }

  .pl-hero__media,
  .pl-hero__veil {
    position: absolute;
    inset: 0;
  }

  .pl-hero__media {
    z-index: 0;
  }

  .pl-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
    filter: saturate(1.04) contrast(1.04);
  }

  .pl-hero__film {
    position: absolute;
    right: max(1.2rem, 4vw);
    bottom: 6.5rem;
    display: grid;
    grid-template-columns: repeat(4, 3.4rem);
    gap: 0.5rem;
    padding: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.34);
    background: rgba(16, 20, 25, 0.32);
    backdrop-filter: blur(10px);
  }

  .pl-hero__film span {
    aspect-ratio: 1;
    border: 1px solid rgba(255, 255, 255, 0.32);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.2), transparent),
      rgba(255, 89, 0, 0.32);
  }

  .pl-hero__film span:nth-child(2) {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.2), transparent),
      rgba(0, 156, 255, 0.34);
  }

  .pl-hero__film span:nth-child(3) {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.2), transparent),
      rgba(255, 195, 0, 0.34);
  }

  .pl-hero__film span:nth-child(4) {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.2), transparent),
      rgba(0, 166, 118, 0.34);
  }

  .pl-hero__veil {
    z-index: 1;
    background:
      linear-gradient(90deg, rgba(16, 20, 25, 0.9) 0%, rgba(16, 20, 25, 0.66) 42%, rgba(16, 20, 25, 0.2) 100%),
      linear-gradient(180deg, rgba(16, 20, 25, 0.3) 0%, rgba(16, 20, 25, 0.38) 48%, #101419 100%);
  }

  .pl-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(260px, 0.48fr);
    gap: 2rem;
    align-items: end;
    padding-top: 7rem;
    padding-bottom: 3rem;
  }

  .pl-hero__copy {
    max-width: 820px;
  }

  .pl-hero__eyebrow {
    margin: 0 0 1rem;
    color: #ffc300;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pl-hero h1 {
    max-width: 800px;
    margin: 0 0 1rem;
    color: #ffffff;
    font-size: 5.6rem;
    line-height: 0.92;
    letter-spacing: 0;
  }

  .pl-hero__lead {
    max-width: 650px;
    margin-bottom: 1.6rem;
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1.08rem, 2vw, 1.42rem);
    line-height: 1.5;
  }

  .pl-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .pl-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 46px;
    padding: 0.9rem 1.15rem;
    border-radius: 999px;
    font-weight: 900;
    text-decoration: none;
  }

  .pl-button--primary {
    color: #ffffff;
    background: var(--color-accent);
    box-shadow: 0 14px 34px rgba(255, 89, 0, 0.3);
  }

  .pl-button--ghost {
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.38);
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
  }

  .pl-button:hover {
    color: #ffffff;
    transform: translateY(-1px);
    text-decoration: none;
  }

  .pl-hero__panel {
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 8px;
    padding: 1rem;
    background: rgba(16, 20, 25, 0.42);
    backdrop-filter: blur(16px);
  }

  .pl-hero__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .pl-hero__stats div {
    min-width: 0;
    padding: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 8px;
  }

  .pl-hero__stats strong,
  .pl-hero__stats span {
    display: block;
  }

  .pl-hero__stats strong {
    color: #ffffff;
    font-family: var(--font-display);
    font-size: 1.8rem;
    line-height: 1;
  }

  .pl-hero__stats span {
    margin-top: 0.35rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.72rem;
    line-height: 1.25;
  }

  .pl-hero__towns {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.8rem;
  }

  .pl-hero__towns span {
    padding: 0.38rem 0.55rem;
    border-radius: 999px;
    color: #101419;
    background: rgba(255, 255, 255, 0.82);
    font-size: 0.72rem;
    font-weight: 900;
  }

  @media (max-width: 900px) {
    .pl-hero {
      min-height: 64svh;
    }

    .pl-hero__content {
      grid-template-columns: 1fr;
      padding-top: 6.5rem;
      padding-bottom: 2.2rem;
    }

    .pl-hero__panel {
      max-width: 520px;
    }

    .pl-hero__film {
      right: 1rem;
      bottom: auto;
      top: 6rem;
      grid-template-columns: repeat(4, 2.4rem);
    }
  }

  @media (max-width: 580px) {
    .pl-hero {
      min-height: 61svh;
    }

    .pl-hero__content {
      padding-left: 1rem;
      padding-right: 1rem;
      padding-top: 5.5rem;
      padding-bottom: 1.4rem;
    }

    .pl-hero h1 {
      font-size: 3.1rem;
      line-height: 0.98;
    }

    .pl-hero__lead {
      margin-bottom: 1rem;
      font-size: 1rem;
    }

    .pl-hero__actions {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.55rem;
    }

    .pl-button {
      min-height: 42px;
      padding: 0.72rem 1rem;
    }

    .pl-hero__film,
    .pl-hero__panel {
      display: none;
    }
  }
</style>
