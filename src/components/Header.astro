---
import { navigation, socialLinks, site } from '../data/site'
const headerSocials = socialLinks.filter((item) =>
  ['Instagram', 'Facebook'].includes(item.label)
)
const hasDropdown = (item: (typeof navigation)[number]) =>
  Array.isArray(item.dropdownSections) && item.dropdownSections.length > 0
const getMobilePanelId = (label: string) =>
  `mobile-section-${label.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`
---

<header class="header" id="header">
  <!-- Mobile: logo outside pill, centered -->
  <a class="logo mobile-logo" href="/" aria-label={`${site.name} home`}>
    <img class="logo__mark logo__mark--day" src="/brand/logo-dark.svg" alt={site.name} width="267" height="63" />
    <img class="logo__mark logo__mark--night" src="/brand/logo-light.svg" alt="" aria-hidden="true" width="267" height="63" />
  </a>

  <div class="header__pill">
    <div class="header__inner">
      <!-- Desktop: logo inside pill, left -->
      <a class="logo desktop-logo" href="/" aria-label={`${site.name} home`}>
        <img class="logo__mark logo__mark--day" src="/brand/logo-dark.svg" alt={site.name} width="267" height="63" />
        <img class="logo__mark logo__mark--night" src="/brand/logo-light.svg" alt="" aria-hidden="true" width="267" height="63" />
      </a>

      <nav class="nav">
        {navigation.map((item) => (
          hasDropdown(item) ? (
            <div class="nav__dropdown">
              {item.href ? (
                <a class="nav__link" href={item.href} aria-haspopup="true">
                  <i class={`fa-solid ${item.icon}`}></i>
                  {item.label}
                  <i class="fa-solid fa-chevron-down nav__chevron"></i>
                </a>
              ) : (
                <button class="nav__link nav__link--button" type="button" aria-haspopup="true">
                  <i class={`fa-solid ${item.icon}`}></i>
                  {item.label}
                  <i class="fa-solid fa-chevron-down nav__chevron"></i>
                </button>
              )}
              <div class="dropdown">
                {item.dropdownSections?.map((section, sectionIndex) => (
                  <Fragment>
                    {sectionIndex > 0 && <div class="dropdown__divider"></div>}
                    <div class="dropdown__section">
                      <span class="dropdown__heading">{section.heading}</span>
                      {section.items.map((link) => (
                        <a class="dropdown__item" href={link.href}>
                          <i class={`fa-solid ${link.icon}`}></i>
                          <span>{link.label}</span>
                        </a>
                      ))}
                    </div>
                  </Fragment>
                ))}
              </div>
            </div>
          ) : (
            <a class="nav__link" href={item.href || '#'}>
              <i class={`fa-solid ${item.icon}`}></i>
              {item.label}
            </a>
          )
        ))}
      </nav>

      <div class="header__actions">
        <div class="header__social">
          {headerSocials.map((item) => (
            <a class="header__social-link" href={item.href} target="_blank" rel="noreferrer" aria-label={item.label}>
              {item.label === 'Instagram' && <i class="fa-brands fa-instagram"></i>}
              {item.label === 'Facebook' && <i class="fa-brands fa-facebook"></i>}
            </a>
          ))}
        </div>
        <span class="header__divider"></span>
        <a class="cta-btn" href="/contact">Contact</a>
        <span class="header__divider"></span>
        <label class="theme-switch" aria-label="Toggle theme">
          <input class="theme-switch__input" type="checkbox" />
          <span class="theme-switch__track">
            <span class="theme-switch__thumb"></span>
          </span>
          <span class="theme-switch__icon" aria-hidden="true">
            <i class="fa-solid fa-sun"></i>
            <i class="fa-solid fa-moon"></i>
          </span>
        </label>
      </div>
    </div>
  </div>

  <!-- Mobile: hamburger -->
  <button class="menu-toggle" type="button" aria-label="Open menu" aria-expanded="false">
    <i class="fa-solid fa-list"></i>
    <i class="fa-solid fa-xmark"></i>
  </button>

  <!-- Full-screen mobile menu -->
  <div class="mobile-panel" role="dialog" aria-modal="true" aria-hidden="true">
    <button class="mobile-panel__close" type="button" aria-label="Close menu">
      <i class="fa-solid fa-xmark"></i>
    </button>
    <a class="mobile-panel__brand" href="/" aria-label={`${site.name} home`}>
      <span class="mobile-panel__brand-mark" aria-hidden="true"></span>
    </a>

    <div class="mobile-panel__links">
      <a class="mobile-panel__link" href="/">
        <i class="fa-solid fa-house"></i> Home
      </a>
      {navigation.map((item) => (
        hasDropdown(item) ? (
          <div class="mobile-panel__accordion" data-mobile-accordion>
            <button
              class="mobile-panel__accordion-toggle"
              type="button"
              aria-expanded="false"
              aria-controls={getMobilePanelId(item.label)}
              data-mobile-accordion-toggle
            >
              <span class="mobile-panel__accordion-label">
                <i class={`fa-solid ${item.icon}`}></i>
                <span>{item.label}</span>
              </span>
              <i class="fa-solid fa-chevron-down mobile-panel__accordion-chevron" aria-hidden="true"></i>
            </button>
            <div class="mobile-panel__accordion-body" id={getMobilePanelId(item.label)} hidden>
              <div class="mobile-panel__sublinks">
                {item.href && (
                  <a class="mobile-panel__sublink mobile-panel__sublink--overview" href={item.href}>
                    <i class="fa-solid fa-arrow-right"></i> {item.label} overview
                  </a>
                )}
              {item.dropdownSections?.map((section) => (
                <Fragment>
                  <span class="mobile-panel__subheading">{section.heading}</span>
                  {section.items.map((link) => (
                    <a class="mobile-panel__sublink" href={link.href}>
                      <i class={`fa-solid ${link.icon}`}></i> {link.label}
                    </a>
                  ))}
                </Fragment>
              ))}
              </div>
            </div>
          </div>
        ) : (
          <a class="mobile-panel__link" href={item.href || '#'}>
            <i class={`fa-solid ${item.icon}`}></i> {item.label}
          </a>
        )
      ))}
    </div>

    <div class="mobile-panel__divider"></div>

    <div class="mobile-panel__theme-row">
      <label class="theme-switch" aria-label="Toggle theme">
        <input class="theme-switch__input" type="checkbox" />
        <span class="theme-switch__track">
          <span class="theme-switch__thumb"></span>
        </span>
        <span class="theme-switch__icon" aria-hidden="true">
          <i class="fa-solid fa-sun"></i>
          <i class="fa-solid fa-moon"></i>
        </span>
      </label>
    </div>

    <div class="mobile-panel__bottom">
      <div class="mobile-panel__social">
        {socialLinks.filter(s => s.label !== 'Email').map((item) => (
          <a href={item.href} target="_blank" rel="noreferrer" aria-label={item.label}>
            {item.label === 'Instagram' && <i class="fa-brands fa-instagram"></i>}
            {item.label === 'Facebook' && <i class="fa-brands fa-facebook"></i>}
            {item.label === 'Twitter' && <i class="fa-brands fa-x-twitter"></i>}
          </a>
        ))}
      </div>
      <a class="mobile-panel__whatsapp" href="/contact">
        <i class="fa-brands fa-whatsapp"></i> WhatsApp
      </a>
    </div>
  </div>
</header>

<script is:inline>
  ;(() => {
    const root = document.documentElement
    const header = document.getElementById('header')
    const themeToggles = Array.from(document.querySelectorAll('.theme-switch__input'))
    const menuToggle = document.querySelector('.menu-toggle')
    const mobilePanel = document.querySelector('.mobile-panel')
    const desktopLogo = document.querySelector('.desktop-logo')
    const scrim = document.getElementById('topScrim')

    /* ── Responsive logo visibility ── */
    const mq = window.matchMedia('(min-width:901px)')
    const syncLogo = () => {
      if (desktopLogo) desktopLogo.style.display = mq.matches ? 'inline-flex' : 'none'
      const mobileLogo = header?.querySelector(':scope > .mobile-logo')
      if (mobileLogo) mobileLogo.style.display = mq.matches ? 'none' : 'inline-flex'
    }
    syncLogo()
    mq.addEventListener('change', syncLogo)

    /* ── Theme ── */
    const getStoredTheme = () => {
      try { return localStorage.getItem('theme') } catch { return null }
    }

    const getSystemTheme = () =>
      window.matchMedia?.('(prefers-color-scheme:dark)').matches ? 'night' : 'day'

    const syncSwitch = (value) =>
      themeToggles.forEach((t) => { t.checked = value === 'night' })

    const setTheme = (value, { persist = false } = {}) => {
      root.dataset.theme = value
      if (persist) try { localStorage.setItem('theme', value) } catch {}
      syncSwitch(value)
    }

    const storedTheme = getStoredTheme()
    const hasStoredTheme = storedTheme === 'day' || storedTheme === 'night'
    const initialTheme = hasStoredTheme ? storedTheme : root.dataset.theme || getSystemTheme()
    let allowSystemSync = !hasStoredTheme

    setTheme(initialTheme, { persist: hasStoredTheme })

    if (window.matchMedia) {
      const media = window.matchMedia('(prefers-color-scheme: dark)')
      const onSystemChange = (event) => {
        if (!allowSystemSync) return
        setTheme(event.matches ? 'night' : 'day')
      }
      if (media.addEventListener) media.addEventListener('change', onSystemChange)
      else if (media.addListener) media.addListener(onSystemChange)
    }

    themeToggles.forEach((toggle) => {
      toggle.addEventListener('change', () => {
        allowSystemSync = false
        setTheme(toggle.checked ? 'night' : 'day', { persist: true })
      })
    })

    /* ── Mobile menu ── */
    menuToggle?.addEventListener('click', () => {
      const isOpen = header?.classList.toggle('menu-open')
      menuToggle.setAttribute('aria-expanded', String(isOpen))
      mobilePanel?.setAttribute('aria-hidden', String(!isOpen))
      document.body.style.overflow = isOpen ? 'hidden' : ''
    })

    const closeMenu = () => {
      header?.classList.remove('menu-open')
      menuToggle?.setAttribute('aria-expanded', 'false')
      mobilePanel?.setAttribute('aria-hidden', 'true')
      document.body.style.overflow = ''
      document.querySelectorAll('[data-mobile-accordion-toggle]').forEach((toggle) => {
        toggle.setAttribute('aria-expanded', 'false')
      })
      document.querySelectorAll('.mobile-panel__accordion-body').forEach((panel) => {
        panel.hidden = true
      })
    }

    document.querySelector('.mobile-panel__close')?.addEventListener('click', closeMenu)

    document.querySelectorAll('[data-mobile-accordion-toggle]').forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const panelId = toggle.getAttribute('aria-controls')
        const panel = panelId ? document.getElementById(panelId) : null
        const isExpanded = toggle.getAttribute('aria-expanded') === 'true'

        toggle.setAttribute('aria-expanded', String(!isExpanded))
        if (panel) panel.hidden = isExpanded
      })
    })

    document.querySelectorAll('.mobile-panel__link, .mobile-panel__sublink').forEach((link) => {
      link.addEventListener('click', closeMenu)
    })

    /* ── Scroll + on-hero + scrim ── */
    /* Hero element lives inside <main><slot/></main> which is parsed AFTER
       this inline script.  We must wait for the full DOM before querying it. */
    const initHero = () => {
      const heroEl = document.querySelector('.hero--orange, .hero--dark, .hero--azure')

      const onScroll = () => {
        const scrolled = window.scrollY > 12
        header?.classList.toggle('is-scrolled', scrolled)
        if (heroEl) {
          const heroBottom = heroEl.getBoundingClientRect().bottom
          const onHero = !scrolled && heroBottom > 80
          header?.classList.toggle('on-hero', onHero)
          if (scrim) scrim.classList.toggle('visible', onHero)
        } else {
          header?.classList.remove('on-hero')
          if (scrim) scrim.classList.remove('visible')
        }
      }

      window.addEventListener('scroll', onScroll, { passive: true })
      onScroll()
      /* Mark header as JS-initialised so CSS :not(.on-hero) rule only applies
         after the class has had a chance to be set */
      header?.setAttribute('data-ready', '')
    }

    /* If DOM is already complete (e.g. deferred execution), run immediately;
       otherwise wait for DOMContentLoaded */
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHero)
    } else {
      initHero()
    }
  })()
</script>

<style>
  /* ═══════════════════════════════════════════
     HEADER — Logo-First Pill (Concept A)
     ═══════════════════════════════════════════ */

  .header {
    position: fixed;
    top: clamp(10px, 2vw, 18px);
    left: 0;
    right: 0;
    z-index: 20;
    pointer-events: none;
    color: var(--color-text);
  }

  /* ─── Pill shell ─── */
  .header__pill {
    pointer-events: auto;
    width: min(var(--container-max), calc(100% - 32px));
    margin: 0 auto;
    border-radius: 999px;
    border: 1px solid transparent;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    transition: background 0.25s, border-color 0.25s, box-shadow 0.25s, backdrop-filter 0.25s;
  }

  /* Show pill background only after JS init (data-ready) — prevents flash on hero pages */
  .header[data-ready].is-scrolled .header__pill,
  .header[data-ready]:not(.on-hero) .header__pill {
    background: var(--color-nav-bg);
    border-color: var(--color-nav-border);
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.6rem;
    transition: padding 0.25s;
  }

  .header.is-scrolled .header__inner {
    padding: 0.55rem 1.4rem;
  }

  /* ─── Logo ─── */
  .logo {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .logo__mark {
    height: 44px;
    width: auto;
    display: block;
    transition: transform 0.2s;
  }

  .header.is-scrolled .logo__mark {
    transform: scale(0.9);
  }

  .logo__mark--night {
    display: none;
  }

  :global([data-theme='night']) .logo__mark--day {
    display: none;
  }

  :global([data-theme='night']) .logo__mark--night {
    display: block;
  }

  /* Mobile logo: hidden by default, shown by JS + media query */
  .mobile-logo {
    display: none;
    pointer-events: auto;
  }

  /* Desktop logo: shown by JS on >=901 */
  .desktop-logo {
    display: none;
  }

  /* ─── Nav ─── */
  .nav {
    display: flex;
    gap: 1.4rem;
    align-items: center;
  }

  .nav__link {
    font-weight: 500;
    font-size: 0.95rem;
    color: currentColor;
    text-decoration: none;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .nav__link i {
    font-size: 1rem;
  }

  .nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -5px;
    width: 0;
    height: 2px;
    background: var(--gradient-sunset);
    transition: width 0.2s;
  }

  .nav__link:hover::after {
    width: 100%;
  }

  .nav__link:hover {
    text-decoration: none;
  }

  .nav__link--button {
    padding: 0;
    border: 0;
    background: transparent;
    font: inherit;
    cursor: pointer;
  }

  /* ─── Actions (right side) ─── */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  /* ─── Desktop social icons ─── */
  .header__social {
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  .header__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    color: currentColor;
    opacity: 0.7;
    font-size: 0.95rem;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.15s;
    position: relative;
  }

  .header__social-link:hover {
    opacity: 1;
    transform: translateY(-1px);
  }

  .header__social-link::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: currentColor;
    opacity: 0;
    transition: opacity 0.15s;
  }

  .header__social-link:hover::after {
    opacity: 0.06;
  }

  .header__social-link i {
    position: relative;
    z-index: 1;
  }

  /* ─── Dividers ─── */
  .header__divider {
    width: 1px;
    height: 18px;
    background: var(--color-border);
    margin: 0 0.4rem;
  }

  /* ─── CTA button ─── */
  .cta-btn {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.45rem 1.1rem;
    border-radius: 999px;
    cursor: pointer;
    border: 1.5px solid var(--color-accent);
    color: var(--color-accent);
    background: transparent;
    transition: background 0.2s, color 0.2s, transform 0.15s;
    white-space: nowrap;
    text-decoration: none;
  }

  .cta-btn:hover {
    background: var(--color-accent);
    color: #fff;
    transform: translateY(-1px);
  }

  /* ─── Theme toggle ─── */
  .theme-switch {
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    position: relative;
  }

  .theme-switch__input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .theme-switch__track {
    width: 42px;
    height: 21px;
    border-radius: 999px;
    background: #1b1f27;
    display: inline-flex;
    align-items: center;
    padding: 2px;
    position: relative;
    z-index: 0;
    transition: background 0.2s;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
  }

  :global([data-theme='night']) .theme-switch__track {
    background: #171c26;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
  }

  .theme-switch__thumb {
    width: 17px;
    height: 17px;
    border-radius: 50%;
    background: #fff;
    display: block;
    transform: translateX(0);
    transition: transform 0.18s;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
    position: relative;
    z-index: 2;
  }

  .theme-switch__input:checked + .theme-switch__track .theme-switch__thumb {
    transform: translateX(21px);
  }

  :global([data-theme='night']) .theme-switch__thumb {
    transform: translateX(21px);
  }

  .theme-switch__icon {
    position: absolute;
    left: 0;
    top: 0;
    width: 42px;
    height: 21px;
    pointer-events: none;
    color: #fff;
    z-index: 1;
  }

  .theme-switch__icon i {
    position: absolute;
    font-size: 0.68rem;
    transition: opacity 0.2s, transform 0.2s;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  .theme-switch__icon .fa-sun {
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
  }

  .theme-switch__icon .fa-moon {
    left: 6px;
    top: 50%;
    transform: translateY(-50%) scale(0.8);
    opacity: 0;
  }

  :global([data-theme='night']) .theme-switch__icon .fa-sun {
    opacity: 0;
    transform: translateY(-50%) scale(0.8);
  }

  :global([data-theme='night']) .theme-switch__icon .fa-moon {
    opacity: 1;
    transform: translateY(-50%) scale(1);
  }

  /* ─── Hamburger ─── */
  .menu-toggle {
    display: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(15, 17, 21, 0.12);
    background: #fff;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #15171d;
    font-size: 1.32rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.18s cubic-bezier(0.2, 0.8, 0.2, 1), background 0.2s, border-color 0.2s, color 0.2s;
    pointer-events: auto;
    box-shadow: none;
  }

  :global([data-theme='night']) .menu-toggle {
    background: #05070a;
    border-color: rgba(255, 255, 255, 0.14);
    color: #fff;
  }

  .header.menu-open > .menu-toggle {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.86) rotate(-12deg);
  }

  .menu-toggle:active {
    transform: scale(0.94);
  }

  .menu-toggle i {
    position: absolute;
    left: 50%;
    top: 50%;
    line-height: 1;
    transform: translate(-50%, -50%) rotate(0deg) scale(1);
    transition: opacity 0.2s ease, transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .menu-toggle .fa-xmark {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg) scale(0.58);
  }

  .header.menu-open .menu-toggle .fa-list {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(-90deg) scale(0.58);
  }

  .header.menu-open .menu-toggle .fa-xmark {
    opacity: 1;
    transform: translate(-50%, -50%) rotate(0deg) scale(1);
  }

  /* ═══════════════════════════════════════════
     ON-HERO STATE (light theme only)
     White navbar content over dark/gradient heroes
     ═══════════════════════════════════════════ */

  :global(:root:not([data-theme='night'])) .header.on-hero:not(.is-scrolled) {
    color: #fff;
  }

  :global(:root:not([data-theme='night'])) .header.on-hero:not(.is-scrolled) .logo__mark--day {
    display: none;
  }

  :global(:root:not([data-theme='night'])) .header.on-hero:not(.is-scrolled) .logo__mark--night {
    display: block;
  }

  :global(:root:not([data-theme='night'])) .header.on-hero:not(.is-scrolled) .logo__mark {
    filter: drop-shadow(0 6px 18px rgba(0, 0, 0, 0.35));
  }

  :global(:root:not([data-theme='night'])) .header.on-hero:not(.is-scrolled) .nav__link::after {
    background: rgba(255, 255, 255, 0.95);
  }

  :global(:root:not([data-theme='night'])) .header.on-hero:not(.is-scrolled) .cta-btn {
    border-color: rgba(255, 255, 255, 0.85);
    color: #fff;
  }

  :global(:root:not([data-theme='night'])) .header.on-hero:not(.is-scrolled) .cta-btn:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: #fff;
  }

  :global(:root:not([data-theme='night'])) .header.on-hero:not(.is-scrolled) .theme-switch__track {
    background: rgba(255, 255, 255, 0.22);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.18);
  }

  :global(:root:not([data-theme='night'])) .header.on-hero:not(.is-scrolled) .header__social-link {
    color: #fff;
    opacity: 0.85;
  }

  :global(:root:not([data-theme='night'])) .header.on-hero:not(.is-scrolled) .header__social-link:hover {
    opacity: 1;
  }

  :global(:root:not([data-theme='night'])) .header.on-hero:not(.is-scrolled) .header__divider {
    background: rgba(255, 255, 255, 0.3);
  }

  :global(:root:not([data-theme='night'])) .header.on-hero:not(.is-scrolled) .menu-toggle {
    background: #fff;
