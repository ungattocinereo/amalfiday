---
export interface Props {
  calendarName: string
  airbnb?: string
  booking?: string
}

const { calendarName, airbnb, booking } = Astro.props
---

<div class="avail" data-calendar data-calendar-name={calendarName}>
  <div class="avail__heading">
    <span class="avail__eyebrow">Availability</span>
    <span class="avail__range">through 30 November 2026</span>
  </div>
  <div class="avail__chips" data-avail-chips aria-label="Jump to month"></div>
  <div class="avail__viewport">
    <button
      class="avail__nav avail__nav--prev"
      type="button"
      data-avail-prev
      aria-label="Previous month"
    >
      <i class="fa-solid fa-chevron-left"></i>
    </button>
    <div class="avail__track" data-avail-track>
      <div class="avail__skeleton"></div>
      <div class="avail__skeleton"></div>
    </div>
    <button
      class="avail__nav avail__nav--next"
      type="button"
      data-avail-next
      aria-label="Next month"
    >
      <i class="fa-solid fa-chevron-right"></i>
    </button>
  </div>
  <div class="avail__legend">
    <span class="avail__legend-item"><span class="avail__sw avail__sw--free"></span>Available</span>
    <span class="avail__legend-item"><span class="avail__sw avail__sw--busy"></span>Booked</span>
  </div>
  {(airbnb || booking) && (
    <div class="avail__actions">
      {airbnb && (
        <a class="avail__btn avail__btn--airbnb" href={airbnb} target="_blank" rel="noopener noreferrer">
          Book on Airbnb
        </a>
      )}
      {booking && (
        <a class="avail__btn avail__btn--booking" href={booking} target="_blank" rel="noopener noreferrer">
          Book on Booking.com
        </a>
      )}
    </div>
  )}
</div>

<script is:inline>
  ;(function () {
    if (window.__availabilityBooted) return
    window.__availabilityBooted = true

    const END_YEAR = 2026
    const END_MONTH = 10 // November (0-indexed)

    const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']
    const monthFull = ['January','February','March','April','May','June','July','August','September','October','November','December']
    const dayLabels = ['Mo','Tu','We','Th','Fr','Sa','Su']

    const formatDate = (d) => {
      const y = d.getFullYear()
      const m = `${d.getMonth() + 1}`.padStart(2, '0')
      const day = `${d.getDate()}`.padStart(2, '0')
      return `${y}-${m}-${day}`
    }

    const isToday = (date, today) =>
      date.getFullYear() === today.getFullYear() &&
      date.getMonth() === today.getMonth() &&
      date.getDate() === today.getDate()

    const monthsInRange = () => {
      const today = new Date()
      const months = []
      for (let i = 0; ; i++) {
        const d = new Date(today.getFullYear(), today.getMonth() + i, 1)
        if (d.getFullYear() > END_YEAR || (d.getFullYear() === END_YEAR && d.getMonth() > END_MONTH)) break
        months.push({ year: d.getFullYear(), month: d.getMonth() })
        if (i > 24) break
      }
      return months
    }

    const renderMonth = (year, month, busy, today, index) => {
      const firstDay = new Date(year, month, 1)
      const offset = (firstDay.getDay() + 6) % 7
      const daysInMonth = new Date(year, month + 1, 0).getDate()
      const cells = []

      for (let i = 0; i < offset; i++) {
        cells.push('<span class="avail__cell avail__cell--empty" aria-hidden="true"></span>')
      }

      for (let day = 1; day <= daysInMonth; day++) {
        const date = new Date(year, month, day)
        const key = formatDate(date)
        const isBusy = busy.has(key)
        const isPast = date < today && !isToday(date, today)
        const isTodayDate = isToday(date, today)
        const classes = ['avail__cell']
        classes.push(isBusy ? 'avail__cell--busy' : 'avail__cell--free')
        if (isPast) classes.push('avail__cell--past')
        if (isTodayDate) classes.push('avail__cell--today')
        const label = `${day} ${monthFull[month]} ${year} — ${isBusy ? 'booked' : 'available'}`
        cells.push(`<span class="${classes.join(' ')}" aria-label="${label}" role="gridcell">${day}</span>`)
      }

      return `
        <div class="avail__month" data-month-index="${index}" data-month-key="${year}-${month}">
          <div class="avail__month-head">
            <span class="avail__month-name">${monthFull[month]}</span>
            <span class="avail__month-year">${year}</span>
          </div>
          <div class="avail__dow" aria-hidden="true">
            ${dayLabels.map((l) => `<span>${l}</span>`).join('')}
          </div>
          <div class="avail__days" role="grid">${cells.join('')}</div>
        </div>`
    }

    const renderChips = (el, months) => {
      el.innerHTML = months
        .map((m, i) => {
          return `<button type="button" class="avail__chip${i === 0 ? ' avail__chip--active' : ''}" data-chip-index="${i}">
            <span class="avail__chip-mon">${monthShort[m.month]}</span>
            <span class="avail__chip-yr">${String(m.year).slice(2)}</span>
          </button>`
        })
        .join('')
    }

    const setupInteractions = (root, months) => {
      const track = root.querySelector('[data-avail-track]')
      const prevBtn = root.querySelector('[data-avail-prev]')
      const nextBtn = root.querySelector('[data-avail-next]')
      const chipEls = Array.from(root.querySelectorAll('.avail__chip'))
      const monthEls = Array.from(track.querySelectorAll('.avail__month'))

      const getMonthStep = () => {
        if (monthEls.length < 2) return monthEls[0]?.offsetWidth || 0
        return monthEls[1].offsetLeft - monthEls[0].offsetLeft
      }

      const scrollToIndex = (index) => {
        const clamped = Math.max(0, Math.min(index, monthEls.length - 1))
        const target = monthEls[clamped]
        if (!target) return
        track.scrollTo({ left: target.offsetLeft, behavior: 'smooth' })
      }

      const getActiveIndex = () => {
        const step = getMonthStep()
        if (step <= 0) return 0
        return Math.max(0, Math.min(monthEls.length - 1, Math.round(track.scrollLeft / step)))
      }

      const updateState = () => {
        const active = getActiveIndex()
        chipEls.forEach((c, i) => c.classList.toggle('avail__chip--active', i === active))

        const atStart = track.scrollLeft < 4
        const atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 4
        prevBtn.disabled = atStart
        nextBtn.disabled = atEnd
      }

      track.addEventListener('scroll', updateState, { passive: true })
      window.addEventListener('resize', updateState)
      updateState()

      prevBtn.addEventListener('click', () => scrollToIndex(getActiveIndex() - 1))
      nextBtn.addEventListener('click', () => scrollToIndex(getActiveIndex() + 1))

      chipEls.forEach((chip) => {
        chip.addEventListener('click', () => {
          const idx = Number(chip.dataset.chipIndex)
          scrollToIndex(idx)
        })
      })
    }

    const renderCalendar = (root, busy) => {
      const chipsEl = root.querySelector('[data-avail-chips]')
      const trackEl = root.querySelector('[data-avail-track]')
      const today = new Date()
      const months = monthsInRange()

      renderChips(chipsEl, months)
      trackEl.innerHTML = months
        .map((m, i) => renderMonth(m.year, m.month, busy, today, i))
        .join('')

      setupInteractions(root, months)
    }

    const renderStatus = (root, message) => {
      const trackEl = root.querySelector('[data-avail-track]')
      const chipsEl = root.querySelector('[data-avail-chips]')
      const prevBtn = root.querySelector('[data-avail-prev]')
      const nextBtn = root.querySelector('[data-avail-next]')
      if (chipsEl) chipsEl.innerHTML = ''
      if (prevBtn) prevBtn.style.display = 'none'
      if (nextBtn) nextBtn.style.display = 'none'
      if (trackEl) trackEl.innerHTML = `<p class="avail__status">${message}</p>`
    }

    const bootCalendar = (root, availability) => {
      const name = root.dataset.calendarName
      if (!name) return
      if (!availability || !availability.calendars) {
        renderStatus(root, 'Availability is updating — please check back shortly.')
        return
      }
      if (!(name in availability.calendars)) {
        renderStatus(root, 'Calendar coming soon.')
        return
      }
      const busy = new Set(availability.calendars[name] || [])
      renderCalendar(root, busy)
    }

    document.addEventListener('DOMContentLoaded', () => {
      const roots = Array.from(document.querySelectorAll('[data-calendar]'))
      if (!roots.length) return

      if (!window.__availabilityPromise) {
        window.__availabilityPromise = fetch('/api/availability', { cache: 'no-store' })
          .then((res) => (res.ok ? res.json() : null))
          .catch(() => null)
          .then((data) => {
            if (data) return data
            return fetch('/calendars/availability.json', { cache: 'no-store' })
              .then((r) => (r.ok ? r.json() : null))
              .catch(() => null)
          })
      }

      window.__availabilityPromise.then((data) => {
        roots.forEach((root) => bootCalendar(root, data))
      })
    })
  })()
</script>

<style is:global>
  .avail {
    container-type: inline-size;
    container-name: avail;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 0.75rem 0 0;
    border: none;
    background: transparent;
  }

  .avail__heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .avail__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .avail__range {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .avail__chips {
    display: flex;
    gap: 2px;
    padding: 4px;
    background: rgba(0, 0, 0, 0.035);
    border-radius: var(--radius-sm);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .avail__chips::-webkit-scrollbar {
    display: none;
  }

  .avail__chip {
    flex: 1 1 0;
    min-width: 58px;
    padding: 6px 8px;
    border: none;
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    display: inline-flex;
    align-items: baseline;
    justify-content: center;
    gap: 4px;
    color: var(--color-text-muted);
    transition: background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
  }

  .avail__chip:hover {
    color: var(--color-text);
    background: rgba(0, 0, 0, 0.05);
  }

  .avail__chip--active {
    background: var(--color-card);
    color: var(--color-text);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08), 0 1px 3px rgba(0, 0, 0, 0.04);
  }

  .avail__chip--active:hover {
    background: var(--color-card);
  }

  .avail__chip-mon {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .avail__chip-yr {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    opacity: 0.65;
  }

  .avail__chip--active .avail__chip-yr {
    opacity: 0.75;
  }

  /* Viewport with arrow buttons */
  .avail__viewport {
    position: relative;
  }

  .avail__track {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding: 0;
  }

  .avail__track::-webkit-scrollbar {
    display: none;
  }

  .avail__month {
    flex: 0 0 calc(50% - 0.625rem);
    scroll-snap-align: start;
    min-width: 0;
  }

  .avail__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-card);
    color: var(--color-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 0.7rem;
    box-shadow: var(--shadow-soft);
    transition: opacity 0.2s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .avail__nav:hover:not(:disabled) {
    background: var(--color-surface);
    border-color: var(--color-text);
  }

  .avail__nav:disabled {
    opacity: 0;
    pointer-events: none;
  }

  .avail__nav--prev {
    left: -14px;
  }

  .avail__nav--next {
    right: -14px;
  }

  .avail__month-head {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .avail__month-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.98rem;
    color: var(--color-text);
    line-height: 1;
  }

  .avail__month-year {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }

  .avail__dow,
  .avail__days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }

  .avail__dow {
    margin-bottom: 2px;
  }

  .avail__dow span {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-align: center;
    padding-bottom: 2px;
    opacity: 0.55;
  }

  /* ===== Airbnb-style cells ===== */
  .avail__cell {
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--color-text);
    background: transparent;
    border-radius: 4px;
    position: relative;
    transition: background 0.14s ease;
  }

  .avail__cell--empty {
    background: transparent;
  }

  /* Available: white / card background + dark number */
  .avail__cell--free {
    background: var(--color-card);
    color: var(--color-text);
    font-weight: 500;
  }

  .avail__cell--free:not(.avail__cell--past):hover {
    background: var(--color-surface);
  }

  /* Booked: no background, grey number, strikethrough */
  .avail__cell--busy {
    background: transparent;
    color: var(--color-text-muted);
    text-decoration: line-through;
    text-decoration-thickness: 1px;
    text-decoration-color: currentColor;
    opacity: 0.7;
  }

  .avail__cell--past {
    opacity: 0.28;
  }

  .avail__cell--today {
    outline: 1.5px solid var(--color-text);
    outline-offset: -1.5px;
    font-weight: 700;
  }

  .avail__legend {
    display: flex;
    gap: 1rem;
    padding: 0.65rem 0.9rem;
    background: rgba(0, 0, 0, 0.035);
    border-radius: var(--radius-sm);
  }

  .avail__legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .avail__sw {
    width: 16px;
    height: 16px;
    border-radius: 3px;
    display: inline-grid;
    place-items: center;
  }

  .avail__sw--free {
    background: var(--color-card);
    border: 1px solid var(--color-border);
  }

  .avail__sw--busy {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.5rem;
    text-decoration: line-through;
    text-decoration-thickness: 1px;
  }

  .avail__sw--busy::before {
    content: '12';
    opacity: 0.7;
  }

  .avail__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .avail__btn {
    flex: 1 1 auto;
    text-align: center;
    padding: 0.6rem 1rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease,
      border-color 0.2s ease, color 0.2s ease;
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .avail__btn--airbnb {
    background: var(--color-accent);
    color: #ffffff;
  }

  .avail__btn--airbnb:hover {
    background: #ff7a33;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(255, 89, 0, 0.28);
    color: #ffffff;
    text-decoration: none;
  }

  .avail__btn--booking {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-border);
  }

  .avail__btn--booking:hover {
    border-color: var(--color-text);
    background: var(--color-surface);
    color: var(--color-text);
    text-decoration: none;
  }

  .avail__status {
    grid-column: 1 / -1;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
    padding: 0.5rem 0;
  }

  .avail__skeleton {
    flex: 0 0 calc(50% - 0.625rem);
    height: 200px;
    border-radius: 10px;
    background: linear-gradient(
      90deg,
      var(--color-surface) 25%,
      var(--color-border) 50%,
      var(--color-surface) 75%
    );
    background-size: 200% 100%;
    animation: avail-shimmer 1.5s ease infinite;
  }

  @keyframes avail-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  [data-theme='night'] .avail__cell--free {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text);
  }

  [data-theme='night'] .avail__cell--free:not(.avail__cell--past):hover {
    background: rgba(255, 255, 255, 0.12);
  }

  [data-theme='night'] .avail__cell--busy {
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  [data-theme='night'] .avail__sw--free {
    background: rgba(255, 255, 255, 0.1);
  }

  [data-theme='night'] .avail__legend,
  [data-theme='night'] .avail__chips {
    background: rgba(255, 255, 255, 0.04);
  }

  [data-theme='night'] .avail__chip:hover {
    background: rgba(255, 255, 255, 0.06);
  }

  [data-theme='night'] .avail__chip--active,
  [data-theme='night'] .avail__chip--active:hover {
    background: var(--color-card);
  }

  [data-theme='night'] .avail__nav {
    background: var(--color-card);
  }

  [data-theme='night'] .avail__chip--active {
    background: var(--color-text);
    color: var(--color-bg);
  }

  /* Wide containers (e.g., Villa Susy featured card) — show 3 months */
  @container avail (min-width: 760px) {
    .avail__month {
      flex: 0 0 calc(33.333% - 0.833rem);
    }
    .avail__skeleton {
      flex: 0 0 calc(33.333% - 0.833rem);
    }
  }

  /* Narrow mobile: show 1 month at a time */
  @media (max-width: 640px) {
    .avail__month {
      flex: 0 0 100%;
    }
    .avail__skeleton {
      flex: 0 0 100%;
    }
    .avail__nav--prev {
      left: -4px;
    }
    .avail__nav--next {
      right: -4px;
    }
    .avail__cell {
      font-size: 0.82rem;
    }
  }
</style>
