---
import 'mapbox-gl/dist/mapbox-gl.css'
import CldImage from './CldImage.astro'
import {
  photoSpotDifficulties,
  photoSpotMapTypes,
  photoSpotTimeTags,
  type PhotoSpot,
} from '../data/photo-locations'

interface Props {
  spots: PhotoSpot[]
}

const { spots } = Astro.props as Props
const cities = Array.from(new Set(spots.map((spot) => spot.city))).sort((a, b) =>
  a.localeCompare(b),
)
const firstSpot = spots[0]
const spotPayload = spots.map((spot) => ({
  slug: spot.slug,
  title: spot.title,
  city: spot.city,
  mapType: spot.mapType,
  types: spot.types,
  timeTags: spot.timeTags,
  difficulty: spot.difficulty,
  cost: spot.cost,
  coordinates: spot.coordinates,
  isApproximate: Boolean(spot.isApproximate),
  mapsUrl: spot.mapsUrl,
  locationNote: spot.locationNote || '',
  description: spot.description,
  quotes: spot.quotes,
  bestTime: spot.bestTime,
  tips: spot.tips,
  image: spot.image,
}))
const spotJson = JSON.stringify(spotPayload).replace(/</g, '\\u003c')

const mapTypeIcons: Record<string, string> = {
  Beach: 'fa-umbrella-beach',
  Viewpoint: 'fa-camera-retro',
  Architecture: 'fa-landmark',
  'Hidden Gem': 'fa-key',
  Hike: 'fa-person-hiking',
  Sea: 'fa-sailboat',
}
const filterGroups = [
  { key: 'city', label: 'Town', values: cities },
  { key: 'type', label: 'Scene', values: photoSpotMapTypes },
  { key: 'time', label: 'Light', values: photoSpotTimeTags },
  { key: 'difficulty', label: 'Access', values: photoSpotDifficulties },
]
const getTypeIcon = (value: string) => mapTypeIcons[value] || ''
---

<section class="photo-map" id="photo-spots-map" data-photo-map>
  <script id="photo-spots-data" type="application/json" set:html={spotJson}></script>

  <div class="container photo-map__intro">
    <div>
      <p class="photo-map__eyebrow">Pinned field notes</p>
      <h2>Pick a place by light, mood, and walking effort.</h2>
    </div>
    <p>
      Browse the map, narrow the coast by town or scene, then open one concise field note
      instead of scrolling through every location at once.
    </p>
  </div>

  <div class="photo-map__workspace">
    <aside class="finder-panel" aria-label="Photo spot results">
      <button class="finder-panel__handle" type="button" data-toggle-results aria-expanded="false">
        <span aria-hidden="true"></span>
        <strong><span data-visible-count>{spots.length}</span> spots</strong>
      </button>

      <div class="finder-panel__top">
        <label class="finder-search">
          <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
          <span class="sr-only">Search photo spots</span>
          <input
            type="search"
            data-search-spots
            autocomplete="off"
            placeholder="Search spots or towns"
          />
        </label>
        <button class="mobile-filter-button" type="button" data-open-filters>
          <i class="fa-solid fa-sliders" aria-hidden="true"></i>
          Filters
        </button>
      </div>

      <div class="active-filters" data-active-filters hidden></div>

      <div class="filter-panel" data-desktop-filter-panel>
        {filterGroups.map((group) => (
          <div class={`filter-group filter-group--${group.key}`}>
            <div class="filter-group__label">{group.label}</div>
            <div class="filter-group__chips">
              {group.values.map((value) => (
                <button
                  class={`filter-chip ${group.key === 'type' ? 'filter-chip--icon' : ''}`}
                  type="button"
                  data-filter-group={group.key}
                  data-filter-value={value}
                  aria-pressed="false"
                >
                  {group.key === 'type' && <i class={`fa-solid ${getTypeIcon(value)}`} aria-hidden="true"></i>}
                  {value}
                </button>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="result-summary">
        <span><strong data-visible-count>{spots.length}</strong> matching spots</span>
        <button type="button" data-clear-filters>Clear</button>
      </div>

      <div class="photo-map__list" data-spot-list aria-live="polite">
        <p class="photo-map__empty" data-empty-state hidden>
          No spots match these filters. Clear one filter or search another town.
        </p>
        {spots.map((spot, index) => (
          <article
            class={`spot-card ${index === 0 ? 'is-selected' : ''}`}
            id={`spot-card-${spot.slug}`}
            data-spot-card
            data-spot-slug={spot.slug}
            data-search-text={`${spot.title} ${spot.city} ${spot.mapType} ${spot.types.join(' ')} ${spot.timeTags.join(' ')} ${spot.difficulty}`}
            aria-selected={index === 0 ? 'true' : 'false'}
          >
            <button
              class="spot-card__main"
              type="button"
              data-select-spot={spot.slug}
              aria-label={`Open details for ${spot.title}`}
            >
              <span class="spot-card__media">
                <CldImage
                  src={spot.image.src}
                  alt={spot.image.alt}
                  width={spot.image.width}
                  height={spot.image.height}
                  sizes="(max-width: 760px) 96px, 132px"
                />
              </span>
              <span class="spot-card__body">
                <span class="spot-card__topline">
                  <span class={`spot-type spot-type--${spot.mapType.toLowerCase().replace(/\s+/g, '-')}`}>
                    <i class={`fa-solid ${mapTypeIcons[spot.mapType]}`} aria-hidden="true"></i>
                    {spot.mapType}
                  </span>
                  <span class="spot-card__city">{spot.city}</span>
                </span>
                <span class="spot-card__title">{spot.title}</span>
                <span class="spot-card__meta">
                  <span><i class="fa-regular fa-clock" aria-hidden="true"></i>{spot.timeTags.join(' / ')}</span>
                  <span><i class="fa-solid fa-shoe-prints" aria-hidden="true"></i>{spot.difficulty}</span>
                </span>
              </span>
            </button>
            <div class="spot-card__actions">
              <button class="spot-save" type="button" data-save-spot={spot.slug} aria-pressed="false" aria-label={`Save ${spot.title}`}>
                <i class="fa-regular fa-bookmark" aria-hidden="true"></i>
                <span>Save</span>
              </button>
              <a href={spot.mapsUrl} target="_blank" rel="noreferrer">
                <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
                Maps
              </a>
            </div>
          </article>
        ))}
      </div>
    </aside>

    <div class="map-frame">
      <div class="photo-map__canvas" data-map-canvas></div>
      <div class="photo-map__fallback" data-map-fallback>
        <i class="fa-solid fa-map-location-dot" aria-hidden="true"></i>
        <p>Map preview is unavailable here. The list and Google Maps links still work.</p>
      </div>
      <div class="map-toolbar" aria-label="Map tools">
        <button class="map-action" type="button" data-fit-all>
          <i class="fa-solid fa-compress" aria-hidden="true"></i>
          All spots
        </button>
        <button class="map-action map-action--mobile" type="button" data-toggle-results aria-expanded="false">
          <i class="fa-solid fa-list" aria-hidden="true"></i>
          List
        </button>
      </div>
      <div class="photo-map__legend" aria-label="Map legend">
        {photoSpotMapTypes.map((type) => (
          <span class={`legend-chip legend-chip--${type.toLowerCase().replace(/\s+/g, '-')}`}>
            <i class={`fa-solid ${mapTypeIcons[type]}`} aria-hidden="true"></i>
            {type}
          </span>
        ))}
      </div>
    </div>

    <aside class="spot-detail" data-detail-panel aria-label="Selected photo spot">
      <button class="spot-detail__close" type="button" data-close-detail aria-label="Close selected spot">
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
      </button>
      {firstSpot && (
        <div data-detail-content>
          <div class="spot-detail__media">
            <CldImage
              src={firstSpot.image.src}
              alt={firstSpot.image.alt}
              width={firstSpot.image.width}
              height={firstSpot.image.height}
              sizes="(max-width: 760px) 100vw, 420px"
            />
          </div>
          <div class="spot-detail__body">
            <div class="spot-detail__kicker">
              <span>{firstSpot.city}</span>
              <span>{firstSpot.difficulty}</span>
            </div>
            <h3>{firstSpot.title}</h3>
            <div class="spot-detail__tags">
              {firstSpot.types.slice(0, 4).map((type) => <span class="spot-tag">{type}</span>)}
            </div>
            {firstSpot.description.map((paragraph) => <p>{paragraph}</p>)}
            <div class="spot-detail__facts">
              <div><strong>Best time</strong><span>{firstSpot.bestTime}</span></div>
              <div><strong>Cost</strong><span>{firstSpot.cost}</span></div>
              <div><strong>Access</strong><span>{firstSpot.difficulty}</span></div>
            </div>
            <div class="spot-detail__block">
              <h4>What people say</h4>
              {firstSpot.quotes.map((quote) => (
                <blockquote>
                  {quote.text}
                  {quote.source && <cite>{quote.source}</cite>}
                </blockquote>
              ))}
            </div>
            <div class="spot-detail__block">
              <h4>Photo tips</h4>
              <ul>
                {firstSpot.tips.map((tip) => <li>{tip}</li>)}
              </ul>
            </div>
            <div class="spot-detail__actions">
              <a class="spot-detail__map" href={firstSpot.mapsUrl} target="_blank" rel="noreferrer">
                <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
                Google Maps
              </a>
              <button class="spot-detail__save" type="button" data-save-spot={firstSpot.slug} aria-pressed="false">
                <i class="fa-regular fa-bookmark" aria-hidden="true"></i>
                <span>Save</span>
              </button>
              <a class="spot-detail__cta" href={`/contact?service=Photoshooting&spot=${encodeURIComponent(firstSpot.title)}&location=${encodeURIComponent(firstSpot.city)}`}>
                Book photographer
              </a>
            </div>
          </div>
        </div>
      )}
    </aside>
  </div>

  <div class="filter-drawer" data-filter-drawer aria-hidden="true">
    <div class="filter-drawer__scrim" data-close-filters></div>
    <div class="filter-drawer__sheet" role="dialog" aria-modal="true" aria-label="Photo spot filters">
      <div class="filter-drawer__header">
        <div>
          <span>Filters</span>
          <strong><span data-visible-count>{spots.length}</span> spots</strong>
        </div>
        <button type="button" data-close-filters aria-label="Close filters">
          <i class="fa-solid fa-xmark" aria-hidden="true"></i>
        </button>
      </div>
      <div class="filter-panel filter-panel--drawer">
        {filterGroups.map((group) => (
          <div class={`filter-group filter-group--${group.key}`}>
            <div class="filter-group__label">{group.label}</div>
            <div class="filter-group__chips">
              {group.values.map((value) => (
                <button
                  class={`filter-chip ${group.key === 'type' ? 'filter-chip--icon' : ''}`}
                  type="button"
                  data-filter-group={group.key}
                  data-filter-value={value}
                  aria-pressed="false"
                >
                  {group.key === 'type' && <i class={`fa-solid ${getTypeIcon(value)}`} aria-hidden="true"></i>}
                  {value}
                </button>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="filter-drawer__footer">
        <button type="button" data-clear-filters>Clear</button>
        <button type="button" data-close-filters>
          Show <span data-visible-count>{spots.length}</span> spots
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector('[data-photo-map]')
  const dataNode = document.getElementById('photo-spots-data')
  const spots = dataNode ? JSON.parse(dataNode.textContent || '[]') : []
  const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN || ''
  const filterButtons = Array.from(root?.querySelectorAll('[data-filter-group]') || [])
  const clearFiltersButtons = Array.from(root?.querySelectorAll('[data-clear-filters]') || [])
  const searchInput = root?.querySelector('[data-search-spots]')
  const cards = Array.from(root?.querySelectorAll('[data-spot-card]') || [])
  const visibleCounts = Array.from(root?.querySelectorAll('[data-visible-count]') || [])
  const activeFiltersNode = root?.querySelector('[data-active-filters]')
  const emptyState = root?.querySelector('[data-empty-state]')
  const mapCanvas = root?.querySelector('[data-map-canvas]')
  const mapFallback = root?.querySelector('[data-map-fallback]')
  const detailPanel = root?.querySelector('[data-detail-panel]')
  const detailContent = root?.querySelector('[data-detail-content]')
  const closeDetailButton = root?.querySelector('[data-close-detail]')
  const filterDrawer = root?.querySelector('[data-filter-drawer]')
  const openFiltersButton = root?.querySelector('[data-open-filters]')
  const closeFiltersButtons = Array.from(root?.querySelectorAll('[data-close-filters]') || [])
  const toggleResultsButtons = Array.from(root?.querySelectorAll('[data-toggle-results]') || [])
  const fitAllButton = root?.querySelector('[data-fit-all]')
  const saveKey = 'amalfi-photo-spots-saved'
  const compactQuery = window.matchMedia('(max-width: 760px)')
  const activeFilters = {
    city: new Set(),
    type: new Set(),
    time: new Set(),
    difficulty: new Set(),
  }
  const filterLabels = {
    city: 'Town',
    type: 'Scene',
    time: 'Light',
    difficulty: 'Access',
  }
  const mapColors = {
    Beach: '#009cff',
    Viewpoint: '#ff5900',
    Architecture: '#7a5cff',
    'Hidden Gem': '#00a676',
    Hike: '#855c34',
    Sea: '#0162ff',
  }
  let map
  let mapboxgl
  let query = ''

  const readHashSlug = () => {
    try {
      return decodeURIComponent(window.location.hash.replace(/^#/, ''))
    } catch (_error) {
      return window.location.hash.replace(/^#/, '')
    }
  }

  const hashSlug = readHashSlug()
  const hasSpotHash = spots.some((spot) => spot.slug === hashSlug)
  let selectedSlug = hasSpotHash ? hashSlug : spots[0]?.slug || ''

  const escapeHtml = (value) =>
    String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;')

  const normalize = (value) =>
    String(value || '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')

  const isCompact = () => compactQuery.matches

  const getSavedSpots = () => {
    try {
      const parsed = JSON.parse(localStorage.getItem(saveKey) || '[]')
      return Array.isArray(parsed) ? parsed : []
    } catch (_error) {
      return []
    }
  }

  const setSavedSpots = (saved) => {
    try {
      localStorage.setItem(saveKey, JSON.stringify(saved))
    } catch (_error) {
      // Local storage is optional.
    }
  }

  const updateSaveButtons = () => {
    const saved = new Set(getSavedSpots())
    root?.querySelectorAll('[data-save-spot]').forEach((button) => {
      const slug = button.dataset.saveSpot
      const isSaved = saved.has(slug)
      button.setAttribute('aria-pressed', String(isSaved))
      button.classList.toggle('is-saved', isSaved)
      const icon = button.querySelector('i')
      const label = button.querySelector('span')
      if (icon) icon.className = isSaved ? 'fa-solid fa-bookmark' : 'fa-regular fa-bookmark'
      if (label) label.textContent = isSaved ? 'Saved' : 'Save'
    })
  }

  const spotMatchesFilters = (spot) => {
    if (activeFilters.city.size && !activeFilters.city.has(spot.city)) return false
    if (activeFilters.type.size && !activeFilters.type.has(spot.mapType)) return false
    if (activeFilters.difficulty.size && !activeFilters.difficulty.has(spot.difficulty)) return false
    if (activeFilters.time.size && !spot.timeTags.some((time) => activeFilters.time.has(time))) return false
    if (query) {
      const haystack = normalize([
        spot.title,
        spot.city,
        spot.mapType,
        spot.difficulty,
        spot.bestTime,
        spot.types.join(' '),
        spot.timeTags.join(' '),
      ].join(' '))
      return haystack.includes(query)
    }
    return true
  }

  const getFilteredSpots = () => spots.filter(spotMatchesFilters)

  const toGeoJson = (items) => ({
    type: 'FeatureCollection',
    features: items.map((spot) => ({
      type: 'Feature',
      properties: {
        slug: spot.slug,
        title: spot.title,
        shortTitle: spot.title.replace(/^Villa\s+/i, '').slice(0, 22),
        city: spot.city,
        mapType: spot.mapType,
        color: mapColors[spot.mapType] || '#ff5900',
      },
      geometry: {
        type: 'Point',
        coordinates: [spot.coordinates.lng, spot.coordinates.lat],
      },
    })),
  })

  const colorMatchExpression = [
    'match',
    ['get', 'mapType'],
    'Beach',
    mapColors.Beach,
    'Viewpoint',
    mapColors.Viewpoint,
    'Architecture',
    mapColors.Architecture,
    'Hidden Gem',
    mapColors['Hidden Gem'],
    'Hike',
    mapColors.Hike,
    'Sea',
    mapColors.Sea,
    '#ff5900',
  ]

  const refreshSelectedLayer = () => {
    if (!map?.getLayer?.('unclustered-point')) return
    map.setPaintProperty('unclustered-point', 'circle-radius', [
      'case',
      ['==', ['get', 'slug'], selectedSlug],
      15,
      10,
    ])
    map.setPaintProperty('unclustered-point', 'circle-stroke-width', [
      'case',
      ['==', ['get', 'slug'], selectedSlug],
      5,
      2,
    ])
  }

  const fitMapToSpots = (items, options = {}) => {
    if (!map || !items.length) return
    const bounds = new mapboxgl.LngLatBounds()
    items.forEach((spot) => bounds.extend([spot.coordinates.lng, spot.coordinates.lat]))
    const padding = isCompact()
      ? { top: 72, right: 28, bottom: 300, left: 28 }
      : { top: 72, right: 72, bottom: 72, left: 72 }
    if (items.length === 1) {
      map.easeTo({
        center: [items[0].coordinates.lng, items[0].coordinates.lat],
        zoom: Math.max(map.getZoom(), 12),
        duration: options.immediate ? 0 : 650,
      })
      return
    }
    map.fitBounds(bounds, {
      padding,
      maxZoom: 11.5,
      duration: options.immediate ? 0 : 650,
    })
  }

  const renderEmptyDetail = () => {
    if (!detailContent) return
    detailContent.innerHTML = `
      <div class="spot-detail__empty">
        <i class="fa-solid fa-map-location-dot" aria-hidden="true"></i>
        <h3>No spots in this view</h3>
        <p>Clear a filter or search another town to bring the field notes back.</p>
      </div>
    `
  }

  const renderDetail = (spot) => {
    if (!detailContent || !spot) return
    const tags = spot.types
      .slice(0, 4)
      .map((type) => `<span class="spot-tag">${escapeHtml(type)}</span>`)
      .join('')
    const description = spot.description.map((paragraph) => `<p>${escapeHtml(paragraph)}</p>`).join('')
    const quotes = spot.quotes
      .map((quote) => `
        <blockquote>
          ${escapeHtml(quote.text)}
          ${quote.source ? `<cite>${escapeHtml(quote.source)}</cite>` : ''}
        </blockquote>
      `)
      .join('')
    const tips = spot.tips.map((tip) => `<li>${escapeHtml(tip)}</li>`).join('')
    const ctaHref = `/contact?service=Photoshooting&spot=${encodeURIComponent(spot.title)}&location=${encodeURIComponent(spot.city)}`
    detailContent.innerHTML = `
      <div class="spot-detail__media">
        <img src="${escapeHtml(spot.image.src)}" alt="${escapeHtml(spot.image.alt)}" width="${spot.image.width}" height="${spot.image.height}" loading="lazy" decoding="async" />
      </div>
      <div class="spot-detail__body">
        <div class="spot-detail__kicker">
          <span>${escapeHtml(spot.city)}</span>
          <span>${escapeHtml(spot.difficulty)}</span>
        </div>
        <h3>${escapeHtml(spot.title)}</h3>
        <div class="spot-detail__tags">${tags}</div>
        ${spot.isApproximate ? '<p class="spot-detail__note">Map pin is approximate; use the Google Maps link for navigation.</p>' : ''}
        ${spot.locationNote ? `<p class="spot-detail__note">${escapeHtml(spot.locationNote)}</p>` : ''}
        ${description}
        <div class="spot-detail__facts">
          <div><strong>Best time</strong><span>${escapeHtml(spot.bestTime)}</span></div>
          <div><strong>Cost</strong><span>${escapeHtml(spot.cost)}</span></div>
          <div><strong>Access</strong><span>${escapeHtml(spot.difficulty)}</span></div>
        </div>
        <div class="spot-detail__block">
          <h4>What people say</h4>
          ${quotes}
        </div>
        <div class="spot-detail__block">
          <h4>Photo tips</h4>
          <ul>${tips}</ul>
        </div>
        <div class="spot-detail__actions">
          <a class="spot-detail__map" href="${escapeHtml(spot.mapsUrl)}" target="_blank" rel="noreferrer">
            <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
            Google Maps
          </a>
          <button class="spot-detail__save" type="button" data-save-spot="${escapeHtml(spot.slug)}" aria-pressed="false">
            <i class="fa-regular fa-bookmark" aria-hidden="true"></i>
            <span>Save</span>
          </button>
          <a class="spot-detail__cta" href="${ctaHref}">
            Book photographer
          </a>
        </div>
      </div>
    `
    updateSaveButtons()
  }

  const setHash = (slug) => {
    if (!slug) return
    const next = `${window.location.pathname}${window.location.search}#${encodeURIComponent(slug)}`
    if (window.location.hash.replace(/^#/, '') !== encodeURIComponent(slug)) {
      window.history.replaceState(null, '', next)
    }
  }

  const selectSpot = (slug, options = {}) => {
    const spot = spots.find((item) => item.slug === slug)
    if (!spot) return
    selectedSlug = slug
    cards.forEach((card) => {
      const isSelected = card.dataset.spotSlug === slug
      card.classList.toggle('is-selected', isSelected)
      card.setAttribute('aria-selected', String(isSelected))
    })
    renderDetail(spot)
    refreshSelectedLayer()
    if (options.openDetail !== false) {
      detailPanel?.classList.add('is-open')
    }
    if (options.hash !== false) setHash(slug)
    if (options.scrollCard) {
      document.getElementById(`spot-card-${slug}`)?.scrollIntoView({ block: 'nearest', behavior: 'smooth' })
    }
    if (map && options.fly !== false) {
      map.easeTo({
        center: [spot.coordinates.lng, spot.coordinates.lat],
        zoom: Math.max(map.getZoom(), 12),
        duration: options.immediate ? 0 : 650,
      })
    }
  }

  const updateAppliedFilters = () => {
    if (!activeFiltersNode) return
    const chips = []
    if (query) {
      chips.push(`
        <button type="button" data-clear-search aria-label="Clear search">
          Search: ${escapeHtml(searchInput?.value || '')}
          <i class="fa-solid fa-xmark" aria-hidden="true"></i>
        </button>
      `)
    }
    Object.entries(activeFilters).forEach(([group, values]) => {
      values.forEach((value) => {
        chips.push(`
          <button type="button" data-remove-filter-group="${escapeHtml(group)}" data-remove-filter-value="${escapeHtml(value)}">
            ${escapeHtml(filterLabels[group])}: ${escapeHtml(value)}
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
          </button>
        `)
      })
    })
    activeFiltersNode.innerHTML = chips.join('')
    activeFiltersNode.hidden = chips.length === 0
  }

  const updateFilterButtons = () => {
    filterButtons.forEach((button) => {
      const group = button.dataset.filterGroup
      const value = button.dataset.filterValue
      const isActive = Boolean(group && value && activeFilters[group]?.has(value))
      button.setAttribute('aria-pressed', String(isActive))
    })
  }

  const updateFilteredView = ({ fit = true } = {}) => {
    const filtered = getFilteredSpots()
    const visibleSlugs = new Set(filtered.map((spot) => spot.slug))
    cards.forEach((card) => {
      card.hidden = !visibleSlugs.has(card.dataset.spotSlug)
    })
    visibleCounts.forEach((node) => {
      node.textContent = String(filtered.length)
    })
    if (emptyState) emptyState.hidden = filtered.length > 0
    const source = map?.getSource('photo-spots')
    if (source?.setData) source.setData(toGeoJson(filtered))
    if (!filtered.length) {
      selectedSlug = ''
      renderEmptyDetail()
      refreshSelectedLayer()
    } else if (!visibleSlugs.has(selectedSlug)) {
      selectSpot(filtered[0].slug, { fly: false, openDetail: !isCompact(), hash: false })
    } else {
      refreshSelectedLayer()
    }
    updateAppliedFilters()
    updateFilterButtons()
    if (fit) fitMapToSpots(filtered)
  }

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const group = button.dataset.filterGroup
      const value = button.dataset.filterValue
      if (!group || !value || !activeFilters[group]) return
      if (activeFilters[group].has(value)) {
        activeFilters[group].delete(value)
      } else {
        activeFilters[group].add(value)
      }
      updateFilteredView()
    })
  })

  searchInput?.addEventListener('input', (event) => {
    query = normalize(event.target.value)
    updateFilteredView()
  })

  clearFiltersButtons.forEach((button) => {
    button.addEventListener('click', () => {
      Object.values(activeFilters).forEach((set) => set.clear())
      query = ''
      if (searchInput) searchInput.value = ''
      updateFilteredView()
    })
  })

  activeFiltersNode?.addEventListener('click', (event) => {
    const clearSearch = event.target.closest('[data-clear-search]')
    if (clearSearch) {
      query = ''
      if (searchInput) searchInput.value = ''
      updateFilteredView()
      return
    }
    const chip = event.target.closest('[data-remove-filter-group]')
    const group = chip?.dataset.removeFilterGroup
    const value = chip?.dataset.removeFilterValue
    if (group && value && activeFilters[group]) {
      activeFilters[group].delete(value)
      updateFilteredView()
    }
  })

  root?.addEventListener('click', (event) => {
    const saveButton = event.target.closest('[data-save-spot]')
    if (saveButton) {
      const slug = saveButton.dataset.saveSpot
      const saved = new Set(getSavedSpots())
      if (saved.has(slug)) {
        saved.delete(slug)
      } else {
        saved.add(slug)
      }
      setSavedSpots([...saved])
      updateSaveButtons()
      return
    }

    const selectButton = event.target.closest('[data-select-spot]')
    const slug = selectButton?.dataset.selectSpot
    if (slug) {
      selectSpot(slug, { openDetail: true })
    }
  })

  openFiltersButton?.addEventListener('click', () => {
    filterDrawer?.classList.add('is-open')
    filterDrawer?.setAttribute('aria-hidden', 'false')
  })

  closeFiltersButtons.forEach((button) => {
    button.addEventListener('click', () => {
      filterDrawer?.classList.remove('is-open')
      filterDrawer?.setAttribute('aria-hidden', 'true')
    })
  })

  toggleResultsButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const isExpanded = root?.classList.toggle('is-results-expanded')
      toggleResultsButtons.forEach((toggle) => {
        toggle.setAttribute('aria-expanded', String(Boolean(isExpanded)))
      })
      window.setTimeout(() => map?.resize?.(), 280)
    })
  })

  closeDetailButton?.addEventListener('click', () => {
    detailPanel?.classList.remove('is-open')
  })

  fitAllButton?.addEventListener('click', () => {
    fitMapToSpots(getFilteredSpots())
  })

  window.addEventListener('hashchange', () => {
    const nextSlug = readHashSlug()
    if (spots.some((spot) => spot.slug === nextSlug)) {
      selectSpot(nextSlug, { hash: false, openDetail: true })
    }
  })

  compactQuery.addEventListener?.('change', () => {
    map?.resize?.()
    fitMapToSpots(getFilteredSpots(), { immediate: true })
  })

  const initMap = async () => {
    if (!mapboxToken || !mapCanvas || !spots.length) {
      mapFallback?.removeAttribute('hidden')
      return
    }

    const mapboxModule = await import('mapbox-gl')
    mapboxgl = mapboxModule.default
    mapboxgl.accessToken = mapboxToken
    map = new mapboxgl.Map({
      container: mapCanvas,
      style: 'mapbox://styles/mapbox/standard',
      config: {
        basemap: {
          theme: 'monochrome',
          lightPreset: 'day',
        },
      },
      center: [14.54, 40.62],
      zoom: 9.15,
      cooperativeGestures: true,
      dragRotate: false,
      pitchWithRotate: false,
      attributionControl: true,
    })

    map.addControl(new mapboxgl.NavigationControl({ showCompass: false }), 'bottom-right')

    map.on('load', () => {
      mapFallback?.setAttribute('hidden', 'true')
      map.addSource('photo-spots', {
        type: 'geojson',
        data: toGeoJson(getFilteredSpots()),
        generateId: true,
        cluster: true,
        clusterMaxZoom: 13,
        clusterRadius: 54,
      })

      map.addLayer({
        id: 'clusters',
        type: 'circle',
        source: 'photo-spots',
        filter: ['has', 'point_count'],
        paint: {
          'circle-color': ['step', ['get', 'point_count'], '#ffca3a', 4, '#ff5900', 9, '#0162ff'],
          'circle-radius': ['step', ['get', 'point_count'], 20, 4, 27, 9, 34],
          'circle-stroke-color': '#ffffff',
          'circle-stroke-width': 3,
          'circle-opacity': 0.95,
        },
      })

      map.addLayer({
        id: 'cluster-count',
        type: 'symbol',
        source: 'photo-spots',
        filter: ['has', 'point_count'],
        layout: {
          'text-field': ['get', 'point_count_abbreviated'],
          'text-font': ['DIN Offc Pro Medium', 'Arial Unicode MS Bold'],
          'text-size': 13,
        },
        paint: {
          'text-color': '#101419',
        },
      })

      map.addLayer({
        id: 'unclustered-point',
        type: 'circle',
        source: 'photo-spots',
        filter: ['!', ['has', 'point_count']],
        paint: {
          'circle-color': colorMatchExpression,
          'circle-radius': ['case', ['==', ['get', 'slug'], selectedSlug], 15, 10],
          'circle-stroke-width': ['case', ['==', ['get', 'slug'], selectedSlug], 5, 2],
          'circle-stroke-color': '#ffffff',
          'circle-opacity': 0.96,
        },
      })

      map.addLayer({
        id: 'point-label',
        type: 'symbol',
        source: 'photo-spots',
        filter: ['!', ['has', 'point_count']],
        minzoom: 10.6,
        layout: {
          'text-field': ['get', 'shortTitle'],
          'text-font': ['DIN Offc Pro Medium', 'Arial Unicode MS Regular'],
          'text-size': 11,
          'text-offset': [0, 1.55],
          'text-anchor': 'top',
        },
        paint: {
          'text-color': '#14171b',
          'text-halo-color': '#ffffff',
          'text-halo-width': 1.6,
        },
      })

      map.on('click', 'clusters', (event) => {
        const features = map.queryRenderedFeatures(event.point, { layers: ['clusters'] })
        const clusterId = features[0]?.properties?.cluster_id
        const source = map.getSource('photo-spots')
        if (!source || clusterId === undefined) return
        const applyZoom = (zoom) => {
          map.easeTo({
            center: features[0].geometry.coordinates,
            zoom,
            duration: 650,
          })
        }
        const result = source.getClusterExpansionZoom(clusterId, (error, zoom) => {
          if (!error) applyZoom(zoom)
        })
        if (result?.then) result.then(applyZoom).catch(() => {})
      })

      map.on('click', 'unclustered-point', (event) => {
        const slug = event.features?.[0]?.properties?.slug
        if (slug) {
          selectSpot(slug, { scrollCard: true, fly: false, openDetail: true })
          if (isCompact()) root?.classList.add('is-results-expanded')
        }
      })

      map.on('mouseenter', 'clusters', () => {
        map.getCanvas().style.cursor = 'pointer'
      })
      map.on('mouseleave', 'clusters', () => {
        map.getCanvas().style.cursor = ''
      })
      map.on('mouseenter', 'unclustered-point', () => {
        map.getCanvas().style.cursor = 'pointer'
      })
      map.on('mouseleave', 'unclustered-point', () => {
        map.getCanvas().style.cursor = ''
      })

      fitMapToSpots(getFilteredSpots(), { immediate: true })
    })
  }

  updateSaveButtons()
  updateAppliedFilters()
  updateFilterButtons()
  if (selectedSlug) {
    selectSpot(selectedSlug, { fly: false, hash: hasSpotHash, openDetail: Boolean(hasSpotHash && isCompact()) })
  }
  initMap()
</script>

